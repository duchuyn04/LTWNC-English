@model AdminAchievementIndexViewModel
@{
    ViewData["Title"] = "Thanh tich";
    ViewData["Heading"] = "Theo doi thanh tich";
}

<section class="admin-panel" aria-labelledby="achievement-sync-heading">
    <div class="admin-panel-header">
        <div>
            <h2 id="achievement-sync-heading">Dong bo lai thanh tich</h2>
            <p>Thao tac chi tinh lai tu du lieu hoc tap va catalog trong source code.</p>
        </div>
    </div>

    @if (TempData["AdminAchievementsSuccess"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success" role="status">@successMessage</div>
    }

    @if (TempData["AdminAchievementsError"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--danger" role="alert">@errorMessage</div>
    }

    <form method="post"
          action="/Admin/Achievements/ResyncAll"
          class="admin-filter-form"
          onsubmit="return confirm('Dong bo lai thanh tich cho toan he thong?');">
        @Html.AntiForgeryToken()
        <div class="admin-filter-field">
            <label for="all-reason">Ly do</label>
            <input id="all-reason" name="Reason" maxlength="500" required />
        </div>
        <div class="admin-filter-field admin-filter-field--compact">
            <label for="batch-size">Kich thuoc lo</label>
            <input id="batch-size" name="BatchSize" type="number" min="1" max="200" value="@Model.DefaultBatchSize" />
        </div>
        <label class="admin-checkbox-line">
            <input type="checkbox" name="Confirmed" value="true" required />
            Xac nhan tinh lai tu du lieu hoc tap
        </label>
        <button type="submit" class="admin-filter-submit">
            <i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Dong bo toan he thong
        </button>
    </form>
</section>

<section class="admin-panel" aria-labelledby="achievement-catalog-heading">
    <div class="admin-panel-header">
        <div>
            <h2 id="achievement-catalog-heading">Danh muc thanh tich</h2>
            <p>@Model.Catalog.Count dinh nghia doc tu source code</p>
        </div>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th scope="col">Thanh tich</th>
                    <th scope="col">Metric</th>
                    <th scope="col">Moc</th>
                    <th scope="col">Da nhan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (AdminAchievementDefinitionViewModel item in Model.Catalog)
                {
                    <tr>
                        <td>
                            <strong>@item.Title</strong>
                            <small class="admin-muted-line">@item.Code</small>
                            <small class="admin-muted-line">@item.Description</small>
                        </td>
                        <td>@item.MetricLabel</td>
                        <td>@item.Target.ToString("N0")</td>
                        <td>@item.RecipientCount.ToString("N0") nguoi dung</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="admin-panel" aria-labelledby="achievement-user-filter-heading">
    <div class="admin-panel-header">
        <div>
            <h2 id="achievement-user-filter-heading">Ket qua theo nguoi dung</h2>
            <p>@Model.TotalUsers nguoi dung - trang @Model.Page/@Model.TotalPages</p>
        </div>
    </div>

    <form method="get" action="/Admin/Achievements" class="admin-filter-form">
        <div class="admin-filter-field">
            <label for="search">Tim kiem</label>
            <input type="search" id="search" name="search" value="@Model.Search"
                   placeholder="Email, ten dang nhap hoac ma tai khoan" maxlength="200" />
        </div>
        <div class="admin-filter-field admin-filter-field--compact">
            <label for="pageSize">Dong/trang</label>
            <input type="number" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" max="100" />
        </div>
        <button type="submit" class="admin-filter-submit">
            <i class="ph ph-funnel" aria-hidden="true"></i> Loc
        </button>
    </form>
</section>

<section class="admin-panel" aria-labelledby="achievement-user-table-heading">
    <div class="admin-panel-header">
        <h2 id="achievement-user-table-heading">Bang ket qua</h2>
    </div>

    @if (Model.UserResults.Count == 0)
    {
        <p class="admin-empty">Khong co nguoi dung nao khop bo loc hien tai.</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th scope="col">Nguoi dung</th>
                        <th scope="col">Da nhan</th>
                        <th scope="col">Du dieu kien</th>
                        <th scope="col">Con thieu</th>
                        <th scope="col">Trang thai</th>
                        <th scope="col">Dong bo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminAchievementUserResultViewModel result in Model.UserResults)
                    {
                        <tr>
                            <td>
                                <strong>@result.UserName</strong>
                                <small class="admin-muted-line">@result.Email</small>
                                <small class="admin-muted-line">@result.UserId</small>
                            </td>
                            <td>
                                @result.UnlockedCount.ToString("N0")
                                <small class="admin-muted-line">Lan gan nhat: @result.LastUnlockedDisplay</small>
                            </td>
                            <td>@result.EligibleCount.ToString("N0")</td>
                            <td>
                                @result.MissingCount.ToString("N0")
                                <small class="admin-muted-line">@result.MissingCodesDisplay</small>
                            </td>
                            <td>
                                <span class="admin-status admin-status--@result.StatusTone">@result.StatusLabel</span>
                            </td>
                            <td>
                                <form method="post"
                                      action="/Admin/Achievements/ResyncUser"
                                      class="admin-inline-action-form"
                                      onsubmit="return confirm('Dong bo lai thanh tich cho nguoi dung nay?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TargetUserId" value="@result.UserId" />
                                    <label for="reason-@result.UserId">Ly do</label>
                                    <textarea id="reason-@result.UserId" name="Reason" maxlength="500" required></textarea>
                                    <label class="admin-checkbox-line">
                                        <input type="checkbox" name="Confirmed" value="true" required />
                                        Xac nhan tinh lai
                                    </label>
                                    <button type="submit" class="admin-filter-submit">
                                        <i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Dong bo lai
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="admin-pagination" aria-label="Phan trang ket qua thanh tich">
            @if (Model.HasPreviousPage)
            {
                <a href="@PageUrl(Model.Page - 1)">
                    <i class="ph ph-caret-left" aria-hidden="true"></i> Trang truoc
                </a>
            }
            <span aria-current="page">Trang @Model.Page / @Model.TotalPages</span>
            @if (Model.HasNextPage)
            {
                <a href="@PageUrl(Model.Page + 1)">
                    Trang sau <i class="ph ph-caret-right" aria-hidden="true"></i>
                </a>
            }
        </nav>
    }
</section>

@functions {
    // Tao URL phan trang va giu nguyen bo loc hien tai.
    private string PageUrl(int page)
    {
        var query = new List<string>
        {
            $"page={page}",
            $"pageSize={Model.PageSize}"
        };

        if (!string.IsNullOrEmpty(Model.Search))
        {
            query.Add($"search={Uri.EscapeDataString(Model.Search)}");
        }

        return $"/Admin/Achievements?{string.Join("&", query)}";
    }
}
