@{
    ViewData["Title"] = "Tổng quan";
    ViewData["Heading"] = "Trung tâm quản trị";
}

<section class="admin-intro" aria-labelledby="admin-intro-title">
    <div>
        <p class="eyebrow">TRUNG TÂM VẬN HÀNH</p>
        <h2 id="admin-intro-title">Khung quản trị đã sẵn sàng</h2>
        <p>
            Theo dõi người học, nội dung và dịch vụ vận hành từ một khu vực riêng được bảo vệ bằng vai trò Admin.
        </p>
    </div>
    <span class="admin-ready-badge"><i class="ph ph-check-circle" aria-hidden="true"></i> Khung sẵn sàng</span>
</section>

<section class="admin-foundation-grid" aria-label="Nền tảng quản trị">
    <article class="admin-foundation-card">
        <i class="ph ph-shield-check" aria-hidden="true"></i>
        <div>
            <h2>Truy cập được bảo vệ</h2>
            <p>Chỉ tài khoản thuộc vai trò Admin mới có thể mở khu vực này.</p>
        </div>
    </article>
    <article class="admin-foundation-card">
        <i class="ph ph-layout" aria-hidden="true"></i>
        <div>
            <h2>Một hệ thống thiết kế</h2>
            <p>Giao diện quản trị tái sử dụng màu sắc, kiểu chữ và thành phần chung của LTWNC.</p>
        </div>
    </article>
    <article class="admin-foundation-card">
        <i class="ph ph-chart-line-up" aria-hidden="true"></i>
        <div>
            <h2>Sẵn sàng mở rộng</h2>
            <p>Các chỉ số và chức năng vận hành sẽ được bổ sung theo từng hạng mục đã duyệt.</p>
        </div>
    </article>
</section>
