@model int
@{
    ViewData["Title"] = "Bảo mật phiên quản trị";
}

<section class="admin-page-header">
    <div>
        <p class="admin-page-eyebrow">Bảo mật</p>
        <h1>Bảo mật phiên quản trị</h1>
        <p>Các thao tác tại đây yêu cầu bạn đã xác nhận lại danh tính trong 15 phút gần nhất.</p>
    </div>
</section>

<section class="admin-panel">
    <h2>Mã khôi phục</h2>
    <p>Bạn còn <strong>@Model</strong> mã khôi phục chưa sử dụng.</p>
    <p>Bộ mã mới chỉ được cấp khi thiết lập xác thực hai bước.</p>
</section>
