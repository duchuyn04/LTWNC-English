@model AdminContentReportIndexViewModel
@{
    ViewData["Title"] = "Báo cáo nội dung";
    ViewData["Heading"] = "Hàng đợi báo cáo nội dung";
}

<section class="admin-panel" aria-labelledby="content-report-filter-heading">
    <div class="admin-panel-header">
        <div>
            <h2 id="content-report-filter-heading">Bộ lọc báo cáo</h2>
            <p>@Model.OverduePendingCount báo cáo đang chờ quá 24 giờ</p>
        </div>
    </div>

    @if (TempData["ContentReportsSuccess"] is string successMessage)
    {
        <div class="admin-alert admin-alert--success" role="status">@successMessage</div>
    }

    @if (TempData["ContentReportsError"] is string errorMessage)
    {
        <div class="admin-alert admin-alert--danger" role="alert">@errorMessage</div>
    }

    <form method="get" action="/Admin/ContentReports" class="admin-filter-form">
        <div class="admin-filter-field">
            <label for="search">Tìm kiếm</label>
            <input type="search" id="search" name="search" value="@Model.Search"
                   placeholder="Mã báo cáo, email, tiêu đề hoặc mã bộ" maxlength="200" />
        </div>
        <div class="admin-filter-field">
            <label for="status">Trạng thái</label>
            <select id="status" name="status">
                <option value="pending" selected="@(IsSelected(Model.Status, "pending"))">Đang chờ</option>
                <option value="all" selected="@(IsSelected(Model.Status, "all"))">Tất cả</option>
                <option value="dismissed" selected="@(IsSelected(Model.Status, "dismissed"))">Đã bác bỏ</option>
                <option value="quarantined" selected="@(IsSelected(Model.Status, "quarantined"))">Đã cách ly</option>
            </select>
        </div>
        <div class="admin-filter-field">
            <label for="reason">Lý do</label>
            <select id="reason" name="reason">
                <option value="">Tất cả lý do</option>
                @foreach (var option in Model.ReasonOptions)
                {
                    <option value="@option.Value" selected="@(Model.Reason == option.Value)">@option.Label</option>
                }
            </select>
        </div>
        <div class="admin-filter-field">
            <label for="sort">Sắp xếp</label>
            <select id="sort" name="sort">
                <option value="" selected="@(IsSelected(Model.Sort, ""))">Mới nhất</option>
                <option value="oldest" selected="@(IsSelected(Model.Sort, "oldest"))">Cũ nhất</option>
                <option value="reason" selected="@(IsSelected(Model.Sort, "reason"))">Theo lý do</option>
                <option value="status" selected="@(IsSelected(Model.Sort, "status"))">Theo trạng thái</option>
            </select>
        </div>
        <div class="admin-filter-field admin-filter-field--compact">
            <label for="pageSize">Dòng/trang</label>
            <input type="number" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" max="100" />
        </div>
        <button type="submit" class="admin-filter-submit">
            <i class="ph ph-funnel" aria-hidden="true"></i> Lọc
        </button>
    </form>
</section>

<section class="admin-panel" aria-labelledby="content-report-table-heading">
    <div class="admin-panel-header">
        <h2 id="content-report-table-heading">Danh sách báo cáo</h2>
        <p>@Model.TotalCount báo cáo - trang @Model.Page/@Model.TotalPages</p>
    </div>

    @if (Model.Items.Count == 0)
    {
        <p class="admin-empty">Không có báo cáo nào khớp bộ lọc hiện tại.</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table admin-content-report-table">
                <thead>
                    <tr>
                        <th scope="col">Báo cáo</th>
                        <th scope="col">Bộ flashcard</th>
                        <th scope="col">Người gửi</th>
                        <th scope="col">Lý do</th>
                        <th scope="col">Thời gian</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Xử lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminContentReportRowViewModel report in Model.Items)
                    {
                        <tr>
                            <td>
                                <strong>#@report.Id</strong>
                                <small class="admin-muted-line">Phiên bản @report.Version</small>
                            </td>
                            <td>
                                <a class="admin-text-link" href="/Admin/Content/@report.FlashcardSetId">
                                    @report.FlashcardSetTitle
                                </a>
                                <small class="admin-muted-line">Chủ sở hữu: @report.OwnerDisplay</small>
                            </td>
                            <td>@report.ReporterDisplay</td>
                            <td>
                                <strong>@report.ReasonLabel</strong>
                                @if (!string.IsNullOrWhiteSpace(report.Description))
                                {
                                    <small class="admin-muted-line">@report.Description</small>
                                }
                            </td>
                            <td>
                                @report.CreatedAtDisplay
                                <small class="admin-muted-line">@report.AgeDisplay</small>
                            </td>
                            <td>
                                <span class="admin-status admin-status--@report.StatusTone">@report.StatusLabel</span>
                            </td>
                            <td>
                                @if (report.CanDismiss)
                                {
                                    <form method="post"
                                          action="/Admin/ContentReports/@report.Id/Dismiss"
                                          class="admin-inline-action-form"
                                          onsubmit="return confirm('Bác bỏ báo cáo nội dung này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Version" value="@report.Version" />
                                        <label for="dismiss-reason-@report.Id">Lý do xử lý</label>
                                        <textarea id="dismiss-reason-@report.Id" name="Reason" maxlength="500" required></textarea>
                                        <button type="submit" class="admin-filter-submit">
                                            <i class="ph ph-x-circle" aria-hidden="true"></i> Bác bỏ
                                        </button>
                                    </form>
                                    <form method="post"
                                          action="/Admin/ContentReports/@report.Id/Quarantine"
                                          class="admin-inline-action-form"
                                          onsubmit="return confirm('Cách ly bộ flashcard từ báo cáo này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ReportVersion" value="@report.Version" />
                                        <input type="hidden" name="FlashcardSetVersion" value="@report.FlashcardSetVersion" />
                                        <label for="quarantine-public-reason-@report.Id">Lý do công khai</label>
                                        <textarea id="quarantine-public-reason-@report.Id" name="PublicReason" maxlength="500" required></textarea>
                                        <label for="quarantine-internal-note-@report.Id">Ghi chú nội bộ</label>
                                        <textarea id="quarantine-internal-note-@report.Id" name="InternalNote" maxlength="1000"></textarea>
                                        <label class="admin-checkbox-line">
                                            <input type="checkbox" name="Confirmed" value="true" required />
                                            Xác nhận cách ly
                                        </label>
                                        <button type="submit" class="admin-filter-submit admin-button-danger">
                                            <i class="ph ph-shield-warning" aria-hidden="true"></i> Cách ly
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span>@report.ResolutionReason</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="admin-pagination" aria-label="Phân trang báo cáo nội dung">
            @if (Model.HasPreviousPage)
            {
                <a href="@PageUrl(Model.Page - 1)">
                    <i class="ph ph-caret-left" aria-hidden="true"></i> Trang trước
                </a>
            }
            <span aria-current="page">Trang @Model.Page / @Model.TotalPages</span>
            @if (Model.HasNextPage)
            {
                <a href="@PageUrl(Model.Page + 1)">
                    Trang sau <i class="ph ph-caret-right" aria-hidden="true"></i>
                </a>
            }
        </nav>
    }
</section>

@functions {
    // So khớp giá trị select, mặc định status rỗng được hiểu là pending.
    private static bool IsSelected(string? currentValue, string optionValue)
    {
        string normalizedCurrent = currentValue?.Trim().ToLowerInvariant() ?? string.Empty;
        string normalizedOption = optionValue.Trim().ToLowerInvariant();

        if (string.IsNullOrEmpty(normalizedCurrent) && normalizedOption == "pending")
        {
            return true;
        }

        return normalizedCurrent == normalizedOption;
    }

    // Tạo URL phân trang và giữ nguyên các bộ lọc hiện tại.
    private string PageUrl(int page)
    {
        var query = new List<string>
        {
            $"page={page}",
            $"pageSize={Model.PageSize}"
        };

        if (!string.IsNullOrEmpty(Model.Search))
        {
            query.Add($"search={Uri.EscapeDataString(Model.Search)}");
        }

        if (!string.IsNullOrEmpty(Model.Status))
        {
            query.Add($"status={Uri.EscapeDataString(Model.Status)}");
        }

        if (!string.IsNullOrEmpty(Model.Reason))
        {
            query.Add($"reason={Uri.EscapeDataString(Model.Reason)}");
        }

        if (!string.IsNullOrEmpty(Model.Sort))
        {
            query.Add($"sort={Uri.EscapeDataString(Model.Sort)}");
        }

        return $"/Admin/ContentReports?{string.Join("&", query)}";
    }
}
