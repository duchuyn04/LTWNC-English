@model AdminUserIndexViewModel
@{
    ViewData["Title"] = "Người dùng";
    ViewData["Heading"] = "Quản lý người dùng";
}

<section class="admin-panel" aria-labelledby="user-filter-heading">
    <h2 id="user-filter-heading" class="visually-hidden">Bộ lọc người dùng</h2>
    <form method="get" action="/Admin/Users" class="admin-filter-form">
        <div class="admin-filter-field">
            <label for="search">Tìm kiếm</label>
            <input type="search" id="search" name="search" value="@Model.Search"
                   placeholder="Email, tên đăng nhập hoặc mã tài khoản" maxlength="200" />
        </div>
        <div class="admin-filter-field">
            <label for="status">Trạng thái</label>
            <select id="status" name="status">
                <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">Tất cả</option>
                <option value="unlocked" selected="@(Model.Status == "unlocked")">Đang mở</option>
                <option value="locked" selected="@(Model.Status == "locked")">Đang khóa</option>
                <option value="admin" selected="@(Model.Status == "admin")">Quản trị viên</option>
            </select>
        </div>
        <div class="admin-filter-field">
            <label for="sort">Sắp xếp</label>
            <select id="sort" name="sort">
                <option value="" selected="@(string.IsNullOrEmpty(Model.Sort))">Email A-Z</option>
                <option value="username" selected="@(Model.Sort == "username")">Tên đăng nhập</option>
                <option value="created" selected="@(Model.Sort == "created")">Mới tạo gần đây</option>
                <option value="locked" selected="@(Model.Sort == "locked")">Tài khoản khóa trước</option>
            </select>
        </div>
        <div class="admin-filter-field admin-filter-field--compact">
            <label for="pageSize">Dòng/trang</label>
            <input type="number" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" max="100" />
        </div>
        <button type="submit" class="admin-filter-submit">
            <i class="ph ph-funnel" aria-hidden="true"></i> Lọc
        </button>
    </form>
</section>

<section class="admin-panel" aria-labelledby="user-table-heading">
    <div class="admin-panel-header">
        <h2 id="user-table-heading">Danh sách tài khoản</h2>
        <p>@Model.TotalCount tài khoản - trang @Model.Page/@Model.TotalPages</p>
    </div>

    @if (Model.Items.Count == 0)
    {
        <p class="admin-empty">Không có tài khoản nào khớp bộ lọc hiện tại.</p>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th scope="col">Tài khoản</th>
                        <th scope="col">Email</th>
                        <th scope="col">Vai trò</th>
                        <th scope="col">Ngày tạo</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminUserRowViewModel user in Model.Items)
                    {
                        <tr>
                            <td>
                                <strong>@user.UserName</strong>
                                <small class="admin-muted-line">@user.Id</small>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.IsAdmin)
                                {
                                    <span class="admin-role-pill">Admin</span>
                                }
                                else
                                {
                                    <span>Người học</span>
                                }
                            </td>
                            <td>@user.CreatedAtDisplay</td>
                            <td>
                                <span class="admin-status admin-status--@user.StatusTone">@user.StatusLabel</span>
                            </td>
                            <td>
                                <a class="admin-text-link" href="/Admin/Users/@Uri.EscapeDataString(user.Id)">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="admin-pagination" aria-label="Phân trang người dùng">
            @if (Model.HasPreviousPage)
            {
                <a href="@PageUrl(Model.Page - 1)">
                    <i class="ph ph-caret-left" aria-hidden="true"></i> Trang trước
                </a>
            }
            <span aria-current="page">Trang @Model.Page / @Model.TotalPages</span>
            @if (Model.HasNextPage)
            {
                <a href="@PageUrl(Model.Page + 1)">
                    Trang sau <i class="ph ph-caret-right" aria-hidden="true"></i>
                </a>
            }
        </nav>
    }
</section>

@functions {
    // Tạo URL phân trang và giữ nguyên các bộ lọc hiện tại.
    private string PageUrl(int page)
    {
        var query = new List<string>
        {
            $"page={page}",
            $"pageSize={Model.PageSize}"
        };

        if (!string.IsNullOrEmpty(Model.Search))
        {
            query.Add($"search={Uri.EscapeDataString(Model.Search)}");
        }

        if (!string.IsNullOrEmpty(Model.Status))
        {
            query.Add($"status={Uri.EscapeDataString(Model.Status)}");
        }

        if (!string.IsNullOrEmpty(Model.Sort))
        {
            query.Add($"sort={Uri.EscapeDataString(Model.Sort)}");
        }

        return $"/Admin/Users?{string.Join("&", query)}";
    }
}
