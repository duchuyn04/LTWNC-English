@model AdminRecoveryCodesViewModel
@{
    ViewData["Title"] = "Mã khôi phục";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <section class="card-custom" aria-labelledby="recovery-codes-title">
            <p class="eyebrow">XÁC THỰC HAI BƯỚC</p>
            <h1 id="recovery-codes-title" class="h2">Mã khôi phục</h1>
            <p class="text-muted-custom">
                Lưu các mã này ở nơi an toàn. Mỗi mã chỉ dùng được một lần khi bạn không thể mở ứng dụng xác thực.
            </p>
            <div class="row g-2 my-4" aria-label="Danh sách mã khôi phục">
                @foreach (string recoveryCode in Model.RecoveryCodes)
                {
                    <div class="col-sm-6"><code class="d-block p-2 bg-light" data-recovery-code>@recoveryCode</code></div>
                }
            </div>
            <a class="btn-primary-custom" href="/Admin">Tiếp tục đến khu vực quản trị</a>
        </section>
    </div>
</div>
