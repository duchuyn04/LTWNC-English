@model AdminTwoFactorVerifyViewModel
@{
    ViewData["Title"] = "Xác minh hai bước";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <section class="card-custom" aria-labelledby="two-factor-verify-title">
            <p class="eyebrow">PHIÊN QUẢN TRỊ ĐẶC QUYỀN</p>
            <h1 id="two-factor-verify-title" class="h2">Xác minh hai bước</h1>
            <p class="text-muted-custom">Nhập mã sáu chữ số đang hiển thị trong ứng dụng xác thực.</p>

            <form action="/Account/AdminTwoFactor/Verify" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="mb-3"></div>
                <label asp-for="Code" class="form-label auth-label"></label>
                <input asp-for="Code" class="form-input-custom" inputmode="numeric" autocomplete="one-time-code" autofocus />
                <span asp-validation-for="Code"></span>
                <div class="form-check my-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="auth-label"></label>
                </div>
                <button type="submit" class="btn-primary-custom w-100">Xác minh</button>
            </form>

            <p class="auth-alt mt-3">
                Không mở được ứng dụng?
                <a asp-controller="AdminTwoFactor"
                   asp-action="RecoveryCode"
                   asp-route-returnUrl="@Model.ReturnUrl">Dùng mã khôi phục</a>
            </p>
        </section>
    </div>
</div>
