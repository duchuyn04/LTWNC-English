@model AdminTwoFactorSetupViewModel
@{
    ViewData["Title"] = "Thiết lập xác thực hai bước";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <section class="card-custom" aria-labelledby="two-factor-setup-title">
            <p class="eyebrow">BẢO VỆ TÀI KHOẢN QUẢN TRỊ</p>
            <h1 id="two-factor-setup-title" class="h2">Thiết lập xác thực hai bước</h1>
            <p class="text-muted-custom">
                Mở ứng dụng xác thực trên điện thoại, thêm tài khoản mới rồi nhập khóa bên dưới.
            </p>

            <div class="alert alert-info mt-4">
                <strong>Khóa thiết lập thủ công</strong>
                <code class="d-block mt-2 text-break">@Model.SharedKey</code>
            </div>

            <a class="btn-secondary-custom" href="@Model.AuthenticatorUri">Mở bằng ứng dụng xác thực</a>

            <form action="/Account/AdminTwoFactor/Setup" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mb-3"></div>
                <label asp-for="Code" class="form-label auth-label"></label>
                <input asp-for="Code" class="form-input-custom" inputmode="numeric" autocomplete="one-time-code" />
                <span asp-validation-for="Code"></span>
                <button type="submit" class="btn-primary-custom mt-3">Xác minh và bật bảo vệ</button>
            </form>
        </section>
    </div>
</div>
