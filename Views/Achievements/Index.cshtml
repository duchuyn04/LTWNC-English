@model IReadOnlyList<ltwnc.Models.ViewModels.Achievements.AchievementListItemViewModel>
@{
    // Trang danh sách huy hiệu: tiến độ, CTA, và banner khi vừa mở khóa
    ViewData["Title"] = "Thành tích";
    var unlockedCount = Model.Count(a => a.IsUnlocked);
}

@section Styles {
    <style>
        /* Trang thành tích — util minimal, khớp site đen/trắng */
        .ach-page {
            box-sizing: border-box;
            max-width: 720px;
            width: 100%;
            margin: 0 auto;
            padding: 2rem 1rem 3rem;
        }

        .ach-page *,
        .ach-page *::before,
        .ach-page *::after {
            box-sizing: border-box;
        }

        .ach-banner {
            background: #EDF3EC;
            color: #346538;
            border: 1px solid #C5DCC3;
            border-radius: 10px;
            padding: 0.85rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.95rem;
            font-weight: 500;
            line-height: 1.45;
            word-break: break-word;
        }

        .ach-hero {
            margin-bottom: 1.75rem;
        }

        .ach-hero h1 {
            font-size: clamp(1.35rem, 4vw, 1.75rem);
            font-weight: 700;
            color: #111;
            letter-spacing: -0.02em;
            margin: 0 0 0.35rem;
            word-break: break-word;
        }

        .ach-hero p {
            color: #787774;
            margin: 0;
        }

        .ach-grid {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            max-width: 100%;
        }

        .ach-card {
            border: 1px solid #EAEAEA;
            border-radius: 12px;
            padding: 1rem 1.15rem;
            background: #fff;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            max-width: 100%;
            overflow: hidden;
        }

        .ach-card.is-locked {
            opacity: 0.72;
            background: #FAFAFA;
        }

        .ach-card.is-unlocked {
            opacity: 1;
            background: #fff;
        }

        .ach-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            flex-shrink: 0;
            background: #111;
            color: #fff;
        }

        .ach-card.is-locked .ach-icon {
            background: #EAEAEA;
            color: #787774;
        }

        .ach-body {
            flex: 1;
            min-width: 0;
            max-width: 100%;
        }

        .ach-title {
            font-weight: 600;
            color: #111;
            margin: 0 0 0.25rem;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .ach-desc {
            color: #787774;
            font-size: 0.92rem;
            margin: 0 0 0.5rem;
            word-break: break-word;
        }

        .ach-meta {
            font-size: 0.8rem;
            color: #9B9A97;
            margin: 0 0 0.5rem;
        }

        .ach-done {
            font-size: 0.85rem;
            color: #9B9A97;
            margin: 0.35rem 0 0;
            font-style: italic;
        }

        /* Thanh tiến độ */
        .ach-progress {
            margin-top: 0.35rem;
            max-width: 100%;
        }

        .ach-progress__meta {
            font-size: 0.8rem;
            color: #787774;
            margin-bottom: 0.35rem;
            font-variant-numeric: tabular-nums;
        }

        .ach-progress__track {
            width: 100%;
            max-width: 100%;
            min-height: 8px;
            height: 8px;
            background: #EAEAEA;
            border-radius: 999px;
            overflow: hidden;
        }

        .ach-progress__fill {
            height: 100%;
            min-height: 8px;
            background: #111;
            border-radius: 999px;
            transition: width 0.25s ease;
            max-width: 100%;
        }

        .ach-card.is-unlocked .ach-progress__fill {
            background: #346538;
        }

        /* CTA khi chưa mở khóa */
        .ach-cta {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-top: 0.75rem;
            padding: 0.5rem 1rem;
            min-height: 40px;
            background: #111;
            color: #fff;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.15s ease, transform 0.1s ease;
            max-width: 100%;
            word-break: break-word;
            text-align: center;
        }

        .ach-cta:hover {
            background: #333;
            color: #fff;
            text-decoration: none;
        }

        .ach-cta:active {
            transform: scale(0.98);
        }

        .ach-empty {
            border: 1px dashed #EAEAEA;
            border-radius: 12px;
            padding: 2rem;
            text-align: center;
            color: #787774;
        }

        /* Mobile: ít padding, CTA dễ bấm */
        @@media (max-width: 480px) {
            .ach-page {
                padding: 1.25rem 0.75rem 2.5rem;
            }

            .ach-card {
                padding: 0.85rem 0.9rem;
                gap: 0.75rem;
            }

            .ach-icon {
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
            }

            .ach-cta {
                display: flex;
                width: 100%;
                min-height: 44px;
                padding: 0.65rem 1rem;
            }

            .ach-banner {
                padding: 0.75rem 0.85rem;
                font-size: 0.9rem;
            }
        }
    </style>
}

<div class="ach-page">
    @* Banner một lần khi rescan vừa mở huy hiệu mới *@
    @if (TempData["AchievementUnlock"] is string unlockMsg)
    {
        <div class="ach-banner" role="status">@unlockMsg</div>
    }

    <div class="ach-hero">
        <h1><i class="ph ph-trophy" aria-hidden="true"></i> Thành tích</h1>
        <p>Bạn đã mở @unlockedCount / @Model.Count huy hiệu. Học flashcard hoặc nghe chép để mở thêm.</p>
    </div>

    @if (Model.Count == 0)
    {
        <div class="ach-empty">
            Chưa có huy hiệu nào trong hệ thống.
        </div>
    }
    else
    {
        <div class="ach-grid">
            @foreach (var item in Model)
            {
                var unlockedAttr = item.IsUnlocked ? "true" : "false";
                <div class="ach-card @(item.IsUnlocked ? "is-unlocked" : "is-locked")"
                     data-code="@item.Code"
                     data-unlocked="@unlockedAttr">
                    <div class="ach-icon" aria-hidden="true">
                        <i class="ph @(item.IsUnlocked ? "ph-medal" : "ph-lock-simple")"></i>
                    </div>
                    <div class="ach-body">
                        <p class="ach-title">@item.Title</p>
                        <p class="ach-desc">@item.Description</p>

                        @if (item.IsUnlocked)
                        {
                            @if (item.UnlockedAt.HasValue)
                            {
                                <p class="ach-meta">
                                    Đã mở lúc @item.UnlockedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </p>
                            }
                            <div class="ach-progress">
                                <div class="ach-progress__meta">@item.Current / @item.Target</div>
                                <div class="ach-progress__track">
                                    <div class="ach-progress__fill"
                                         role="progressbar"
                                         aria-valuenow="@item.ProgressPercent"
                                         aria-valuemin="0"
                                         aria-valuemax="100"
                                         style="width: @(item.ProgressPercent)%"></div>
                                </div>
                            </div>
                            <p class="ach-done">Đã hoàn thành</p>
                        }
                        else
                        {
                            <div class="ach-progress">
                                <div class="ach-progress__meta">@item.Current / @item.Target</div>
                                <div class="ach-progress__track">
                                    <div class="ach-progress__fill"
                                         role="progressbar"
                                         aria-valuenow="@item.ProgressPercent"
                                         aria-valuemin="0"
                                         aria-valuemax="100"
                                         style="width: @(item.ProgressPercent)%"></div>
                                </div>
                            </div>
                            <a class="ach-cta" href="@item.CtaUrl">@item.CtaText</a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
