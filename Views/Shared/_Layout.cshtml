<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LTWNC English</title>
    <meta name="description" content="LTWNC English giúp bạn học từ vựng bằng flashcard, nghe chép, hội thoại tình huống và theo dõi tiến độ." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Newsreader:ital,opsz,wght@0,6..72,500..800;1,6..72,500..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/phosphor-icons@1.4.2/src/css/icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="pt-overlay" class="pt-overlay--visible"></div>
    <noscript>
        <style>
            #pt-overlay { display: none !important; }
        </style>
    </noscript>

    @{
        var hideLayoutChrome = ViewData["HideLayoutChrome"] as bool? == true;
        var signedIn = User.Identity?.IsAuthenticated == true;
    }
    @if (!hideLayoutChrome)
    {
    <header>
        <nav class="navbar navbar-expand-lg app-nav">
            <div class="container">
                <a class="navbar-brand app-nav-brand" href="/">
                    <i class="ph ph-book-open"></i> LTWNC
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Mở menu điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Leaderboard">Bảng xếp hạng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Library">Thư viện</a>
                        </li>
                        @if (signedIn)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Set">Bộ thẻ của tôi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Achievements">Thành tích</a>
                            </li>
                            @if (User.IsInRole(ltwnc.Services.Auth.AdminRoleBootstrapper.AdminRole))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Admin">Quản trị</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-lg-center">
                        @if (signedIn)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="ph ph-user-circle"></i> @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-route="PublicProfile"
                                           asp-route-username="@User.Identity?.Name">
                                            <i class="ph ph-user"></i> Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/Account/Profile/Edit">
                                            <i class="ph ph-pencil-simple"></i> Chỉnh sửa profile
                                        </a>
                                    </li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item p-0">
                                            <button type="submit" class="dropdown-item">
                                                <i class="ph ph-sign-out"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="btn-primary-custom app-nav-cta" href="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    }

    <main class="app-main">
        @if (IsSectionDefined("FullWidth"))
        {
            @RenderSection("FullWidth", required: false)
        }
        else
        {
            <div class="container py-5">
                @RenderBody()
            </div>
        }
    </main>

    @if (!hideLayoutChrome)
    {
    <footer class="app-footer">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="app-footer-brand"><i class="ph ph-book-open"></i> LTWNC</div>
                    <p class="app-footer-tagline">Học từ vựng bằng flashcard, nghe chép và hội thoại tình huống.</p>
                </div>
                <div class="col-lg-3 col-6">
                    <div class="app-footer-heading">Điều hướng</div>
                    <ul class="app-footer-links">
                        <li><a href="/">Trang chủ</a></li>
                        <li><a href="/Leaderboard">Bảng xếp hạng</a></li>
                        <li><a href="/Library">Thư viện</a></li>
                        @if (signedIn)
                        {
                            <li><a href="/Set">Bộ thẻ của tôi</a></li>
                            <li><a href="/Achievements">Thành tích</a></li>
                        }
                        else
                        {
                            <li><a href="/Account/Login">Đăng nhập</a></li>
                            <li><a href="/Account/Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
                <div class="col-lg-4 col-6">
                    <div class="app-footer-heading">LTWNC English</div>
                    <p class="app-footer-quote">Flashcard · Nghe chép · English Mission</p>
                </div>
            </div>
            <div class="app-footer-bottom">
                &copy; @DateTime.Now.Year LTWNC English. Học tiếng Anh theo nhiều cách.
            </div>
        </div>
    </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/page-transition.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
