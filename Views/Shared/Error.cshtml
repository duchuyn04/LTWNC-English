@model ErrorViewModel
@{
    ViewData["Title"] = "Có lỗi xảy ra";
}

<section class="mx-auto gsap-fade-up col-12 col-lg-8">
    <div class="card-custom p-4 p-md-5">
        <p class="eyebrow mb-2">Tạm gián đoạn</p>
        <h1 class="mb-3">Chúng tôi chưa thể hoàn tất yêu cầu này.</h1>
        <p class="text-muted-custom mb-4">
            Hãy thử tải lại trang sau ít phút. Nếu lỗi vẫn tiếp diễn, mã yêu cầu bên dưới sẽ giúp chúng tôi kiểm tra nhanh hơn.
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="mb-4 p-3 rounded-3 border bg-body-tertiary">
                <span class="d-block text-muted-custom small mb-1">Mã yêu cầu</span>
                <code class="text-dark text-break">@Model.RequestId</code>
            </div>
        }

        <div class="d-flex flex-wrap gap-2">
            <a class="btn-primary-custom" href="/">Về trang chủ</a>
            <button class="btn-secondary-custom" type="button" onclick="window.location.reload()">Thử lại</button>
        </div>
    </div>
</section>
