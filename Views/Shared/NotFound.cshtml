@{
    Layout = null;
    ViewData["Title"] = "Không tìm thấy trang";
    ViewData["HideLayoutChrome"] = true;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Không tìm thấy trang - LTWNC English</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Newsreader:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/not-found.css" asp-append-version="true" />
</head>
<body>
    <main class="wrong-turn-page">
        <section class="not-found-landscape" aria-label="Minh họa trang không tìm thấy">
            <div class="not-found-sky"></div><div class="not-found-hill not-found-hill-back"></div><div class="not-found-hill not-found-hill-front"></div>
            <div class="not-found-sign"><strong>LTWNC</strong><span>HOME / UNKNOWN</span></div>
            <article class="not-found-card" data-vocabulary-card tabindex="0" role="button" aria-pressed="false">
                <div class="not-found-card-face not-found-card-front"><span class="not-found-label">VOCABULARY NOTE</span><h1>wrong turn</h1><p><b>n.</b> a direction that takes you somewhere unexpected</p><small>Chọn "Lật thẻ" để xem ví dụ</small></div>
                <div class="not-found-card-face not-found-card-back"><span class="not-found-label">EXAMPLE</span><h1>wrong turn</h1><p>I took a wrong turn, but found a new route.</p><small>phát âm: /rɔːŋ tɜːrn/</small></div>
            </article>
            <button class="not-found-flip" type="button" data-flip-card aria-pressed="false">Lật thẻ</button>
        </section>
        <section class="not-found-message"><p class="not-found-eyebrow">404 / WRONG TURN</p><h2>Bạn vừa rẽ nhầm một hướng.</h2><p>Trang bạn tìm không tồn tại, nhưng bạn có thể học nhanh một từ mới trước khi quay lại.</p><a class="not-found-home" href="/">Về trang chủ</a></section>
    </main>
    <script src="~/js/not-found.js" asp-append-version="true"></script>
</body>
</html>
