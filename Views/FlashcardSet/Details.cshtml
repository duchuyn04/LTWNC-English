@model SetDetailViewModel
@using ltwnc.Areas.Admin
@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="~/css/set-management.css" asp-append-version="true" />

<div class="set-management-shell">
    <div class="set-detail-hero">
        <h2>@Model.Title</h2>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
        else
        {
            <p>@(Model.IsPublic ? "Bộ thẻ công khai" : "Bộ thẻ riêng tư") · @Model.Flashcards.Count thẻ</p>
        }

        <div class="set-detail-stats">
            <div class="set-detail-stat">
                <div class="set-detail-stat-value">0%</div>
                <div class="set-detail-stat-label">Tiến độ</div>
            </div>
            <div class="set-detail-stat">
                <div class="set-detail-stat-value">0</div>
                <div class="set-detail-stat-label">Đã thuộc</div>
            </div>
            <div class="set-detail-stat">
                <div class="set-detail-stat-value">@Model.Flashcards.Count</div>
                <div class="set-detail-stat-label">Tổng số</div>
            </div>
        </div>

        @if (Model.IsOwner && Model.IsQuarantined)
        {
            <div class="set-report-alert set-report-alert--danger" role="alert">
                Bộ flashcard này đang bị cách ly khỏi tìm kiếm, chia sẻ, sao chép và học công khai.
                @if (!string.IsNullOrWhiteSpace(Model.ModerationPublicReason))
                {
                    <span>Lý do: @Model.ModerationPublicReason</span>
                }
                @if (Model.ModeratedAtUtc.HasValue)
                {
                    <span>Thời điểm xử lý: @FormatVietnamTime(Model.ModeratedAtUtc.Value)</span>
                }
            </div>
        }

        <div class="d-flex gap-2 justify-content-center flex-wrap">
            @if (Model.IsOwner)
            {
                <a href="/Set/@Model.Id/Edit" class="btn-secondary-custom">
                    <i class="ph ph-pencil"></i> Quản lý
                </a>
                <a href="/Study/@Model.Id" class="btn-primary-custom">
                    <i class="ph ph-play-circle"></i> Bắt đầu học
                </a>
            }
            else if (User.Identity?.IsAuthenticated == true)
            {
                if (Model.ExistingCopyId.HasValue)
                {
                    <a href="/Study/@Model.ExistingCopyId" class="btn-primary-custom">
                        <i class="ph ph-play-circle"></i> Mở bộ đã sao chép
                    </a>
                }
                else
                {
                    <form asp-action="Copy" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary-custom">
                            <i class="ph ph-copy"></i> Sao chép và học
                        </button>
                    </form>
                }
            }
            else
            {
                <a href="/Account/Login?ReturnUrl=@Uri.EscapeDataString($"/Set/{Model.Id}")" class="btn-primary-custom">
                    <i class="ph ph-sign-in"></i> Đăng nhập để học
                </a>
            }
        </div>
    </div>

    @if (TempData["ContentReportSuccess"] is string reportSuccess)
    {
        <div class="set-report-alert set-report-alert--success" role="status">@reportSuccess</div>
    }

    @if (TempData["ContentReportError"] is string reportError)
    {
        <div class="set-report-alert set-report-alert--danger" role="alert">@reportError</div>
    }

    @if (Model.CanReport)
    {
        <section class="set-report-panel" aria-labelledby="report-content-heading">
            <div>
                <h3 id="report-content-heading">Báo cáo bộ flashcard</h3>
                <p>Chọn lý do cố định và thêm mô tả nếu cần.</p>
            </div>
            <form asp-action="Report" asp-route-id="@Model.Id" method="post" class="set-report-form">
                @Html.AntiForgeryToken()
                <div>
                    <label for="report-reason">Lý do</label>
                    <select id="report-reason" name="Reason" required>
                        <option value="">Chọn lý do</option>
                        @foreach (var option in Model.ReportReasonOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="report-description">Mô tả thêm</label>
                    <textarea id="report-description" name="Description" maxlength="1000" rows="4"></textarea>
                </div>
                <button type="submit" class="btn-secondary-custom">
                    <i class="ph ph-flag" aria-hidden="true"></i> Gửi báo cáo
                </button>
            </form>
        </section>
    }
    else if (Model.HasOpenReport)
    {
        <div class="set-report-alert" role="status">
            Bạn đã có một báo cáo đang chờ xử lý cho bộ flashcard này.
        </div>
    }

    @if (Model.Flashcards.Any())
    {
        <div class="set-detail-list">
            <div class="set-detail-list-header">
                <h3>Danh sách từ</h3>
                @if (Model.IsOwner)
                {
                    <a href="/Set/@Model.Id/Edit" class="btn-secondary-custom set-detail-list-action">Quản lý</a>
                }
            </div>
            @foreach (var card in Model.Flashcards.OrderBy(c => c.OrderIndex))
            {
                <div class="set-detail-row">
                    <div>
                        <div class="set-detail-term">@card.FrontText</div>
                        <small class="set-detail-meta">@card.PartOfSpeech · @card.Pronunciation</small>
                    </div>
                    <div class="set-detail-definition">@card.BackText</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="set-empty-state">
            <div class="set-empty-state-icon"><i class="ph ph-note-pencil" aria-hidden="true"></i></div>
            <p class="set-empty-state-title">Bộ thẻ này chưa có từ nào.</p>
            @if (Model.IsOwner)
            {
                <a href="/Set/@Model.Id/Edit" class="btn-primary-custom">Thêm từ đầu tiên</a>
            }
        </div>
    }
</div>

@functions {
    private static string FormatVietnamTime(DateTime valueUtc)
    {
        return AdminTimeZone.ToVietnamTime(valueUtc).ToString("HH:mm dd/MM/yyyy");
    }
}
