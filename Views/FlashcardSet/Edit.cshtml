@model EditSetViewModel
@{
    ViewData["Title"] = "Quản lý bộ thẻ";
    var cards = ViewBag.Cards as List<ltwnc.Models.Entities.Flashcard> ?? new();
    var importErrorsJson = TempData["ImportErrors"] as string;
    var importErrors = string.IsNullOrWhiteSpace(importErrorsJson)
        ? Array.Empty<ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError>()
        : System.Text.Json.JsonSerializer.Deserialize<ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError[]>(importErrorsJson)
            ?? Array.Empty<ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError>();
}

<link rel="stylesheet" href="~/css/set-management.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/edit.css" asp-append-version="true" />

<div class="set-management-shell">
<div class="set-editor-layout">
    <aside class="set-editor-sidebar">
        <nav aria-label="Điều hướng trình chỉnh sửa bộ thẻ">
            <a href="#set-info">Thông tin bộ thẻ</a>
            <a href="#file-import">Nhập từ tệp</a>
            <a href="#card-list">Danh sách từ</a>
            <a href="#add-card-form">Thêm từ mới</a>
        </nav>
    </aside>

    <div class="set-editor-content">
<div class="row justify-content-center gsap-fade-up">
    <div class="col-md-10 col-lg-8">
        <div id="set-info" class="set-form-card mb-4 gsap-scale-in">
            <h1 style="margin: 0 0 0.25rem; font-size: 1.5rem; font-weight: 800; color: var(--sm-ink);">Quản lý bộ thẻ</h1>

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mt-4 gsap-stagger">
                <div asp-validation-summary="ModelOnly" class="mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="set-form-label"></label>
                    <input asp-for="Title" class="set-form-input" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="set-form-label"></label>
                    <textarea asp-for="Description" class="set-form-input set-form-textarea" rows="3"></textarea>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="IsPublic" class="form-check-input" />
                    <label asp-for="IsPublic" style="font-size: 0.875rem; color: #57534e;">Công khai</label>
                </div>

                <button type="submit" class="btn-primary-custom">Lưu thông tin bộ thẻ</button>
                <a href="/Set" class="btn-secondary-custom ms-2">Hủy</a>
            </form>
        </div>

        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success d-flex justify-content-between align-items-center">
                <span>@success</span>
                @if (TempData["UndoLogId"] is int undoLogId)
                {
                    <form asp-controller="CardActions" asp-action="Undo" asp-route-logId="@undoLogId" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-link">Hoàn tác</button>
                    </form>
                }
            </div>
        }

        <div id="file-import" class="set-form-card mb-4">
            <h2 style="margin: 0 0 0.5rem; font-size: 1.15rem; font-weight: 800; color: var(--sm-ink);">Nhập thẻ từ tệp</h2>
            <p class="text-muted mb-3">Chọn tệp CSV UTF-8 hoặc XLSX. Sáu cột bắt buộc: <code>THUẬT NGỮ</code>, <code>ĐỊNH NGHĨA</code>, <code>IPA</code>, <code>LOẠI TỪ</code>, <code>VÍ DỤ TIẾNG ANH</code>, <code>NGHĨA VÍ DỤ TIẾNG VIỆT</code>. Cột tùy chọn: <code>TỪ ĐỒNG NGHĨA</code>, <code>URL ẢNH</code>.</p>
            <form asp-action="Import" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="d-flex flex-wrap align-items-end gap-2">
                @Html.AntiForgeryToken()
                <div>
                    <label for="flashcard-import-file" class="set-form-label">Tệp dữ liệu</label>
                    <input id="flashcard-import-file" type="file" name="file" class="form-input-custom" accept=".csv,.xlsx" required />
                </div>
                <button type="submit" class="btn-primary-custom">Nhập thẻ</button>
                <a href="~/templates/flashcard-import-template.csv" download class="btn-secondary-custom">Tải mẫu CSV</a>
            </form>
        </div>

        @if (TempData["ImportImportedCount"] is not null || TempData["ImportSkippedCount"] is not null)
        {
            <div class="alert alert-info">
                Đã nhập <strong>@(TempData["ImportImportedCount"] ?? 0)</strong> thẻ; bỏ qua <strong>@(TempData["ImportSkippedCount"] ?? 0)</strong> dòng.
                @if (importErrors.Length > 0)
                {
                    <ul class="mb-0 mt-2">
                        @foreach (var importError in importErrors)
                        {
                            <li>Dòng @importError.RowNumber: @importError.Reason</li>
                        }
                    </ul>
                }
            </div>
        }

        <div id="card-list" class="vocab-editor gsap-fade-up">
            <aside class="vocab-list gsap-stagger">
                <div class="vocab-list-header">
                    <h5>Danh sách từ</h5>
                </div>

                @if (!cards.Any())
                {
                    <p style="color: #787774;">Chưa có thẻ nào.</p>
                }
                else
                {
                    <form asp-controller="CardActions" asp-action="BatchAction" asp-route-setId="@Model.Id" method="post" id="batch-form">
                        @Html.AntiForgeryToken()
                        <div class="batch-toolbar mb-3">
                            <button type="submit" name="action" value="Delete" class="btn-secondary-custom" onclick="return confirm('Xóa các thẻ đã chọn?');">
                                <i class="ph ph-trash"></i> Xóa đã chọn
                            </button>
                            <button type="submit" name="action" value="Star" class="btn-secondary-custom">
                                <i class="ph ph-star"></i> Đánh sao
                            </button>
                            <button type="submit" name="action" value="Unstar" class="btn-secondary-custom">
                                <i class="ph ph-star-off"></i> Bỏ sao
                            </button>
                        </div>

                        @foreach (var card in cards.OrderBy(c => c.OrderIndex))
                        {
                            <div class="vocab-list-item-wrapper">
                                <input type="checkbox" name="selectedCardIds" value="@card.Id" class="card-checkbox" />
                                <button type="button"
                                        class="vocab-list-item @(card == cards.OrderBy(c => c.OrderIndex).First() ? "is-active" : "")"
                                        data-card-id="@card.Id">
                                    <span class="vocab-star">@(card.IsStarred ? "★" : "☆")</span>
                                    <span class="vocab-list-copy">
                                        <strong>@card.FrontText</strong>
                                        <small>@card.PartOfSpeech · @card.Pronunciation</small>
                                        <span>@card.BackText</span>
                                    </span>
                                </button>
                            </div>
                        }
                    </form>
                }
            </aside>

            <section class="vocab-detail">
                @foreach (var card in cards.OrderBy(c => c.OrderIndex))
                {
                    <div class="vocab-card-panel" data-card-panel="@card.Id">
                        <form asp-action="EditCard"
                              asp-route-id="@card.Id"
                              method="post"
                              enctype="multipart/form-data"
                              class="vocab-card-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="setId" value="@card.FlashcardSetId" />
                            
                            <div class="vocab-form-header">
                                <div>
                                    <span class="vocab-form-label">Đang chỉnh sửa</span>
                                    <h5>@card.FrontText</h5>
                                </div>
                                <div class="vocab-form-actions">
                                    <input type="checkbox"
                                           name="isStarred"
                                           value="true"
                                           id="star-card-@card.Id"
                                           class="star-checkbox"
                                           data-toggle-star-url="@Url.Action("ToggleStar", "FlashcardSet", new { setId = Model.Id, cardId = card.Id })"
                                           data-card-id="@card.Id"
                                           data-star-target="#star-label-@card.Id"
                                           aria-label="Đánh sao thẻ @card.FrontText"
                                           @(card.IsStarred ? "checked" : "") />
                                    <label id="star-label-@card.Id" for="star-card-@card.Id" class="star-toggle">
                                        <span>Đánh sao</span>
                                    </label>
                                    <button type="submit" class="btn-primary-custom">Lưu từ</button>
                                </div>
                            </div>

                            <div class="vocab-grid">
                                <label>
                                    <span>Thuật ngữ <b>*</b></span>
                                    <input type="text" name="frontText" value="@card.FrontText" class="form-input-custom" required />
                                </label>
                                <label>
                                    <span>Định nghĩa <b>*</b></span>
                                    <input type="text" name="backText" value="@card.BackText" class="form-input-custom" required />
                                </label>
                                <label>
                                    <span>IPA <b>*</b></span>
                                    <input type="text" name="pronunciation" value="@card.Pronunciation" class="form-input-custom" required />
                                </label>
                                <label>
                                    <span>Loại từ <b>*</b></span>
                                    <input type="text" name="partOfSpeech" value="@card.PartOfSpeech" list="partOfSpeechOptions" class="form-input-custom" required />
                                </label>
                            </div>

                            <label class="vocab-wide-field">
                                <span>Ví dụ tiếng Anh <b>*</b></span>
                                <textarea name="exampleSentence" class="form-input-custom" rows="2" required>@card.ExampleSentence</textarea>
                            </label>

                            <label class="vocab-wide-field">
                                <span>Nghĩa câu ví dụ tiếng Việt <b>*</b></span>
                                <textarea name="exampleMeaning" class="form-input-custom" rows="2" required>@card.ExampleMeaning</textarea>
                            </label>

                            <label class="vocab-wide-field">
                                <span>Từ đồng nghĩa</span>
                                <input type="text" name="synonyms" value="@card.Synonyms" class="form-input-custom" />
                            </label>

                            <div class="vocab-grid mt-2">
                                <label>
                                    <span>Đường dẫn ảnh (URL)</span>
                                    <input type="text" name="imageUrl" value="@card.ImageUrl" class="form-input-custom" placeholder="https://example.com/image.png" />
                                </label>
                                <label>
                                    <span>Tải ảnh lên (Max 2MB)</span>
                                    <input type="file" name="imageFile" class="form-input-custom" accept=".jpg,.jpeg,.png,.webp" />
                                </label>
                            </div>
                            @if (!string.IsNullOrEmpty(card.UploadedImagePath))
                            {
                                <div class="mt-2 d-flex align-items-center gap-3">
                                    <img src="@card.UploadedImagePath" alt="Uploaded image" style="max-height: 80px; border-radius: 6px; border: 1px solid #EAEAEA;" />
                                    <label class="form-check d-flex align-items-center gap-2" style="font-size: 0.85rem; color: #dc3545; cursor: pointer; margin-bottom: 0;">
                                        <input type="checkbox" name="removeUploadedImage" value="true" class="form-check-input" style="margin-top: 0;" />
                                        <span>Xóa ảnh đã tải lên</span>
                                    </label>
                                </div>
                            }
                        </form>

                        <form asp-action="DeleteCard"
                              asp-route-id="@card.Id"
                              method="post"
                              class="vocab-delete-form"
                              onsubmit="return confirm('Xóa thẻ này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-secondary-custom">
                                <i class="ph ph-trash"></i> Xóa từ
                            </button>
                        </form>
                    </div>
                }
            </section>
        </div>

        <section class="set-form-card mb-4">
                <form id="add-card-form"
                      asp-action="AddCard"
                      asp-route-setId="@Model.Id"
                      method="post"
                      enctype="multipart/form-data"
                      class="vocab-card-form add-card-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="isStarred" value="false" />
                    
                    <div class="vocab-form-header">
                        <div>
                            <span class="vocab-form-label">Thêm mới</span>
                            <h5>Thêm từ vựng</h5>
                        </div>
                        <div class="vocab-form-actions">
                            <button type="submit" class="btn-primary-custom">Thêm từ</button>
                        </div>
                    </div>

                    <div class="vocab-grid">
                        <label>
                            <span>Thuật ngữ <b>*</b></span>
                            <input type="text" name="frontText" class="form-input-custom" aria-label="Thuật ngữ" required />
                        </label>
                        <label>
                            <span>Định nghĩa <b>*</b></span>
                            <input type="text" name="backText" class="form-input-custom" aria-label="Định nghĩa" required />
                        </label>
                        <label>
                            <span>IPA <b>*</b></span>
                            <input type="text" name="pronunciation" class="form-input-custom" aria-label="IPA" required />
                        </label>
                        <label>
                            <span>Loại từ <b>*</b></span>
                            <input type="text" name="partOfSpeech" list="partOfSpeechOptions" class="form-input-custom" aria-label="Loại từ" required />
                        </label>
                    </div>

                    <label class="vocab-wide-field">
                        <span>Ví dụ tiếng Anh <b>*</b></span>
                        <textarea name="exampleSentence" class="form-input-custom" rows="2" required></textarea>
                    </label>

                    <label class="vocab-wide-field">
                        <span>Nghĩa câu ví dụ tiếng Việt <b>*</b></span>
                        <textarea name="exampleMeaning" class="form-input-custom" rows="2" required></textarea>
                    </label>

                    <label class="vocab-wide-field">
                        <span>Từ đồng nghĩa</span>
                        <input type="text" name="synonyms" class="form-input-custom" aria-label="Từ đồng nghĩa" />
                    </label>

                    <div class="vocab-grid mt-2">
                        <label>
                            <span>Đường dẫn ảnh (URL)</span>
                            <input type="text" name="imageUrl" class="form-input-custom" placeholder="https://example.com/image.png" aria-label="Đường dẫn ảnh" />
                        </label>
                        <label>
                            <span>Tải ảnh lên (Max 2MB)</span>
                            <input type="file" name="imageFile" class="form-input-custom" accept=".jpg,.jpeg,.png,.webp" aria-label="Tải ảnh lên" />
                        </label>
                    </div>
                </form>
            </section>
    </div>
</div>
    </div>
</div>
</div>

<datalist id="partOfSpeechOptions">
    <option value="noun"></option>
    <option value="verb"></option>
    <option value="adjective"></option>
    <option value="adverb"></option>
    <option value="phrase"></option>
    <option value="idiom"></option>
    <option value="other"></option>
</datalist>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.vocab-list-item[data-card-id]').forEach(button => {
            button.addEventListener('click', () => {
                const cardId = button.getAttribute('data-card-id');

                document.querySelectorAll('.vocab-list-item[data-card-id]').forEach(item => {
                    item.classList.toggle('is-active', item === button);
                });

                document.querySelectorAll('[data-card-panel]').forEach(panel => {
                    const isActive = panel.getAttribute('data-card-panel') === cardId;
                    panel.classList.toggle('is-active', isActive);
                    
                    if (isActive && window.innerWidth <= 900) {
                        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });
        });

        const firstCardButton = document.querySelector('.vocab-list-item[data-card-id]');
        if (firstCardButton) firstCardButton.click();
    </script>
}
