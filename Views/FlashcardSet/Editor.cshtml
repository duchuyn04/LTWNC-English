@model ltwnc.Models.ViewModels.FlashcardSet.EditorViewModel
@using ltwnc.Areas.Admin
@{
    ViewData["Title"] = Model.Id.HasValue ? "Chỉnh sửa bộ thẻ" : "Tạo bộ thẻ";
}

@{
    var importErrorsJson = TempData["ImportErrors"] as string;
    var importErrors = string.IsNullOrWhiteSpace(importErrorsJson)
        ? Array.Empty<ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError>()
        : System.Text.Json.JsonSerializer.Deserialize<
            ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError[]>(importErrorsJson)
            ?? Array.Empty<ltwnc.Models.ViewModels.FlashcardSet.FlashcardImportError>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/unified-editor.css" />
}

<div class="unified-editor" data-set-id="@Model.Id" data-is-new="@(Model.Id.HasValue ? "false" : "true")" data-description="@(Model.Description ?? "")" data-is-public="@Model.IsPublic.ToString().ToLowerInvariant()" data-is-quarantined="@Model.IsQuarantined.ToString().ToLowerInvariant()">
    <div class="editor-header">
        <div>
            <h2>Danh sách từ</h2>
            <p class="subtitle"><span id="card-count">@Model.Cards.Count</span> thẻ · có thể chỉnh sửa trực tiếp</p>
        </div>
        <div class="header-actions">
            <select id="card-filter" class="form-select">
                <option value="all">Tất cả thẻ</option>
                <option value="starred">Đã đánh dấu</option>
            </select>
            <button id="btn-import" type="button" class="btn btn-secondary">Import</button>
            <button id="btn-finish" type="button" class="btn btn-primary" disabled>Hoàn tất</button>
        </div>
    </div>

    @if (TempData["ImportImportedCount"] is not null ||
         TempData["ImportSkippedCount"] is not null)
    {
        <div class="import-result-banner" role="status">
            <strong>Đã nhập @(TempData["ImportImportedCount"] ?? 0) thẻ.</strong>
            <span>Bỏ qua @(TempData["ImportSkippedCount"] ?? 0) dòng.</span>
            @if (importErrors.Length > 0)
            {
                <ul>
                    @foreach (var importError in importErrors)
                    {
                        <li>
                            @(importError.RowNumber > 0 ? $"Dòng {importError.RowNumber}: " : null)@importError.Reason
                        </li>
                    }
                </ul>
            }
            @if (TempData["ImportErrorsOmittedCount"] is int omittedImportErrorCount &&
                 omittedImportErrorCount > 0)
            {
                <span>Còn @omittedImportErrorCount lỗi khác không hiển thị.</span>
            }
        </div>
    }

    @if (TempData["Error"] is string importErrorMessage)
    {
        <div class="import-result-banner import-result-banner--error" role="alert">
            @importErrorMessage
        </div>
    }

    @if (Model.IsQuarantined)
    {
        <div class="set-report-alert set-report-alert--danger" role="alert">
            Bộ flashcard này đang bị cách ly. Bạn vẫn có thể chỉnh sửa nội dung, nhưng chỉ Admin mới có thể khôi phục để xuất hiện công khai.
            @if (!string.IsNullOrWhiteSpace(Model.ModerationPublicReason))
            {
                <span>Lý do: @Model.ModerationPublicReason</span>
            }
            @if (Model.ModeratedAtUtc.HasValue)
            {
                <span>Thời điểm xử lý: @FormatVietnamTime(Model.ModeratedAtUtc.Value)</span>
            }
        </div>
    }

    <div class="editor-meta">
        <label for="set-title">Tên bộ từ <span class="required">*</span></label>
        <input id="set-title" class="form-control" value="@Model.Title" placeholder="Nhập tên bộ thẻ" />

        <label for="set-description">Mô tả</label>
        <textarea id="set-description" class="form-control" rows="3" placeholder="Mô tả bộ thẻ">@Model.Description</textarea>

        <label class="checkbox-label">
            <input type="checkbox" id="set-is-public" @(Model.IsPublic ? "checked" : "") @(Model.IsQuarantined ? "disabled" : "") />
            Công khai
        </label>

        <div class="save-status" id="save-status"></div>
    </div>

    <div id="cards-container" class="cards-container">
        @for (int i = 0; i < Model.Cards.Count; i++)
        {
            var card = Model.Cards[i];
            <div class="flashcard-card @(i == 0 ? "expanded" : "collapsed")"
                 data-id="@(Model.Id.HasValue ? card.Id.ToString() : "new-" + Guid.NewGuid())"
                 data-order="@card.OrderIndex"
                 data-starred="@card.IsStarred.ToString().ToLowerInvariant()">
                <div class="card-header">
                    <span class="card-drag-handle" aria-label="Drag to reorder">⋮⋮</span>
                    <span class="card-number">@(i + 1)</span>
                    <button type="button" class="btn-star" aria-label="Toggle star">
                        @(card.IsStarred ? "★" : "☆")
                    </button>
                    <span class="card-term">@card.FrontText</span>
                    <div class="card-actions">
                        <button type="button" class="btn-move-up" aria-label="Move up">↑</button>
                        <button type="button" class="btn-move-down" aria-label="Move down">↓</button>
                        <button type="button" class="btn-toggle" aria-label="Expand/collapse">▲</button>
                        <button type="button" class="btn-delete" aria-label="Delete">🗑</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Thuật ngữ <span class="required">*</span></label>
                            <input class="form-control input-front" value="@card.FrontText" placeholder="Thuật ngữ" />
                        </div>
                        <div class="form-group">
                            <label>Định nghĩa <span class="required">*</span></label>
                            <input class="form-control input-back" value="@card.BackText" placeholder="Định nghĩa" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Phát âm</label>
                            <input class="form-control input-pronunciation" value="@card.Pronunciation" placeholder="IPA" />
                        </div>
                        <div class="form-group">
                            <label>Loại từ</label>
                            <input class="form-control input-part-of-speech" value="@card.PartOfSpeech" placeholder="noun, verb..." />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Ví dụ tiếng Anh</label>
                        <textarea class="form-control input-example-sentence" rows="2" placeholder="Ví dụ">@card.ExampleSentence</textarea>
                    </div>
                    <div class="form-group">
                        <label>Nghĩa câu ví dụ tiếng Việt</label>
                        <textarea class="form-control input-example-meaning" rows="2" placeholder="Nghĩa">@card.ExampleMeaning</textarea>
                    </div>
                    <div class="form-group">
                        <label>Từ đồng nghĩa</label>
                        <input class="form-control input-synonyms" value="@card.Synonyms" placeholder="Cách nhau bằng dấu phẩy" />
                    </div>
                </div>
            </div>
        }
    </div>

    <button id="btn-add-card" type="button" class="btn btn-add-card">+ Thêm thẻ mới</button>
</div>

<div id="import-modal"
     class="modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="import-modal-title"
     style="display:none;">
    <div class="modal-content">
        <div class="import-modal-header">
            <div>
                <span class="import-eyebrow">Nhập dữ liệu</span>
                <h3 id="import-modal-title">Thêm nhiều thẻ cùng lúc</h3>
            </div>
            <button id="btn-import-close"
                    type="button"
                    class="import-modal-close"
                    aria-label="Đóng cửa sổ import">×</button>
        </div>

        <div class="import-tabs" role="tablist" aria-label="Cách nhập thẻ">
            <button id="import-tab-file"
                    type="button"
                    class="import-tab is-active"
                    role="tab"
                    aria-selected="true"
                    aria-controls="import-panel-file">
                <i class="ph ph-file-arrow-up" aria-hidden="true"></i>
                Tải file
            </button>
            <button id="import-tab-paste"
                    type="button"
                    class="import-tab"
                    role="tab"
                    aria-selected="false"
                    aria-controls="import-panel-paste">
                <i class="ph ph-clipboard-text" aria-hidden="true"></i>
                Dán nhanh
            </button>
        </div>

        <form id="file-import-form"
              action="@(Model.Id.HasValue ? Url.Action("Import", "FlashcardSet", new { id = Model.Id.Value }) : string.Empty)"
              data-action-template="/Set/__SET_ID__/Import"
              method="post"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <section id="import-panel-file"
                     class="import-tab-panel"
                     role="tabpanel"
                     aria-labelledby="import-tab-file">
                <label class="import-dropzone" for="import-file">
                    <i class="ph ph-cloud-arrow-up" aria-hidden="true"></i>
                    <strong>Chọn hoặc kéo file vào đây</strong>
                    <span>CSV UTF-8 hoặc XLSX · tối đa 10 MB</span>
                    <input id="import-file"
                           type="file"
                           name="file"
                           accept=".csv,.xlsx" />
                </label>
                <div id="import-file-meta" class="import-file-meta" aria-live="polite"></div>

                <div class="import-template-note">
                    <p>
                        File gồm 6 cột bắt buộc: Thuật ngữ, Định nghĩa, IPA,
                        Loại từ, Ví dụ tiếng Anh và Nghĩa ví dụ tiếng Việt.
                        Từ đồng nghĩa và URL ảnh là tùy chọn.
                    </p>
                    <a href="~/templates/flashcard-import-template.csv" download>
                        <i class="ph ph-download-simple" aria-hidden="true"></i>
                        Tải file CSV mẫu
                    </a>
                </div>

                <button id="btn-file-preview"
                        type="button"
                        class="btn btn-secondary"
                        disabled>
                    Xem trước dữ liệu
                </button>
                <div id="file-import-preview"
                     class="file-import-preview"
                     aria-live="polite"></div>
            </section>

            <section id="import-panel-paste"
                     class="import-tab-panel"
                     role="tabpanel"
                     aria-labelledby="import-tab-paste"
                     hidden>
                <p>Dán danh sách từ, mỗi dòng một thẻ rồi chọn dấu phân cách.</p>
                <label for="import-delimiter">Dấu phân cách</label>
                <select id="import-delimiter" class="form-select">
                    <option value="&#9;">Tab</option>
                    <option value=",">Dấu phẩy</option>
                    <option value="-">Dấu gạch ngang</option>
                </select>
                <label for="import-text">Nội dung</label>
                <textarea id="import-text"
                          class="form-control"
                          rows="10"
                          placeholder="hello&#9;xin chào"></textarea>
                <div id="import-preview" aria-live="polite"></div>
            </section>

            <fieldset class="import-mode-options">
                <legend>Cách nhập vào bộ thẻ</legend>
                <label>
                    <input id="import-mode-append"
                           type="radio"
                           name="replaceAll"
                           value="false"
                           checked />
                    <span>
                        <strong>Thêm vào bộ thẻ</strong>
                        <small>Giữ nguyên các thẻ hiện có</small>
                    </span>
                </label>
                <label>
                    <input id="import-mode-replace"
                           type="radio"
                           name="replaceAll"
                           value="true" />
                    <span>
                        <strong>Ghi đè toàn bộ</strong>
                        <small>Xóa thẻ và tiến độ học hiện tại</small>
                    </span>
                </label>
            </fieldset>

            <div id="import-modal-status" class="import-modal-status" aria-live="polite"></div>
            <div class="modal-actions">
                <button id="btn-import-cancel" type="button" class="btn btn-secondary">Hủy</button>
                <button id="btn-file-import-confirm"
                        type="button"
                        class="btn btn-primary"
                        disabled>
                    Nhập từ file
                </button>
                <button id="btn-import-confirm"
                        type="button"
                        class="btn btn-primary"
                        hidden>
                    Thêm
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
    <script src="~/js/unified-editor.js" asp-append-version="true"></script>
}

@functions {
    private static string FormatVietnamTime(DateTime valueUtc)
    {
        return AdminTimeZone.ToVietnamTime(valueUtc).ToString("HH:mm dd/MM/yyyy");
    }
}
