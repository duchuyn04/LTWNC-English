@model ltwnc.Models.ViewModels.AiProviders.AiProviderEditViewModel
@{ ViewData["Title"] = Model.Id.HasValue ? "Sửa AI Provider" : "Thêm AI Provider"; }
@section Styles { <link rel="stylesheet" href="~/css/ai-providers.css" asp-append-version="true" /> }
<div class="provider-edit-page">
    <a class="provider-back" href="/Admin/AiProviders"><i class="ph ph-arrow-left"></i> Danh sách provider</a>
    <header><span class="eyebrow">Quản trị AI</span><h1>@ViewData["Title"]</h1><p>Hiện hỗ trợ adapter OpenAI-compatible. Có thể để trống API key cho endpoint local như 9Router.</p></header>
    <form method="post" action="/Admin/AiProviders/Save" class="provider-form">
        @Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><div asp-validation-summary="ModelOnly" class="provider-validation"></div>
        <label><span>Tên provider</span><input asp-for="Name" placeholder="9Router Local" /></label>
        <label><span>Adapter</span><select asp-for="AdapterType"><option value="OpenAICompatible">OpenAI-compatible</option></select></label>
        <label class="wide"><span>Base URL</span><input asp-for="BaseUrl" placeholder="http://localhost:20128/v1" /></label>
        <label class="wide"><span>Model ID</span><input asp-for="ModelId" placeholder="cx/gpt-5.6-luna" /></label>
        <label class="wide"><span>API key @(Model.HasApiKey ? $"(đã lưu ••••{Model.ApiKeyLastFour})" : "(tùy chọn)")</span><input asp-for="ApiKey" autocomplete="new-password" placeholder="Để trống để giữ nguyên hoặc không dùng key" /></label>
        @if(Model.HasApiKey){<label class="provider-checkbox wide"><input asp-for="ClearApiKey" /> Xóa API key đã lưu</label>}
        <label><span>Priority</span><input asp-for="Priority" type="number" /></label><label><span>Timeout (giây)</span><input asp-for="TimeoutSeconds" type="number" /></label>
        <label class="provider-checkbox wide"><input asp-for="IsEnabled" /> Bật provider</label>
        <div class="provider-form-actions wide"><a href="/Admin/AiProviders">Hủy</a><button type="submit">Lưu provider</button></div>
    </form>
</div>
