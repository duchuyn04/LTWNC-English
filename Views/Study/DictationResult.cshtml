@model DictationResultViewModel
@{
    ViewData["Title"] = "Kết quả nghe chép";
    var wrongCount = Model.TotalCards - Model.CorrectCount;
    var correctPct = Model.TotalCards > 0 ? (int)Math.Round((double)Model.CorrectCount / Model.TotalCards * 100) : 0;
    var wrongPct = 100 - correctPct;
    var isSentence = Model.ContentMode == DictationContentMode.ExampleSentence;
}

<link rel="stylesheet" href="~/css/flashcard.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/dictation-result.css" asp-append-version="true" />

<div class="result-shell" aria-label="Kết quả nghe chép"
     data-total="@Model.TotalCards"
     data-correct="@Model.CorrectCount"
     data-wrong="@wrongCount"
     data-score="@Model.Score"
     data-correct-pct="@correctPct"
     data-wrong-pct="@wrongPct">
    <div class="result-container">
        <header class="result-header">
            <span class="badge badge-green">Hoàn thành</span>
            <h1 class="result-title">Tổng kết buổi học</h1>
            <p class="result-subtitle">
                <span>@Model.CorrectCount</span> đúng ·
                <span>@wrongCount</span> cần ôn
            </p>
        </header>

        <section class="result-kpi-grid" aria-label="Chỉ số tổng quan">
            <article class="result-kpi result-card">
                <span class="result-kpi-icon" aria-hidden="true">
                    <i class="ph ph-list-numbers" aria-hidden="true"></i>
                </span>
                <div>
                    <div class="result-kpi-value">@Model.TotalCards</div>
                    <div class="result-kpi-label">Tổng thể</div>
                </div>
            </article>

            <article class="result-kpi result-card">
                <span class="result-kpi-icon is-success" aria-hidden="true">
                    <i class="ph ph-check-circle" aria-hidden="true"></i>
                </span>
                <div>
                    <div class="result-kpi-value">@Model.CorrectCount</div>
                    <div class="result-kpi-label">Đã thuộc</div>
                </div>
            </article>

            <article class="result-kpi result-card">
                <span class="result-kpi-icon is-error" aria-hidden="true">
                    <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
                </span>
                <div>
                    <div class="result-kpi-value">@wrongCount</div>
                    <div class="result-kpi-label">Cần ôn</div>
                </div>
            </article>
        </section>

        <section class="result-charts-grid" aria-label="Biểu đồ kết quả">
            <article class="result-chart-panel result-card">
                <h2 class="result-chart-title">Độ chính xác</h2>
                <svg class="result-donut" viewBox="0 0 120 120" role="img" aria-label="Độ chính xác @Model.Score%">
                    <circle class="result-donut-track" cx="60" cy="60" r="45" pathLength="100"></circle>
                    <circle class="result-donut-fill"
                            cx="60" cy="60" r="45" pathLength="100"
                            stroke-dasharray="@Model.Score 100"></circle>
                    <text class="result-donut-text" x="60" y="60" text-anchor="middle" dominant-baseline="middle">@Model.Score%</text>
                </svg>
            </article>

            <article class="result-chart-panel result-card">
                <h2 class="result-chart-title">Tỷ lệ đúng / sai</h2>
                <div class="result-stack" role="img" aria-label="Đúng @correctPct%, sai @wrongPct%">
                    <div class="result-stack-correct" style="width:@correctPct%"></div>
                    <div class="result-stack-wrong" style="width:@wrongPct%"></div>
                </div>
                <div class="result-legend">
                    <span class="result-legend-item">
                        <span class="result-legend-dot" style="background:var(--dr-bar-correct);"></span>
                        Đúng <span>@Model.CorrectCount</span>
                        <span>(@correctPct%)</span>
                    </span>
                    <span class="result-legend-item">
                        <span class="result-legend-dot" style="background:var(--dr-bar-wrong);"></span>
                        Sai <span>@wrongCount</span>
                        <span>(@wrongPct%)</span>
                    </span>
                </div>
            </article>
        </section>

        @if (Model.WrongCards.Any())
        {
            <section class="result-table-card result-card" aria-label="Danh sách thẻ cần ôn">
                <h2 class="result-chart-title" id="wrong-cards-heading">@(Model.WrongCards.Count) thẻ cần ôn lại</h2>
                <table class="result-table" aria-labelledby="wrong-cards-heading">
                    <caption class="visually-hidden">Danh sách thẻ cần ôn lại</caption>
                    <thead>
                        <tr>
                            <th scope="col">Thuật ngữ</th>
                            @if (!isSentence)
                            {
                                <th scope="col">Phát âm</th>
                            }
                            <th scope="col">@(isSentence ? "Câu ví dụ" : "Nghĩa")</th>
                            @if (isSentence)
                            {
                                <th scope="col">Nghĩa</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var card in Model.WrongCards)
                        {
                            <tr>
                                <td class="result-table-term">@card.Term</td>
                                @if (!isSentence)
                                {
                                    <td class="result-table-meta">@card.Pronunciation</td>
                                }
                                @if (isSentence)
                                {
                                    <td class="result-table-meta">@card.ExampleSentence</td>
                                    <td class="result-table-meta">@card.ExampleMeaning</td>
                                }
                                else
                                {
                                    <td class="result-table-meta">@card.Definition</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }
        else
        {
            <section class="result-table-card result-card">
                <div class="result-empty">
                    <i class="ph ph-confetti" aria-hidden="true"></i>
                    Chính xác 100% - không có thẻ nào cần ôn.
                </div>
            </section>
        }

        <nav class="result-actions" aria-label="Hành động tiếp theo">
            @if (wrongCount > 0)
            {
                <a class="study-button is-red" href="/Study/@Model.SetId/Dictation?retrySessionId=@Model.SessionId">Ôn lại @wrongCount thẻ cần nhớ</a>
            }
            <a class="study-button" href="/Study/@Model.SetId/Quiz">Chuyển sang kiểm tra</a>
            <a class="study-button" href="/Study/@Model.SetId/Dictation">Học lại toàn bộ</a>
            <a class="primary-dark" href="/Study/@Model.SetId">Về bộ từ vựng</a>
        </nav>
    </div>
</div>
