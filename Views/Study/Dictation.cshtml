@model DictationStudyViewModel
@{
    ViewData["Title"] = "Nghe chép chính tả";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
<link rel="stylesheet" href="~/css/flashcard.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/dictation-redesign.css" asp-append-version="true" />

<div class="dictation-shell">
    @Html.AntiForgeryToken()

    <section class="dictation-stage" aria-label="Nghe chép chính tả">
        <header class="dictation-header gsap-fade-up">
            <a class="dictation-back" href="/Study/@Model.SetId" title="Thoát về trang học">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>

            <div class="dictation-title-block">
                <span class="dictation-eyebrow">Nghe chép chính tả</span>
                <h1 class="dictation-title">@Model.SetTitle</h1>
            </div>

            <button type="button" class="dictation-settings-btn" onclick="toggleDictationSettings(event)" title="Cài đặt nghe chép">
                <span class="material-symbols-outlined">tune</span>
            </button>
        </header>

        <div class="dictation-progress gsap-fade-up">
            <div class="dictation-progress-track" aria-hidden="true">
                <div id="dictation-progress-fill" class="dictation-progress-fill"></div>
            </div>
            <span id="dictation-progress-text" class="dictation-progress-text">Câu 1 / @Model.Cards.Count</span>
        </div>

        <div class="dictation-layout">
            <main class="dictation-main">
                <div class="dictation-card gsap-scale-in">
                    <h2 class="dictation-card-title">Bài tập nghe chép</h2>

                    <div class="dictation-audio-control">
                        <button type="button" id="dictation-play-btn" class="dictation-audio-btn" onclick="playCurrentPrompt()" title="Phát âm (Ctrl + 1)">
                            <span class="material-symbols-outlined">volume_up</span>
                        </button>
                        <span class="dictation-audio-label">Phát âm</span>
                        <div class="dictation-audio-speed">
                            <label for="dictation-speed">Tốc độ</label>
                            <select id="dictation-speed" onchange="saveTtsSettings()">
                                <option value="0.5">0.5x</option>
                                <option value="0.75">0.75x</option>
                                <option value="1.0" selected>1.0x</option>
                                <option value="1.25">1.25x</option>
                                <option value="1.5">1.5x</option>
                            </select>
                        </div>
                    </div>

                    <label for="dictation-answer" class="dictation-input-label">Điền lại nội dung bạn nghe được</label>
                    <textarea id="dictation-answer" class="dictation-answer" rows="2" lang="en" placeholder="Nhập từ hoặc câu bạn nghe được..."></textarea>

                    <div id="dictation-feedback" class="dictation-feedback" hidden>
                        <div id="dictation-feedback-icon" class="dictation-feedback-icon"></div>
                        <div id="dictation-feedback-answer" class="dictation-feedback-answer"></div>
                        <div id="dictation-feedback-hint" class="dictation-feedback-hint"></div>
                        <div id="dictation-feedback-comparison" class="dictation-feedback-comparison" hidden>
                            <div class="dictation-feedback-row">
                                <span class="dictation-feedback-label">Bạn đã nhập</span>
                                <div id="dictation-answered-words" class="dictation-feedback-words"></div>
                            </div>
                            <div class="dictation-feedback-row">
                                <span class="dictation-feedback-label">Câu đúng</span>
                                <div id="dictation-correct-words" class="dictation-feedback-words"></div>
                            </div>
                            <p id="dictation-example-meaning" class="dictation-example-meaning"></p>
                            <button type="button" id="dictation-replay-correct" class="dictation-feedback-replay" onclick="speak(lastCorrectAnswer)">
                                <span class="material-symbols-outlined">volume_up</span>
                                Nghe lại câu đúng
                            </button>
                        </div>
                    </div>

                    <div class="dictation-actions">
                        <button type="button" id="dictation-check-btn" class="dictation-btn dictation-btn-primary" onclick="checkAnswer()">
                            <span class="material-symbols-outlined">check</span>
                            <span>Kiểm tra (Enter)</span>
                        </button>
                        <button type="button" id="dictation-dont-know-btn" class="dictation-btn dictation-btn-secondary" onclick="markUnknown()">
                            <span class="material-symbols-outlined">close</span>
                            <span>Tôi không biết</span>
                        </button>
                        <button type="button" id="dictation-continue-btn" class="dictation-btn dictation-btn-primary" onclick="nextCard()" hidden>
                            <span class="material-symbols-outlined">arrow_forward</span>
                            <span>Tiếp tục</span>
                        </button>
                        <button type="button" id="dictation-retry-btn" class="dictation-btn dictation-btn-secondary" onclick="startRetry()" hidden>
                            <span class="material-symbols-outlined">replay</span>
                            <span>Thử lại</span>
                        </button>
                    </div>
                </div>
            </main>

            <aside class="dictation-sidebar gsap-stagger">
                <div class="dictation-stat-card">
                    <h3 class="dictation-stat-title">Tiến độ buổi học</h3>
                    <div class="dictation-stat-row"><span>Đã hoàn thành</span><span id="stat-completed">0 / @Model.Cards.Count</span></div>
                    <div class="dictation-stat-row"><span>Tổng số câu hỏi</span><span id="stat-total">@Model.Cards.Count</span></div>
                    <div class="dictation-stat-row"><span>Tỉ lệ chính xác</span><span id="stat-accuracy">--</span></div>
                </div>

                @if (Model.StreakDays > 0)
                {
                    <div class="dictation-stat-card">
                        <h3 class="dictation-stat-title">Chuỗi học tập</h3>
                        <p class="dictation-streak-value"><strong>@Model.StreakDays</strong> ngày liên tiếp</p>
                    </div>
                }

                <div class="dictation-stat-card">
                    <h3 class="dictation-stat-title">Phím tắt</h3>
                    <div class="dictation-shortcut-row"><span>Nghe lại</span><span><kbd>Ctrl</kbd> + <kbd>1</kbd></span></div>
                    <div class="dictation-shortcut-row"><span>Kiểm tra / tiếp tục</span><span><kbd>Enter</kbd></span></div>
                </div>

                <div class="dictation-links">
                    <a class="dictation-link" href="/Study/@Model.SetId/History">
                        <span class="material-symbols-outlined">history</span>
                        Xem lại lịch sử câu sai
                    </a>
                    <a class="dictation-link dictation-link-danger" href="/Study/@Model.SetId">
                        <span class="material-symbols-outlined">logout</span>
                        Kết thúc phiên học
                    </a>
                </div>
            </aside>
        </div>
    </section>

    <aside id="dictation-settings-drawer" class="dictation-settings-drawer" hidden>
        <div class="dictation-settings-header">
            <span class="dictation-settings-title">Cài đặt nghe chép</span>
            <button type="button" class="dictation-settings-close" onclick="toggleDictationSettings(event)" title="Đóng">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="dictation-settings-body">
            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Lọc từ vựng</div>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="StarredOnly"> Chỉ học từ đánh dấu sao</label>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="UnlearnedOnly"> Chỉ học từ chưa thuộc</label>
            </div>

            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Thứ tự học</div>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="DictationShuffle"> Xáo trộn</label>
            </div>

            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Nội dung nghe chép</div>
                <label class="dictation-settings-option"><input type="radio" name="contentMode" value="Vocabulary" data-setting="DictationContentMode" @(Model.Settings.DictationContentMode == DictationContentMode.Vocabulary ? "checked" : "")> Từ vựng</label>
                <label class="dictation-settings-option"><input type="radio" name="contentMode" value="ExampleSentence" data-setting="DictationContentMode" @(Model.Settings.DictationContentMode == DictationContentMode.ExampleSentence ? "checked" : "")> Câu ví dụ</label>
            </div>

            <div id="dictation-synonyms-group" class="dictation-settings-group">
                <div class="dictation-settings-group-title">Tùy chọn trả lời</div>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="DictationAcceptSynonyms" @(Model.Settings.DictationAcceptSynonyms ? "checked" : "")> Chấp nhận từ đồng nghĩa</label>
            </div>

            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Tùy chọn hành vi</div>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="DictationAutoAdvance"> Tự động tiếp tục khi đúng</label>
            </div>

            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Tùy chọn âm thanh</div>
                <div class="dictation-settings-field">
                    <label for="dictation-voice" class="dictation-settings-field-label">Giọng đọc</label>
                    <select id="dictation-voice" class="dictation-settings-select" onchange="saveTtsSettings()"></select>
                </div>
            </div>

            <div class="dictation-settings-group">
                <div class="dictation-settings-group-title">Gợi ý</div>
                <label class="dictation-settings-option"><input type="checkbox" data-setting="DictationShowHint"> Hiện gợi ý khi trả lời sai</label>
            </div>
        </div>
    </aside>
    <div id="dictation-settings-backdrop" class="dictation-settings-backdrop" hidden onclick="toggleDictationSettings(event)"></div>
</div>

@section Scripts {
    <script>
        const cards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Cards.Select(c => new
        {
            c.Id,
            c.Term,
            c.Definition,
            c.ExampleSentence,
            c.ExampleMeaning,
            c.PromptText,
            c.Pronunciation,
            Image = c.ImageUrl
        })));
        const initialSettings = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Settings, new System.Text.Json.JsonSerializerOptions
        {
            PropertyNamingPolicy = null,
            Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
        }));
        const settings = { ...initialSettings };
        const setId = @Model.SetId;
        const sessionId = @Model.SessionId;
        const contentMode = '@Model.ContentMode';

        let currentIndex = 0;
        let answeredCount = 0;
        let correctCount = 0;
        let isAnswered = false;
        let lastCorrectAnswer = '';
        let isRetrying = false;

        const synth = window.speechSynthesis;
        const voiceSelect = document.getElementById('dictation-voice');
        const speedSelect = document.getElementById('dictation-speed');
        const answerInput = document.getElementById('dictation-answer');
        const feedbackPanel = document.getElementById('dictation-feedback');
        const continueBtn = document.getElementById('dictation-continue-btn');
        const checkBtn = document.getElementById('dictation-check-btn');
        const dontKnowBtn = document.getElementById('dictation-dont-know-btn');
        const playBtn = document.getElementById('dictation-play-btn');
        const retryBtn = document.getElementById('dictation-retry-btn');

        let voices = [];

        function loadVoices() {
            if (!synth || !voiceSelect) return;
            voices = synth.getVoices();
            voiceSelect.innerHTML = '';

            const enVoices = voices.filter(v => v.lang.startsWith('en'));
            if (enVoices.length === 0) {
                const opt = document.createElement('option');
                opt.value = 'default';
                opt.textContent = 'Mặc định hệ thống';
                voiceSelect.appendChild(opt);
                voiceSelect.disabled = true;
            } else {
                enVoices.forEach(voice => {
                    const opt = document.createElement('option');
                    opt.value = voice.voiceURI;
                    opt.textContent = `${voice.name} (${voice.lang})`;
                    voiceSelect.appendChild(opt);
                });
                voiceSelect.disabled = false;
            }

            restoreTtsSettings();
        }

        if (synth) {
            if (synth.onvoiceschanged !== undefined) {
                synth.onvoiceschanged = loadVoices;
            }
            loadVoices();
        }

        function saveTtsSettings() {
            const data = {
                speed: speedSelect.value,
                voiceUri: voiceSelect.value
            };
            localStorage.setItem('ltwnc_dictation_tts', JSON.stringify(data));
        }

        function restoreTtsSettings() {
            const raw = localStorage.getItem('ltwnc_dictation_tts');
            if (!raw) return;
            try {
                const data = JSON.parse(raw);
                if (data.speed) speedSelect.value = data.speed;
                if (data.voiceUri) {
                    for (let i = 0; i < voiceSelect.options.length; i++) {
                        if (voiceSelect.options[i].value === data.voiceUri) {
                            voiceSelect.selectedIndex = i;
                            break;
                        }
                    }
                }
            } catch (e) {
                console.error('Không đọc được cài đặt TTS', e);
            }
        }

        function playCurrentPrompt() {
            if (!synth || cards.length === 0) return;
            speak(cards[currentIndex].PromptText);
        }

        function speak(text) {
            if (!synth || !text) return;
            if (synth.speaking) synth.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.rate = parseFloat(speedSelect.value) || 1.0;
            utterance.lang = 'en-US';

            const selectedUri = voiceSelect.value;
            const selectedVoice = voices.find(v => v.voiceURI === selectedUri);
            if (selectedVoice) utterance.voice = selectedVoice;

            utterance.onstart = () => playBtn.classList.add('is-playing');
            utterance.onend = () => playBtn.classList.remove('is-playing');
            utterance.onerror = () => playBtn.classList.remove('is-playing');

            synth.speak(utterance);
        }

        async function checkAnswer() {
            if (cards.length === 0) return;

            if (isRetrying) {
                checkRetryAnswer();
                return;
            }

            if (isAnswered) return;

            const value = answerInput.value.trim();
            if (!value) {
                answerInput.focus();
                return;
            }

            await submitCheck(value);
        }

        async function submitCheck(value) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', token);
            params.append('sessionId', sessionId);
            params.append('cardId', cards[currentIndex].Id);
            params.append('answeredText', value);

            try {
                const response = await fetch(`/Study/${setId}/Dictation/Check`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params
                });

                if (!response.ok) {
                    console.error('Lỗi kiểm tra đáp án', response.status);
                    return;
                }

                const data = await response.json();
                handleCheckResult(data);
            } catch (err) {
                console.error('Lỗi mạng khi kiểm tra đáp án', err);
            }
        }

        function handleCheckResult(data) {
            isAnswered = true;
            answeredCount++;
            if (data.isCorrect) correctCount++;

            feedbackPanel.hidden = false;
            answerInput.readOnly = true;
            checkBtn.hidden = true;
            dontKnowBtn.hidden = true;
            const icon = document.getElementById('dictation-feedback-icon');
            const answer = document.getElementById('dictation-feedback-answer');
            const hint = document.getElementById('dictation-feedback-hint');
            const comparison = document.getElementById('dictation-feedback-comparison');
            lastCorrectAnswer = data.correctAnswer || '';
            comparison.hidden = true;

            if (data.isCorrect) {
                feedbackPanel.className = 'dictation-feedback is-correct';
                icon.innerHTML = '<span class="material-symbols-outlined" style="color: var(--dt-success); font-size: 1.75rem;">check_circle</span>';
                answer.textContent = 'Chính xác!';
                hint.textContent = '';
            } else {
                feedbackPanel.className = 'dictation-feedback is-wrong';
                icon.innerHTML = '<span class="material-symbols-outlined" style="color: var(--dt-error); font-size: 1.75rem;">cancel</span>';
                if (contentMode === 'ExampleSentence') {
                    answer.textContent = 'Chưa chính xác';
                    hint.textContent = '';
                    comparison.hidden = false;
                    renderWordComparison(data.wordComparison || []);
                    document.getElementById('dictation-example-meaning').textContent = data.exampleMeaning
                        ? `Nghĩa: ${data.exampleMeaning}`
                        : '';
                } else {
                    answer.textContent = `Đáp án đúng: ${data.correctAnswer}`;
                    hint.textContent = settings.DictationShowHint ? (data.hint || '') : '';
                }
            }

            updateStats();

            if (data.isCorrect && settings.DictationAutoAdvance) {
                continueBtn.hidden = true;
                setTimeout(nextCard, 1000);
            } else {
                continueBtn.hidden = false;
                if (!data.isCorrect && retryBtn) retryBtn.hidden = false;
            }
        }

        function startRetry() {
            if (!isAnswered) return;

            isRetrying = true;
            answerInput.value = '';
            answerInput.readOnly = false;
            feedbackPanel.hidden = true;
            document.getElementById('dictation-feedback-comparison').hidden = true;

            continueBtn.hidden = true;
            if (retryBtn) retryBtn.hidden = true;
            checkBtn.hidden = false;
            dontKnowBtn.hidden = false;

            answerInput.focus();
        }

        function normalizeRetryInput(input) {
            if (!input) return '';
            return input
                .toLowerCase()
                .replace(/[,.!?;]/g, '')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function checkRetryAnswer() {
            if (!isRetrying || cards.length === 0) return;

            const value = answerInput.value.trim();
            if (!value) {
                answerInput.focus();
                return;
            }

            const normalizedInput = normalizeRetryInput(value);
            const normalizedCorrect = normalizeRetryInput(lastCorrectAnswer);
            const isNowCorrect = normalizedInput === normalizedCorrect && normalizedCorrect !== '';

            feedbackPanel.hidden = false;
            answerInput.readOnly = true;
            checkBtn.hidden = true;
            dontKnowBtn.hidden = true;

            const icon = document.getElementById('dictation-feedback-icon');
            const answer = document.getElementById('dictation-feedback-answer');
            const hint = document.getElementById('dictation-feedback-hint');
            const comparison = document.getElementById('dictation-feedback-comparison');
            comparison.hidden = true;

            if (isNowCorrect) {
                feedbackPanel.className = 'dictation-feedback is-correct';
                icon.innerHTML = '<span class="material-symbols-outlined" style="color: var(--dt-success); font-size: 1.75rem;">check_circle</span>';
                answer.textContent = 'Chính xác!';
                hint.textContent = '';
                continueBtn.hidden = false;
                if (retryBtn) retryBtn.hidden = true;
                isRetrying = false;
            } else {
                feedbackPanel.className = 'dictation-feedback is-wrong';
                icon.innerHTML = '<span class="material-symbols-outlined" style="color: var(--dt-error); font-size: 1.75rem;">cancel</span>';
                answer.textContent = 'Chưa chính xác';
                hint.textContent = settings.DictationShowHint ? (cards[currentIndex].Definition || '') : '';
                continueBtn.hidden = false;
                if (retryBtn) retryBtn.hidden = false;
            }
        }

        function renderWordComparison(words) {
            const answered = document.getElementById('dictation-answered-words');
            const correct = document.getElementById('dictation-correct-words');
            answered.replaceChildren();
            correct.replaceChildren();

            words.forEach(word => {
                if (word.status !== 'Missing') {
                    appendFeedbackWord(answered, word.answeredWord, word.status, 'Từ đã nhập');
                }
                if (word.status !== 'Extra') {
                    appendFeedbackWord(correct, word.correctWord, word.status, 'Từ đúng');
                }
            });

            if (!answered.hasChildNodes()) answered.textContent = 'Không có câu trả lời';
        }

        function appendFeedbackWord(container, text, status, label) {
            const word = document.createElement('span');
            word.className = `dictation-word is-${status.toLowerCase()}`;
            word.textContent = text || '';
            word.setAttribute('aria-label', `${label}: ${text || ''} (${status})`);
            container.appendChild(word);
        }

        function markUnknown() {
            if (cards.length === 0 || isAnswered) return;
            submitCheck('');
        }

        function nextCard() {
            if (currentIndex < cards.length - 1) {
                currentIndex++;
                resetCard();
                playCurrentPrompt();
            } else {
                completeSession();
            }
        }

        function resetCard() {
            isAnswered = false;
            isRetrying = false;
            answerInput.value = '';
            answerInput.readOnly = false;
            lastCorrectAnswer = '';
            feedbackPanel.hidden = true;
            document.getElementById('dictation-feedback-comparison').hidden = true;
            continueBtn.hidden = true;
            if (retryBtn) retryBtn.hidden = true;
            checkBtn.hidden = false;
            dontKnowBtn.hidden = false;
            answerInput.focus();
            updateProgress();
        }

        function updateProgress() {
            const total = cards.length;
            const current = currentIndex + 1;
            document.getElementById('dictation-progress-text').textContent = `Câu ${current} / ${total}`;
            document.getElementById('dictation-progress-fill').style.width = `${(current / total) * 100}%`;
        }

        function updateStats() {
            document.getElementById('stat-completed').textContent = `${answeredCount} / ${cards.length}`;
            const accuracy = answeredCount === 0 ? '--' : `${Math.round((correctCount / answeredCount) * 100)}%`;
            document.getElementById('stat-accuracy').textContent = accuracy;
        }

        async function completeSession() {
            const score = cards.length === 0 ? 0 : Math.round((correctCount / cards.length) * 100);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', token);
            params.append('sessionId', sessionId);
            params.append('score', score);

            try {
                const response = await fetch(`/Study/${setId}/Dictation/Complete`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params
                });

                const data = await response.json();
                if (data.success && data.redirectUrl) {
                    window.location.href = data.redirectUrl;
                }
            } catch (err) {
                console.error('Lỗi khi hoàn thành phiên', err);
            }
        }

        function toggleDictationSettings(event) {
            if (event) event.stopPropagation();
            const drawer = document.getElementById('dictation-settings-drawer');
            const backdrop = document.getElementById('dictation-settings-backdrop');
            const isOpen = !drawer.hidden;
            drawer.hidden = isOpen;
            backdrop.hidden = isOpen;
        }

        function bindSettingsInputs() {
            document.querySelectorAll('[data-setting]').forEach(input => {
                const key = input.dataset.setting;
                if (input.type === 'radio') {
                    input.checked = settings[key] === input.value;
                    input.addEventListener('change', () => {
                        if (input.checked) {
                            settings[key] = input.value;
                            updateContentModeSettings();
                            if (key === 'DictationContentMode') {
                                saveSettings().then(() => window.location.reload());
                            } else {
                                saveSettings();
                            }
                        }
                    });
                } else {
                    input.checked = !!settings[key];
                    input.addEventListener('change', () => {
                        settings[key] = input.checked;
                        if (key === 'StarredOnly' || key === 'UnlearnedOnly') {
                            saveSettings().then(() => reloadWithFilters());
                        } else {
                            saveSettings();
                        }
                    });
                }
            });

            updateContentModeSettings();

            document.addEventListener('click', (e) => {
                const drawer = document.getElementById('dictation-settings-drawer');
                const btn = document.querySelector('.dictation-settings-btn');
                if (drawer && !drawer.hidden && !drawer.contains(e.target) && !btn.contains(e.target)) {
                    toggleDictationSettings();
                }
            });
        }

        function updateContentModeSettings() {
            const isSentence = settings.DictationContentMode === 'ExampleSentence';
            document.getElementById('dictation-synonyms-group').hidden = isSentence;
        }

        async function saveSettings() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', token);
            Object.keys(settings).forEach(key => {
                params.append(key, settings[key]);
            });

            try {
                await fetch('/Study/Settings', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params
                });
            } catch (err) {
                console.error('Lỗi lưu cài đặt', err);
            }
        }

        function reloadWithFilters() {
            const url = new URL(window.location.href);
            url.searchParams.set('starredOnly', settings.StarredOnly);
            url.searchParams.set('unlearnedOnly', settings.UnlearnedOnly);
            window.location.href = url.toString();
        }

        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === '1') {
                e.preventDefault();
                playCurrentPrompt();
            } else if (e.key === 'Enter' && !e.shiftKey && document.activeElement === answerInput) {
                e.preventDefault();
                if (isRetrying) {
                    checkRetryAnswer();
                } else if (isAnswered) {
                    nextCard();
                } else {
                    checkAnswer();
                }
            }
        });

        bindSettingsInputs();
        updateProgress();
        updateStats();
        answerInput.focus();

        document.body.addEventListener('click', () => {
            if (currentIndex === 0 && !isAnswered) {
                playCurrentPrompt();
            }
        }, { once: true });
    </script>
}
