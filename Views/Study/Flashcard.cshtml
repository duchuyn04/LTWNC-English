@model FlashcardStudyViewModel
@{
    ViewData["Title"] = "Học flashcard";
}

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
<link rel="stylesheet" href="~/css/flashcard.css" asp-append-version="true" />

<div class="study-shell">
    @Html.AntiForgeryToken()

    <section id="study-view" class="study-stage" aria-label="Học flashcard">
        <header class="study-header">
            <a class="exit-link" href="/Study/@Model.SetId" title="Backspace: thoát về trang học">
                <span class="material-symbols-outlined">arrow_back</span>
                <span>Thoát</span>
                <span class="keycap">Backspace</span>
            </a>

            <div class="set-meta">
                <div class="study-eyebrow">Học flashcard</div>
                <h1 id="set-title-header" class="set-title">@Model.SetTitle</h1>
                <div class="study-filter-toggle" aria-label="Lọc thẻ học">
                    <a class="@(!Model.StarredOnly && !Model.UnlearnedOnly ? "is-active" : "")" href="/Study/@Model.SetId/Flashcard?starredOnly=false&unlearnedOnly=false">Tất cả</a>
                    <a class="@(Model.StarredOnly ? "is-active" : "")" href="/Study/@Model.SetId/Flashcard?starredOnly=true&unlearnedOnly=false">Đã sao</a>
                </div>
            </div>

            <div class="progress-block">
                <span id="card-progress-text" class="progress-text">Thẻ 1 / 1</span>
                <div class="progress-track" aria-hidden="true">
                    <div id="card-progress-fill" class="progress-fill"></div>
                </div>
            </div>
        </header>

        <!-- Learning Modes Grid -->
        <section class="learning-modes" aria-label="Chế độ học">
            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-7 g-2">
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">chat_bubble</span>
                    <span>Speaking</span>
                </button>
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">forum</span>
                    <span>Hội thoại</span>
                </button>
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">menu_book</span>
                    <span>Ngữ pháp</span>
                </button>
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">article</span>
                    <span>Đọc hiểu</span>
                </button>
                <button type="button" class="btn learning-chip is-active">
                    <span class="material-symbols-outlined filled">school</span>
                    <span>Học</span>
                </button>
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">assignment</span>
                    <span>Kiểm tra</span>
                </button>
                <button type="button" class="btn learning-chip" disabled>
                    <span class="material-symbols-outlined">headphones</span>
                    <span>Nghe Chép</span>
                </button>
            </div>
        </section>

        <main class="card-area">
            <div class="flashcard-frame" onclick="toggleCardFlip()" role="button" tabindex="0" aria-label="Lật thẻ">
                <div id="study-settings-panel" class="study-settings-panel" hidden onclick="event.stopPropagation()">
                    <div class="settings-title">Cài đặt học</div>
                    <label><input type="checkbox" data-setting="StarredOnly"> Chỉ học từ đánh dấu sao</label>
                    <label><input type="checkbox" data-setting="UnlearnedOnly"> Chỉ học từ chưa thuộc</label>

                    <div class="settings-group-title">Mặt trước</div>
                    <label><input type="checkbox" data-setting="ShowFrontTerm"> Hiển thị thuật ngữ</label>
                    <label><input type="checkbox" data-setting="ShowFrontDefinition"> Hiển thị định nghĩa</label>
                    <label><input type="checkbox" data-setting="ShowFrontIpa"> Hiển thị IPA</label>
                    <label><input type="checkbox" data-setting="ShowFrontImage"> Hiển thị ảnh</label>

                    <div class="settings-group-title">Mặt sau</div>
                    <label><input type="checkbox" data-setting="ShowBackTerm"> Hiển thị thuật ngữ</label>
                    <label><input type="checkbox" data-setting="ShowBackDefinition"> Hiển thị định nghĩa</label>
                    <label><input type="checkbox" data-setting="ShowBackIpa"> Hiển thị IPA</label>
                    <label><input type="checkbox" data-setting="ShowBackExample"> Hiển thị ví dụ</label>
                    <label><input type="checkbox" data-setting="ShowBackImage"> Hiển thị ảnh</label>

                    <div class="settings-group-title">Ảnh</div>
                    <label><input type="checkbox" data-setting="HideImage"> Ẩn ảnh</label>
                    <label><input type="checkbox" data-setting="BlurImage"> Che mờ ảnh</label>
                    <label><input type="checkbox" data-setting="LargeImage"> Ảnh lớn</label>
                </div>

                <div id="study-card-core" class="flashcard-core">
                    <button type="button" class="study-settings-button" onclick="toggleSettingsPanel(event)" title="Cài đặt học">
                        <span class="material-symbols-outlined">tune</span>
                    </button>

                    <article class="card-face card-front">
                        <button type="button" class="card-star-btn" onclick="toggleCurrentCardStar(event)" title="Đánh dấu sao">
                            <span class="material-symbols-outlined">star</span>
                        </button>
                        <div class="card-topline">
                            <span class="badge badge-blue">English</span>
                            <span>Click để lật</span>
                        </div>
                        <div class="card-content">
                            <span id="card-front-text" class="card-word card-word-front">Loading...</span>
                            <p id="card-front-ipa" class="card-detail-text" hidden></p>
                            <p id="card-front-definition" class="card-detail-text" hidden></p>
                            <img id="card-front-image" class="card-study-image" alt="Ảnh minh họa mặt trước" hidden />
                            <span class="card-flip-hint">Click hoặc Space để lật</span>
                        </div>
                        <div class="card-bottomline">
                            <span>Space để lật nhanh</span>
                        </div>
                        <div class="card-audio-controls" onclick="event.stopPropagation()">
                            <label class="card-voice-toggle" title="Tự động phát khi chuyển sang mặt sau">
                                <input type="checkbox" id="tts-autoplay" checked>
                                <span></span>
                            </label>
                            <button type="button" class="card-audio-btn" onclick="playAudioCurrentCard()" title="Phát giọng đọc (Ctrl)">
                                <span class="material-symbols-outlined">volume_up</span>
                            </button>
                        </div>
                    </article>

                    <article class="card-face card-back">
                        <button type="button" class="card-star-btn" onclick="toggleCurrentCardStar(event)" title="Đánh dấu sao">
                            <span class="material-symbols-outlined">star</span>
                        </button>
                        <div class="card-topline">
                            <span class="badge badge-green">Nghĩa Việt</span>
                            <span>Click để quay lại</span>
                        </div>
                        <div class="card-content">
                            <span id="card-back-text" class="card-word card-word-back">Loading...</span>
                            <p id="card-back-term" class="card-detail-text" hidden></p>
                            <p id="card-back-ipa" class="card-detail-text" hidden></p>
                            <p id="card-back-example" class="card-detail-text" hidden></p>
                            <img id="card-back-image" class="card-study-image" alt="Ảnh minh họa mặt sau" hidden />
                            <span class="card-flip-hint">Click để quay lại</span>
                        </div>
                        <div class="card-bottomline">
                            <span>1: chưa biết</span>
                            <span>2: đã biết</span>
                        </div>
                        <div class="card-audio-controls" onclick="event.stopPropagation()">
                            <label class="card-voice-toggle" title="Tự động phát khi chuyển sang mặt sau">
                                <input type="checkbox" id="tts-autoplay-back" checked>
                                <span></span>
                            </label>
                            <button type="button" class="card-audio-btn" onclick="playAudioCurrentCard()" title="Phát giọng đọc (Ctrl)">
                                <span class="material-symbols-outlined">volume_up</span>
                            </button>
                        </div>
                    </article>
                </div>
            </div>
        </main>

        <div class="card-nav-strip">
            <button type="button" id="progress-mode-btn" class="card-nav-btn card-progress-mode-btn" onclick="toggleProgressMode()" title="Bật chế độ đánh giá tiến độ">
                <span class="material-symbols-outlined">layers</span>
                <span>Tiến độ</span>
            </button>
            <button type="button" id="nav-left-btn" class="card-nav-btn" onclick="handleLeftAction()" title="Thẻ trước (←)">
                <span class="material-symbols-outlined">arrow_back</span>
            </button>
            <span id="card-nav-progress" class="card-nav-progress">Thẻ 1 / 1</span>
            <button type="button" id="nav-right-btn" class="card-nav-btn" onclick="handleRightAction()" title="Thẻ tiếp (→)">
                <span class="material-symbols-outlined">arrow_forward</span>
            </button>
            <button type="button" class="card-nav-btn" onclick="shuffleCards()" title="Trộn thẻ">
                <span class="material-symbols-outlined">shuffle</span>
            </button>
        </div>

        <div class="shortcut-strip" aria-label="Phím tắt">
            <span><span class="keycap">Space</span> lật thẻ</span>
            <span><span class="keycap">←</span> thẻ trước</span>
            <span><span class="keycap">→</span> thẻ tiếp</span>
            <span><span class="keycap">Backspace</span> thoát</span>
        </div>

        <section class="vocab-panel" aria-label="Danh sách từ vựng">
            <div class="vocab-panel-toolbar">
                <a class="vocab-edit-link" href="/Set/@Model.SetId/Edit">
                    <span class="material-symbols-outlined">edit</span>
                    <span>Chỉnh sửa</span>
                </a>

                <select id="vocab-sort" class="form-select vocab-sort-select" aria-label="Sắp xếp từ vựng">
                    <option value="original">Thứ tự gốc</option>
                    <option value="starred">Được đánh dấu sao trước</option>
                    <option value="unlearned">Chưa học trước</option>
                    <option value="learning">Đang học trước</option>
                    <option value="mastered">Đã thành thạo trước</option>
                </select>
            </div>

            <div id="vocab-list" class="vocab-list"></div>
        </section>

        <section class="control-dock" aria-label="Điều khiển học">
            <div class="nav-cluster" aria-hidden="true" style="visibility:hidden;">
                <button type="button" class="icon-button" onclick="prevCard()" title="Thẻ trước">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <button type="button" class="icon-button" onclick="nextCard()" title="Thẻ tiếp theo">
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>

            <div></div>

            <div class="audio-cluster">
                <details class="tts-details">
                    <summary class="tts-summary">
                        <span class="material-symbols-outlined">tune</span>
                        <span>Giọng đọc</span>
                    </summary>
                    <div class="tts-panel">
                        <div class="tts-row">
                            <label for="tts-voice-select">Giọng EN</label>
                            <select id="tts-voice-select" class="form-select premium-select"></select>
                        </div>
                        <div class="tts-row">
                            <label for="tts-speed">Tốc độ</label>
                            <select id="tts-speed" class="form-select premium-select">
                                <option value="0.8">0.8x</option>
                                <option value="1.0" selected>1.0x</option>
                                <option value="1.2">1.2x</option>
                            </select>
                        </div>
                    </div>
                </details>
            </div>
        </section>
    </section>

    <section id="completion-view" class="completion-view" aria-label="Hoàn thành">
        <canvas id="fireworksCanvas"></canvas>
        <div class="completion-inner">
            <span class="badge badge-green">Đã hoàn thành bộ thẻ</span>
            <h2 class="completion-title">Hoàn thành phiên học</h2>
            <p class="completion-copy">
                Tiến độ của bạn đã được ghi nhận. Xem nhanh nhóm thẻ đã biết và nhóm cần ôn lại bên dưới.
            </p>

            <div class="stats-grid">
                <div class="stat-card is-green">
                    <span id="count-learned" class="stat-number">0</span>
                    <span class="stat-label">Đã biết</span>
                </div>
                <div class="stat-card is-red">
                    <span id="count-unlearned" class="stat-number">0</span>
                    <span class="stat-label">Cần ôn</span>
                </div>
            </div>

            <div class="completion-actions">
                <button type="button" class="study-button is-red" onclick="restartStudy()">
                    <span>Ôn lại</span>
                    <span class="button-icon"><span class="material-symbols-outlined">refresh</span></span>
                </button>
                <button type="button" class="primary-dark" onclick="completeStudySession()">
                    Về trang học
                </button>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        let flashcards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Flashcards.Select(c => new
        {
            c.Id,
            c.FrontText,
            c.BackText,
            c.Pronunciation,
            c.ExampleSentence,
            c.ExampleMeaning,
            c.IsStarred,
            Image = !string.IsNullOrWhiteSpace(c.UploadedImagePath) ? c.UploadedImagePath : c.ImageUrl
        })));
        const initialSettings = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Settings));
        const isAuthenticated = @Json.Serialize(Model.IsAuthenticated);
        const settings = { ...initialSettings };
        const setId = @Model.SetId;
        const vocabularyCards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VocabularyCards.Select(c =>
        {
            Model.ProgressByCardId.TryGetValue(c.Id, out var progress);
            return new
            {
                c.Id,
                c.FrontText,
                c.BackText,
                c.Pronunciation,
                c.PartOfSpeech,
                c.ExampleSentence,
                c.Synonyms,
                c.IsStarred,
                c.OrderIndex,
                Status = progress == null ? 0 : (int)progress.Status,
                CorrectCount = progress == null ? 0 : progress.CorrectCount,
                WrongCount = progress == null ? 0 : progress.WrongCount
            };
        })));

        let currentIndex = 0;
        let isFlipped = false;
        let progressMode = false;

        const sessionStats = {
            learned: new Set(),
            unlearned: new Set()
        };

        let voices = [];
        const synth = window.speechSynthesis;
        const voiceSelect = document.getElementById('tts-voice-select');
        const autoplayCheckbox = document.getElementById('tts-autoplay');
        const autoplayBackCheckbox = document.getElementById('tts-autoplay-back');
        const speedSelect = document.getElementById('tts-speed');

        function exitStudy() {
            window.location.href = `/Study/${setId}`;
        }

        function loadVoices() {
            if (!synth || !voiceSelect) return;

            voices = synth.getVoices();
            voiceSelect.innerHTML = '';

            const enVoices = voices.filter(v => v.lang.startsWith('en'));

            if (enVoices.length === 0) {
                const opt = document.createElement('option');
                opt.textContent = 'Mặc định hệ thống';
                opt.value = 'default';
                voiceSelect.appendChild(opt);
            } else {
                enVoices.forEach(voice => {
                    const opt = document.createElement('option');
                    opt.value = voice.name;
                    opt.textContent = `${voice.name} (${voice.lang})`;
                    if (voice.name.toLowerCase().includes('zira') || voice.name.toLowerCase().includes('female')) {
                        opt.selected = true;
                    }
                    voiceSelect.appendChild(opt);
                });
            }

            restoreTtsSettings();
        }

        if (synth) {
            if (synth.onvoiceschanged !== undefined) {
                synth.onvoiceschanged = loadVoices;
            }
            loadVoices();
        }

        function saveTtsSettings() {
            if (!voiceSelect || !autoplayCheckbox || !speedSelect) return;
            localStorage.setItem('ltwnc_tts_settings', JSON.stringify({
                autoplay: autoplayCheckbox.checked,
                voiceName: voiceSelect.value,
                speed: speedSelect.value
            }));
        }

        function restoreTtsSettings() {
            const data = localStorage.getItem('ltwnc_tts_settings');
            if (!data) return;

            try {
                const settings = JSON.parse(data);
                autoplayCheckbox.checked = settings.autoplay;
                if (autoplayBackCheckbox) autoplayBackCheckbox.checked = settings.autoplay;
                speedSelect.value = settings.speed || '1.0';

                for (let i = 0; i < voiceSelect.options.length; i++) {
                    if (voiceSelect.options[i].value === settings.voiceName) {
                        voiceSelect.selectedIndex = i;
                        break;
                    }
                }
            } catch (e) {
                console.error('Failed to restore TTS settings', e);
            }
        }

        function setAutoplay(value) {
            if (autoplayCheckbox) autoplayCheckbox.checked = value;
            if (autoplayBackCheckbox) autoplayBackCheckbox.checked = value;
            saveTtsSettings();
        }

        autoplayCheckbox?.addEventListener('change', () => setAutoplay(autoplayCheckbox.checked));
        autoplayBackCheckbox?.addEventListener('change', () => setAutoplay(autoplayBackCheckbox.checked));
        voiceSelect?.addEventListener('change', saveTtsSettings);
        speedSelect?.addEventListener('change', saveTtsSettings);

        function speak(text, isVietnamese = false) {
            if (!synth || !text || text.trim() === '') return;
            if (synth.speaking) synth.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.rate = parseFloat(speedSelect?.value) || 1.0;

            if (isVietnamese) {
                const viVoice = voices.find(v => v.lang.startsWith('vi'));
                if (viVoice) utterance.voice = viVoice;
                utterance.lang = 'vi-VN';
            } else {
                const enVoice = voices.find(v => v.name === voiceSelect?.value);
                if (enVoice) utterance.voice = enVoice;
                utterance.lang = 'en-US';
            }

            synth.speak(utterance);
        }

        function statusLabel(status) {
            if (status === 2) return 'Đã thành thạo';
            if (status === 1) return 'Đang học';
            return 'Chưa học';
        }

        function sortedVocabularyCards() {
            const sort = document.getElementById('vocab-sort')?.value || 'original';
            const cards = [...vocabularyCards];
            const byOriginal = (a, b) => a.OrderIndex - b.OrderIndex;

            if (sort === 'starred') return cards.sort((a, b) => Number(b.IsStarred) - Number(a.IsStarred) || byOriginal(a, b));
            if (sort === 'unlearned') return cards.sort((a, b) => Number(a.Status !== 0) - Number(b.Status !== 0) || byOriginal(a, b));
            if (sort === 'learning') return cards.sort((a, b) => Number(a.Status !== 1) - Number(b.Status !== 1) || byOriginal(a, b));
            if (sort === 'mastered') return cards.sort((a, b) => Number(a.Status !== 2) - Number(b.Status !== 2) || byOriginal(a, b));
            return cards.sort(byOriginal);
        }

        function renderVocabularyPanel() {
            const list = document.getElementById('vocab-list');
            const count = document.getElementById('vocab-count');
            if (!list) return;

            const cards = sortedVocabularyCards();
            list.innerHTML = '';
            if (count) count.textContent = `${cards.length} từ`;

            cards.forEach(card => {
                const item = document.createElement('article');
                item.className = 'vocab-item';

                const term = document.createElement('div');
                term.className = 'vocab-term';
                const termText = document.createElement('strong');
                termText.textContent = card.FrontText || '';
                const meta = document.createElement('span');
                meta.textContent = [card.PartOfSpeech, card.Pronunciation, card.Synonyms].filter(Boolean).join(' · ');
                term.append(termText, meta);

                const definition = document.createElement('div');
                definition.className = 'vocab-definition';
                const backText = document.createElement('strong');
                backText.textContent = card.BackText || '';
                const example = document.createElement('em');
                example.textContent = card.ExampleSentence || '';
                const status = document.createElement('small');
                status.textContent = statusLabel(card.Status);
                definition.append(backText, example, status);

                const actions = document.createElement('div');
                actions.className = 'vocab-actions';
                const star = document.createElement('i');
                star.className = card.IsStarred ? 'ph ph-star-fill' : 'ph ph-star';
                const audio = document.createElement('button');
                audio.type = 'button';
                audio.title = 'Phát giọng đọc';
                audio.innerHTML = '<i class="ph ph-speaker-high"></i>';
                audio.addEventListener('click', () => speak(card.FrontText || '', false));
                actions.append(star, audio);

                item.append(term, definition, actions);
                list.appendChild(item);
            });
        }

        function updateUI() {
            if (flashcards.length === 0) return;

            const currentCard = flashcards[currentIndex];
            enforceVisibleSide('front');
            enforceVisibleSide('back');
            syncSettingsInputs();
            // Front face rendering
            const frontTextElem = document.getElementById('card-front-text');
            frontTextElem.hidden = !settings.ShowFrontTerm;
            frontTextElem.textContent = currentCard.FrontText;

            const frontIpaElem = document.getElementById('card-front-ipa');
            frontIpaElem.hidden = !settings.ShowFrontIpa || !currentCard.Pronunciation;
            frontIpaElem.textContent = currentCard.Pronunciation || '';

            const frontDefElem = document.getElementById('card-front-definition');
            frontDefElem.hidden = !settings.ShowFrontDefinition;
            frontDefElem.textContent = currentCard.BackText || '';

            // Back face rendering
            const backDefElem = document.getElementById('card-back-text');
            backDefElem.hidden = !settings.ShowBackDefinition;
            backDefElem.textContent = currentCard.BackText;

            const backTermElem = document.getElementById('card-back-term');
            backTermElem.hidden = !settings.ShowBackTerm;
            backTermElem.textContent = currentCard.FrontText || '';

            const backIpaElem = document.getElementById('card-back-ipa');
            backIpaElem.hidden = !settings.ShowBackIpa || !currentCard.Pronunciation;
            backIpaElem.textContent = currentCard.Pronunciation || '';

            const backExElem = document.getElementById('card-back-example');
            backExElem.hidden = !settings.ShowBackExample || !currentCard.ExampleSentence;
            if (currentCard.ExampleSentence) {
                backExElem.innerHTML = '';
                const strong = document.createElement('strong');
                strong.textContent = 'Ví dụ: ';
                backExElem.appendChild(strong);
                
                const textSpan = document.createElement('span');
                textSpan.textContent = currentCard.ExampleSentence;
                backExElem.appendChild(textSpan);
                
                if (currentCard.ExampleMeaning) {
                    backExElem.appendChild(document.createElement('br'));
                    const meaningSpan = document.createElement('span');
                    meaningSpan.className = 'text-sm text-muted';
                    meaningSpan.textContent = currentCard.ExampleMeaning;
                    backExElem.appendChild(meaningSpan);
                }
            }

            renderCardImage('front', currentCard);
            renderCardImage('back', currentCard);

            const cardCore = document.getElementById('study-card-core');
            cardCore.classList.remove('flipped');
            isFlipped = false;

            const currentDisplay = currentIndex + 1;
            const total = flashcards.length;
            document.getElementById('card-progress-text').textContent = `Thẻ ${currentDisplay} / ${total}`;
            document.getElementById('card-progress-fill').style.width = `${(currentDisplay / total) * 100}%`;
            
            const cardNavProgress = document.getElementById('card-nav-progress');
            if (cardNavProgress) {
                cardNavProgress.textContent = `Thẻ ${currentDisplay} / ${total}`;
            }

            updateStarUI(currentCard.IsStarred);
            updateProgressModeButtons();
        }

        function toggleProgressMode() {
            progressMode = !progressMode;
            updateProgressModeButtons();
        }

        function handleLeftAction() {
            progressMode ? markCard(false) : prevCard();
        }

        function handleRightAction() {
            progressMode ? markCard(true) : nextCard();
        }

        function updateProgressModeButtons() {
            const modeBtn = document.getElementById('progress-mode-btn');
            const leftBtn = document.getElementById('nav-left-btn');
            const rightBtn = document.getElementById('nav-right-btn');
            if (!modeBtn || !leftBtn || !rightBtn) return;

            modeBtn.classList.toggle('is-active', progressMode);
            modeBtn.title = progressMode ? 'Tắt chế độ đánh giá tiến độ' : 'Bật chế độ đánh giá tiến độ';

            leftBtn.classList.toggle('is-danger', progressMode);
            rightBtn.classList.toggle('is-success', progressMode);
            leftBtn.title = progressMode ? 'Chưa biết (1)' : 'Thẻ trước (←)';
            rightBtn.title = progressMode ? 'Đã biết (2)' : 'Thẻ tiếp (→)';
            leftBtn.innerHTML = progressMode ? '<i class="ph ph-x"></i>' : '<i class="ph ph-arrow-left"></i>';
            rightBtn.innerHTML = progressMode ? '<i class="ph ph-check"></i>' : '<i class="ph ph-arrow-right"></i>';
        }

        function toggleCurrentCardStar(event) {
            if (event) {
                event.stopPropagation(); // Prevents flipping the card when clicking the star!
            }
            if (flashcards.length === 0) return;

            const card = flashcards[currentIndex];
            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

            // Optimistic update of UI
            card.IsStarred = !card.IsStarred;
            updateStarUI(card.IsStarred);
            const vocabCard = vocabularyCards.find(c => c.Id === card.Id);
            if (vocabCard) vocabCard.IsStarred = card.IsStarred;
            renderVocabularyPanel();

            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);

            fetch(`/Study/${setId}/Flashcard/${card.Id}/ToggleStar`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    card.IsStarred = data.isStarred;
                    updateStarUI(card.IsStarred);
                    const vocabCard = vocabularyCards.find(c => c.Id === card.Id);
                    if (vocabCard) vocabCard.IsStarred = card.IsStarred;
                    renderVocabularyPanel();
                } else {
                    // Revert if failed
                    card.IsStarred = !card.IsStarred;
                    updateStarUI(card.IsStarred);
                    const vocabCard = vocabularyCards.find(c => c.Id === card.Id);
                    if (vocabCard) vocabCard.IsStarred = card.IsStarred;
                    renderVocabularyPanel();
                }
            })
            .catch(err => {
                console.error('AJAX Error:', err);
                // Revert if failed
                card.IsStarred = !card.IsStarred;
                updateStarUI(card.IsStarred);
                const vocabCard = vocabularyCards.find(c => c.Id === card.Id);
                if (vocabCard) vocabCard.IsStarred = card.IsStarred;
                renderVocabularyPanel();
            });
        }

        function updateStarUI(isStarred) {
            const starIconFront = document.querySelector('.card-front .card-star-btn i');
            const starIconBack = document.querySelector('.card-back .card-star-btn i');
            const starBtnFront = document.querySelector('.card-front .card-star-btn');
            const starBtnBack = document.querySelector('.card-back .card-star-btn');

            if (starIconFront && starIconBack) {
                if (isStarred) {
                    starIconFront.className = 'ph ph-star-fill';
                    starIconBack.className = 'ph ph-star-fill';
                    starBtnFront.classList.add('is-starred');
                    starBtnBack.classList.add('is-starred');
                } else {
                    starIconFront.className = 'ph ph-star';
                    starIconBack.className = 'ph ph-star';
                    starBtnFront.classList.remove('is-starred');
                    starBtnBack.classList.remove('is-starred');
                }
            }
        }

        function toggleCardFlip() {
            if (flashcards.length === 0) return;

            const cardCore = document.getElementById('study-card-core');
            isFlipped = !isFlipped;
            cardCore.classList.toggle('flipped', isFlipped);

            if (!isFlipped) {
                if (synth) synth.cancel();
                return;
            }

            if (autoplayCheckbox?.checked) {
                speak(flashcards[currentIndex].FrontText, false);
            }
        }

        function playAudioCurrentCard() {
            if (flashcards.length === 0) return;
            const current = flashcards[currentIndex];
            speak(current.FrontText, false);
        }

        function nextCard() {
            if (currentIndex < flashcards.length - 1) {
                currentIndex++;
                updateUI();
                return;
            }

            showCompletionScreen();
        }

        function prevCard() {
            if (currentIndex > 0) {
                currentIndex--;
                updateUI();
            }
        }

        function shuffleCards() {
            for (let i = flashcards.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [flashcards[i], flashcards[j]] = [flashcards[j], flashcards[i]];
            }
            currentIndex = 0;
            updateUI();
        }

        function markCard(learned) {
            if (flashcards.length === 0) return;

            const card = flashcards[currentIndex];

            if (learned) {
                sessionStats.learned.add(card.Id);
                sessionStats.unlearned.delete(card.Id);
            } else {
                sessionStats.unlearned.add(card.Id);
                sessionStats.learned.delete(card.Id);
            }

            const vocabCard = vocabularyCards.find(c => c.Id === card.Id);
            if (vocabCard) {
                vocabCard.Status = learned ? 2 : 1;
                if (learned) vocabCard.CorrectCount++;
                else vocabCard.WrongCount++;
                renderVocabularyPanel();
            }

            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);
            params.append('setId', setId);
            params.append('cardId', card.Id);
            params.append('learned', learned);

            fetch(`/Study/${setId}/Flashcard/Mark`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => {
                if (!res.ok) console.error('Failed to save progress to server');
            })
            .catch(err => console.error('AJAX Error:', err));

            nextCard();
        }

        function restartStudy() {
            currentIndex = 0;
            sessionStats.learned.clear();
            sessionStats.unlearned.clear();

            document.getElementById('study-view').style.display = 'grid';
            document.getElementById('completion-view').style.display = 'none';

            stopFireworks();
            updateUI();
        }

        function completeStudySession() {
            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);
            params.append('setId', setId);

            fetch(`/Study/${setId}/Complete`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => res.json())
            .then(data => {
                window.location.href = data.success && data.redirectUrl ? data.redirectUrl : `/Study/${setId}`;
            })
            .catch(err => {
                console.error('AJAX Error:', err);
                window.location.href = `/Study/${setId}`;
            });
        }

        function showCompletionScreen() {
            const learnedCount = sessionStats.learned.size;
            const unlearnedCount = flashcards.length - learnedCount;

            document.getElementById('count-learned').textContent = learnedCount;
            document.getElementById('count-unlearned').textContent = unlearnedCount;

            document.getElementById('study-view').style.display = 'none';
            document.getElementById('completion-view').style.display = 'block';

            startFireworks();
        }

        document.addEventListener('keydown', function(e) {
            const tagName = e.target.tagName;
            if (tagName === 'INPUT' || tagName === 'SELECT' || tagName === 'TEXTAREA' || tagName === 'BUTTON' || tagName === 'A' || e.target.isContentEditable) return;

            switch (e.key) {
                case ' ':
                    e.preventDefault();
                    toggleCardFlip();
                    break;
                case 'Backspace':
                    e.preventDefault();
                    exitStudy();
                    break;
                case 'ArrowLeft':
                    e.preventDefault();
                    prevCard();
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    nextCard();
                    break;
                case '1':
                    markCard(false);
                    break;
                case '2':
                    markCard(true);
                    break;
                case 'Control':
                    e.preventDefault();
                    playAudioCurrentCard();
                    break;
            }
        });

        document.querySelector('.flashcard-frame')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                toggleCardFlip();
            }
        });

        function bindSettingsInputs() {
            document.querySelectorAll('[data-setting]').forEach(input => {
                const key = input.dataset.setting;
                input.checked = !!settings[key];
                input.addEventListener('change', () => {
                    settings[key] = input.checked;
                    if (key === 'StarredOnly' || key === 'UnlearnedOnly') {
                        saveSettings().finally(() => {
                            reloadWithFilters();
                        });
                        return;
                    }
                    enforceVisibleSide('front');
                    enforceVisibleSide('back');
                    saveSettings();
                    updateUI();
                });
            });

            // Close popover when clicking outside of it
            document.addEventListener('click', (e) => {
                const panel = document.getElementById('study-settings-panel');
                const btn = document.querySelector('.study-settings-button');
                if (panel && !panel.hidden && !panel.contains(e.target) && !btn.contains(e.target)) {
                    panel.hidden = true;
                }
            });
        }

        function toggleSettingsPanel(event) {
            event.stopPropagation();
            const panel = document.getElementById('study-settings-panel');
            panel.hidden = !panel.hidden;
        }

        function sideHasImage(side) {
            const card = flashcards[currentIndex];
            if (!card || !card.Image || settings.HideImage) return false;
            return side === 'front' ? settings.ShowFrontImage : settings.ShowBackImage;
        }

        function syncSettingsInputs() {
            document.querySelectorAll('[data-setting]').forEach(input => {
                const key = input.dataset.setting;
                input.checked = !!settings[key];
            });
        }

        function enforceVisibleSide(side) {
            if (sideHasImage(side)) return;

            const keys = side === 'front'
                ? ['ShowFrontTerm', 'ShowFrontDefinition', 'ShowFrontIpa']
                : ['ShowBackTerm', 'ShowBackDefinition', 'ShowBackIpa', 'ShowBackExample'];

            if (keys.some(key => settings[key])) return;
            settings[keys[0]] = true;
            const input = document.querySelector(`[data-setting="${keys[0]}"]`);
            if (input) input.checked = true;
        }

        function saveSettings() {
            if (!isAuthenticated) return Promise.resolve();

            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);
            Object.keys(settings).forEach(key => {
                params.append(key, settings[key]);
            });

            return fetch('/Study/Settings', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            }).catch(err => console.error('Failed to save study settings', err));
        }

        function reloadWithFilters() {
            const url = new URL(window.location.href);
            url.searchParams.set('starredOnly', settings.StarredOnly);
            url.searchParams.set('unlearnedOnly', settings.UnlearnedOnly);
            url.searchParams.set('index', '0');
            window.location.href = url.toString();
        }

        function renderCardImage(side, card) {
            const image = document.getElementById(side === 'front' ? 'card-front-image' : 'card-back-image');
            const enabled = side === 'front' ? settings.ShowFrontImage : settings.ShowBackImage;

            if (!enabled || settings.HideImage || !card.Image) {
                image.hidden = true;
                image.removeAttribute('src');
                return;
            }

            image.src = card.Image;
            image.hidden = false;
            image.classList.toggle('is-large', !!settings.LargeImage);
            image.classList.toggle('is-blurred', !!settings.BlurImage);
        }

        bindSettingsInputs();
        document.getElementById('vocab-sort')?.addEventListener('change', renderVocabularyPanel);
        renderVocabularyPanel();
        updateUI();

        let canvas, ctx, animationFrameId;
        let fireworksList = [];
        let particlesList = [];
        const celebrateColors = ['#2f6a37', '#1f6c9f', '#9c3430', '#956400', '#151515'];

        class CanvasParticle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.color = color;
                this.angle = Math.random() * Math.PI * 2;
                this.speed = Math.random() * 4 + 1.5;
                this.friction = 0.96;
                this.gravity = 0.08;
                this.alpha = 1;
                this.decay = Math.random() * 0.015 + 0.008;
                this.radius = Math.random() * 2 + 1.5;
            }

            update() {
                this.speed *= this.friction;
                this.x += Math.cos(this.angle) * this.speed;
                this.y += Math.sin(this.angle) * this.speed + this.gravity;
                this.alpha -= this.decay;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        class CanvasFirework {
            constructor() {
                const w = canvas.width / window.devicePixelRatio;
                const h = canvas.height / window.devicePixelRatio;
                this.x = Math.random() * w;
                this.y = h;
                this.targetY = Math.random() * (h * 0.55) + 30;
                this.speed = Math.random() * 5 + 6;
                this.color = celebrateColors[Math.floor(Math.random() * celebrateColors.length)];
                this.exploded = false;
            }

            update() {
                if (!this.exploded) {
                    this.y -= this.speed;
                    this.speed *= 0.98;
                    if (this.speed <= 1 || this.y <= this.targetY) {
                        this.exploded = true;
                        this.explode();
                    }
                }
            }

            draw() {
                if (!this.exploded) {
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, 2, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            explode() {
                const count = Math.floor(Math.random() * 25) + 35;
                for (let i = 0; i < count; i++) {
                    particlesList.push(new CanvasParticle(this.x, this.y, this.color));
                }
            }
        }

        function resizeCanvas() {
            if (!canvas || !ctx) return;

            const dpr = window.devicePixelRatio || 1;
            canvas.width = canvas.offsetWidth * dpr;
            canvas.height = canvas.offsetHeight * dpr;
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function animateFireworks() {
            const w = canvas.width / (window.devicePixelRatio || 1);
            const h = canvas.height / (window.devicePixelRatio || 1);

            ctx.fillStyle = 'rgba(255, 255, 255, 0.22)';
            ctx.fillRect(0, 0, w, h);

            if (Math.random() < 0.05 && fireworksList.length < 4) {
                fireworksList.push(new CanvasFirework());
            }

            for (let i = fireworksList.length - 1; i >= 0; i--) {
                fireworksList[i].update();
                fireworksList[i].draw();
                if (fireworksList[i].exploded) fireworksList.splice(i, 1);
            }

            for (let i = particlesList.length - 1; i >= 0; i--) {
                particlesList[i].update();
                particlesList[i].draw();
                if (particlesList[i].alpha <= 0) particlesList.splice(i, 1);
            }

            animationFrameId = requestAnimationFrame(animateFireworks);
        }

        function startFireworks() {
            canvas = document.getElementById('fireworksCanvas');
            ctx = canvas.getContext('2d');
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();
            fireworksList = [];
            particlesList = [];
            animateFireworks();
        }

        function stopFireworks() {
            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
                animationFrameId = null;
            }
            window.removeEventListener('resize', resizeCanvas);
        }
    </script>
}
