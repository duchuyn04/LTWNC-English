@model FlashcardStudyViewModel
@{
    ViewData["Title"] = "Học flashcard";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    .study-shell {
        --ink: #151515;
        --muted: #74716b;
        --line: #e4e1da;
        --paper: #fffdf9;
        --canvas: #f6f3ed;
        --soft: #ebe6dc;
        --blue-bg: #e6f3fb;
        --blue: #1f6c9f;
        --green-bg: #eaf3e8;
        --green: #2f6a37;
        --red-bg: #fae9e7;
        --red: #9c3430;
        font-family: "Plus Jakarta Sans", sans-serif;
        min-height: calc(100dvh - 58px);
        margin: -3rem calc(50% - 50vw);
        padding: 1rem clamp(1rem, 3vw, 2.5rem);
        color: var(--ink);
        background:
            radial-gradient(circle at 20% 0%, rgba(230, 243, 251, 0.7), transparent 30rem),
            linear-gradient(180deg, #fbfaf7 0%, var(--canvas) 100%);
    }

    .study-stage {
        width: min(100%, 980px);
        margin: 0 auto;
        display: grid;
        gap: 1rem;
    }

    .study-header {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 1rem;
    }

    .exit-link,
    .icon-button {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.8);
        color: var(--ink);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        min-height: 42px;
        border-radius: 999px;
        font-weight: 700;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
        box-shadow: 0 8px 24px rgba(62, 53, 40, 0.05);
    }

    .exit-link {
        padding: 0 0.9rem;
        white-space: nowrap;
    }

    .exit-link:hover,
    .icon-button:hover {
        background: #ffffff;
        color: var(--ink);
        border-color: #cfc9bd;
        transform: translateY(-1px);
    }

    .exit-link:active,
    .icon-button:active,
    .study-button:active {
        transform: translateY(1px) scale(0.99);
    }

    .keycap {
        border: 1px solid #d6d1c7;
        border-bottom-width: 2px;
        border-radius: 6px;
        padding: 0.08rem 0.35rem;
        color: var(--muted);
        font-size: 0.68rem;
        font-weight: 700;
        line-height: 1.2;
        background: #fffaf2;
    }

    .set-meta {
        min-width: 0;
        text-align: center;
    }

    .study-eyebrow {
        color: var(--blue);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .set-title {
        margin: 0.1rem 0 0;
        font-size: clamp(1.05rem, 2vw, 1.45rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .progress-block {
        justify-self: end;
        min-width: 132px;
    }

    .progress-text {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 800;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .progress-track {
        height: 7px;
        border-radius: 999px;
        background: #ded9cf;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        width: 0%;
        border-radius: inherit;
        background: var(--ink);
        transition: width 260ms ease;
    }

    .card-area {
        position: relative;
        perspective: 1200px;
    }

    .flashcard-frame {
        width: min(100%, 860px);
        margin: 0 auto;
        padding: clamp(0.55rem, 1.2vw, 0.9rem);
        border: 1px solid rgba(77, 66, 49, 0.12);
        border-radius: clamp(1.2rem, 2vw, 1.8rem);
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 28px 70px rgba(75, 63, 45, 0.12);
        cursor: pointer;
        transition: transform 220ms ease, box-shadow 220ms ease;
    }

    .flashcard-frame:hover {
        transform: translateY(-2px);
        box-shadow: 0 34px 80px rgba(75, 63, 45, 0.15);
    }

    .flashcard-core {
        position: relative;
        height: clamp(340px, 52vh, 500px);
        border-radius: clamp(0.9rem, 1.5vw, 1.35rem);
        transform-style: preserve-3d;
        transition: transform 520ms cubic-bezier(0.2, 0.75, 0.2, 1);
    }

    .flashcard-core.flipped {
        transform: rotateY(180deg);
    }

    .card-face {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-rows: auto 1fr auto;
        align-items: center;
        padding: clamp(1.25rem, 3vw, 2.3rem);
        border: 1px solid var(--line);
        border-radius: inherit;
        backface-visibility: hidden;
        overflow: hidden;
    }

    .card-face::before {
        content: "";
        position: absolute;
        inset: 1rem;
        border: 1px solid rgba(77, 66, 49, 0.06);
        border-radius: calc(clamp(0.9rem, 1.5vw, 1.35rem) - 0.2rem);
        pointer-events: none;
    }

    .card-front {
        background: var(--paper);
    }

    .card-back {
        background: #f8fbf4;
        transform: rotateY(180deg);
    }

    .card-topline,
    .card-bottomline {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        color: var(--muted);
        font-size: 0.8rem;
        font-weight: 700;
    }

    .card-topline {
        padding-right: 2rem; /* Give space for absolute star button */
    }

    .card-star-btn {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        z-index: 10;
        background: none;
        border: none;
        color: var(--muted);
        font-size: 1.65rem;
        cursor: pointer;
        padding: 0.25rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 180ms ease, color 180ms ease;
    }
    .card-star-btn:hover {
        transform: scale(1.15);
        color: #B7791F;
    }
    .card-star-btn.is-starred {
        color: #B7791F;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.32rem 0.7rem;
        background: #ffffff;
        color: var(--muted);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .badge-blue {
        background: var(--blue-bg);
        border-color: rgba(31, 108, 159, 0.15);
        color: var(--blue);
    }

    .badge-green {
        background: var(--green-bg);
        border-color: rgba(47, 106, 55, 0.15);
        color: var(--green);
    }

    .card-content {
        position: relative;
        z-index: 1;
        width: 100%;
        text-align: center;
    }

    .card-word {
        display: block;
        max-width: 100%;
        overflow-wrap: anywhere;
        line-height: 1.02;
        letter-spacing: -0.04em;
    }

    .card-word-front {
        font-size: clamp(3rem, 8vw, 6.5rem);
        font-weight: 800;
        color: var(--ink);
    }

    .card-word-back {
        font-size: clamp(2.4rem, 6vw, 5.4rem);
        font-weight: 800;
        color: var(--green);
    }

    .control-dock {
        width: min(100%, 860px);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 1rem;
        align-items: center;
        padding: 0.85rem;
        border: 1px solid rgba(77, 66, 49, 0.1);
        border-radius: 1.15rem;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 14px 36px rgba(75, 63, 45, 0.08);
    }

    .nav-cluster,
    .audio-cluster {
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .audio-cluster {
        justify-content: flex-end;
    }

    .icon-button {
        width: 42px;
        padding: 0;
        font-size: 1rem;
        cursor: pointer;
    }

    .score-cluster {
        display: flex;
        gap: 0.8rem;
        align-items: center;
        justify-content: center;
    }

    .study-button {
        min-height: 50px;
        border: 1px solid transparent;
        border-radius: 999px;
        padding: 0.45rem 0.55rem 0.45rem 1.2rem;
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        min-width: 160px;
        color: var(--ink);
        font-weight: 800;
        cursor: pointer;
        transition: transform 180ms ease, filter 180ms ease;
    }

    .study-button:hover {
        filter: brightness(0.98);
    }

    .study-button.is-red {
        color: var(--red);
        background: var(--red-bg);
        border-color: rgba(156, 52, 48, 0.16);
    }

    .study-button.is-green {
        color: var(--green);
        background: var(--green-bg);
        border-color: rgba(47, 106, 55, 0.16);
    }

    .button-icon {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 1rem;
    }

    .is-red .button-icon {
        background: var(--red);
    }

    .is-green .button-icon {
        background: var(--green);
    }

    .tts-summary {
        min-height: 42px;
        list-style: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        padding: 0 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--muted);
        font-weight: 800;
        cursor: pointer;
    }

    .tts-summary::-webkit-details-marker {
        display: none;
    }

    .tts-panel {
        position: absolute;
        right: 0;
        top: calc(100% + 0.5rem);
        z-index: 5;
        width: min(88vw, 420px);
        padding: 0.9rem;
        border: 1px solid var(--line);
        border-radius: 1rem;
        background: #ffffff;
        box-shadow: 0 18px 48px rgba(75, 63, 45, 0.14);
        display: grid;
        gap: 0.75rem;
    }

    .tts-details {
        position: relative;
    }

    .tts-row {
        display: grid;
        grid-template-columns: 90px 1fr;
        gap: 0.75rem;
        align-items: center;
        color: var(--muted);
        font-size: 0.8rem;
        font-weight: 700;
    }

    .tts-row label {
        margin: 0;
    }

    .premium-select {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 0.65rem;
        padding: 0.48rem 0.65rem;
        background: #ffffff;
        color: var(--ink);
        font-size: 0.82rem;
        outline: none;
    }

    .shortcut-strip {
        width: min(100%, 860px);
        margin: 0 auto;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.45rem 1rem;
        color: var(--muted);
        font-size: 0.76rem;
        font-weight: 700;
    }

    .completion-view {
        display: none;
        position: relative;
        width: min(100%, 760px);
        min-height: 520px;
        margin: 0 auto;
        padding: clamp(1.5rem, 5vw, 3rem);
        text-align: center;
        border: 1px solid rgba(77, 66, 49, 0.12);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.78);
        box-shadow: 0 28px 70px rgba(75, 63, 45, 0.12);
        overflow: hidden;
    }

    .completion-inner {
        position: relative;
        z-index: 2;
    }

    .completion-title {
        margin: 0.8rem 0 0.5rem;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
    }

    .completion-copy {
        max-width: 520px;
        margin: 0 auto 1.5rem;
        color: var(--muted);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin: 1.5rem auto;
        max-width: 480px;
    }

    .stat-card {
        border: 1px solid transparent;
        border-radius: 1.1rem;
        padding: 1.25rem;
    }

    .stat-card.is-green {
        background: var(--green-bg);
        border-color: rgba(47, 106, 55, 0.15);
        color: var(--green);
    }

    .stat-card.is-red {
        background: var(--red-bg);
        border-color: rgba(156, 52, 48, 0.15);
        color: var(--red);
    }

    .stat-number {
        display: block;
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .stat-label {
        display: block;
        margin-top: 0.45rem;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .completion-actions {
        display: flex;
        justify-content: center;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .primary-dark {
        min-height: 50px;
        border: none;
        border-radius: 999px;
        padding: 0 1.2rem;
        background: var(--ink);
        color: #ffffff;
        font-weight: 800;
        cursor: pointer;
    }

    #fireworksCanvas {
        position: absolute;
        inset: -2rem;
        width: calc(100% + 4rem);
        height: calc(100% + 4rem);
        pointer-events: none;
        z-index: 1;
    }

    .study-filter-toggle {
        display: inline-flex;
        justify-self: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.2rem;
        background: rgba(255, 255, 255, 0.72);
        margin-top: 0.5rem;
    }

    .study-filter-toggle a {
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-decoration: none;
    }

    .study-filter-toggle a.is-active {
        background: var(--ink);
        color: #ffffff;
    }

    @@media (max-width: 767px) {
        .study-shell {
            padding: 0.75rem;
        }

        .study-header {
            grid-template-columns: 1fr auto;
        }

        .exit-link {
            grid-column: 1;
            grid-row: 1;
            justify-self: start;
        }

        .set-meta {
            grid-column: 1 / -1;
            grid-row: 2;
            text-align: left;
        }

        .progress-block {
            grid-column: 2;
            grid-row: 1;
            min-width: 120px;
        }

        .flashcard-core {
            height: clamp(300px, 48vh, 420px);
        }

        .control-dock {
            grid-template-columns: 1fr;
        }

        .nav-cluster,
        .audio-cluster,
        .score-cluster {
            justify-content: center;
        }

        .score-cluster {
            order: -1;
        }

        .study-button {
            min-width: 0;
            width: min(44vw, 170px);
            padding-left: 0.9rem;
        }

        .tts-panel {
            right: 50%;
            transform: translateX(50%);
        }
    }
</style>

<div class="study-shell">
    @Html.AntiForgeryToken()

    <section id="study-view" class="study-stage" aria-label="Học flashcard">
        <header class="study-header">
            <a class="exit-link" href="/Study/@Model.SetId" title="Backspace: thoát về trang học">
                <i class="ph ph-arrow-left"></i>
                <span>Thoát</span>
                <span class="keycap">Backspace</span>
            </a>

            <div class="set-meta">
                <div class="study-eyebrow">Học flashcard</div>
                <h1 id="set-title-header" class="set-title">@Model.SetTitle</h1>
                <div class="study-filter-toggle" aria-label="Lọc thẻ học">
                    <a class="@(Model.StarredOnly ? "" : "is-active")" href="/Study/@Model.SetId/Flashcard">Tất cả</a>
                    <a class="@(Model.StarredOnly ? "is-active" : "")" href="/Study/@Model.SetId/Flashcard?starredOnly=true">Đã sao</a>
                </div>
            </div>

            <div class="progress-block">
                <span id="card-progress-text" class="progress-text">Thẻ 1 / 1</span>
                <div class="progress-track" aria-hidden="true">
                    <div id="card-progress-fill" class="progress-fill"></div>
                </div>
            </div>
        </header>

        <main class="card-area">
            <div class="flashcard-frame" onclick="toggleCardFlip()" role="button" tabindex="0" aria-label="Lật thẻ">
                <div id="study-card-core" class="flashcard-core">
                    <article class="card-face card-front">
                        <button type="button" class="card-star-btn" onclick="toggleCurrentCardStar(event)" title="Đánh dấu sao">
                            <i class="ph ph-star"></i>
                        </button>
                        <div class="card-topline">
                            <span class="badge badge-blue">English</span>
                            <span>Click để lật</span>
                        </div>
                        <div class="card-content">
                            <span id="card-front-text" class="card-word card-word-front">Loading...</span>
                            <p id="card-phonetic" style="display: none;"></p>
                        </div>
                        <div class="card-bottomline">
                            <span>Space để lật nhanh</span>
                            <span>R để đọc lại</span>
                        </div>
                    </article>

                    <article class="card-face card-back">
                        <button type="button" class="card-star-btn" onclick="toggleCurrentCardStar(event)" title="Đánh dấu sao">
                            <i class="ph ph-star"></i>
                        </button>
                        <div class="card-topline">
                            <span class="badge badge-green">Nghĩa Việt</span>
                            <span>Click để quay lại</span>
                        </div>
                        <div class="card-content">
                            <span id="card-back-text" class="card-word card-word-back">Loading...</span>
                        </div>
                        <div class="card-bottomline">
                            <span>1: chưa biết</span>
                            <span>2: đã biết</span>
                        </div>
                    </article>
                </div>
            </div>
        </main>

        <section class="control-dock" aria-label="Điều khiển học">
            <div class="nav-cluster">
                <button type="button" class="icon-button" onclick="prevCard()" title="Thẻ trước">
                    <i class="ph ph-arrow-left"></i>
                </button>
                <button type="button" class="icon-button" onclick="nextCard()" title="Thẻ tiếp theo">
                    <i class="ph ph-arrow-right"></i>
                </button>
            </div>

            <div class="score-cluster">
                <button type="button" class="study-button is-red" onclick="markCard(false)">
                    <span>Chưa biết</span>
                    <span class="button-icon"><i class="ph ph-x"></i></span>
                </button>
                <button type="button" class="study-button is-green" onclick="markCard(true)">
                    <span>Đã biết</span>
                    <span class="button-icon"><i class="ph ph-check"></i></span>
                </button>
            </div>

            <div class="audio-cluster">
                <button type="button" class="icon-button" onclick="playAudioCurrentCard()" title="Đọc lại">
                    <i class="ph ph-speaker-high"></i>
                </button>

                <details class="tts-details">
                    <summary class="tts-summary">
                        <i class="ph ph-sliders-horizontal"></i>
                        <span>Giọng đọc</span>
                    </summary>
                    <div class="tts-panel">
                        <div class="tts-row">
                            <label for="tts-autoplay">Tự đọc</label>
                            <input type="checkbox" id="tts-autoplay" checked style="accent-color: #151515;">
                        </div>
                        <div class="tts-row">
                            <label for="tts-voice-select">Giọng EN</label>
                            <select id="tts-voice-select" class="premium-select"></select>
                        </div>
                        <div class="tts-row">
                            <label for="tts-speed">Tốc độ</label>
                            <select id="tts-speed" class="premium-select">
                                <option value="0.8">0.8x</option>
                                <option value="1.0" selected>1.0x</option>
                                <option value="1.2">1.2x</option>
                            </select>
                        </div>
                    </div>
                </details>
            </div>
        </section>

        <div class="shortcut-strip" aria-label="Phím tắt">
            <span><span class="keycap">Space</span> lật thẻ</span>
            <span><span class="keycap">←</span> thẻ trước</span>
            <span><span class="keycap">→</span> thẻ tiếp</span>
            <span><span class="keycap">Backspace</span> thoát</span>
        </div>
    </section>

    <section id="completion-view" class="completion-view" aria-label="Hoàn thành">
        <canvas id="fireworksCanvas"></canvas>
        <div class="completion-inner">
            <span class="badge badge-green">Đã hoàn thành bộ thẻ</span>
            <h2 class="completion-title">Hoàn thành phiên học</h2>
            <p class="completion-copy">
                Tiến độ của bạn đã được ghi nhận. Xem nhanh nhóm thẻ đã biết và nhóm cần ôn lại bên dưới.
            </p>

            <div class="stats-grid">
                <div class="stat-card is-green">
                    <span id="count-learned" class="stat-number">0</span>
                    <span class="stat-label">Đã biết</span>
                </div>
                <div class="stat-card is-red">
                    <span id="count-unlearned" class="stat-number">0</span>
                    <span class="stat-label">Cần ôn</span>
                </div>
            </div>

            <div class="completion-actions">
                <button type="button" class="study-button is-red" onclick="restartStudy()">
                    <span>Ôn lại</span>
                    <span class="button-icon"><i class="ph ph-arrow-counter-clockwise"></i></span>
                </button>
                <button type="button" class="primary-dark" onclick="completeStudySession()">
                    Về trang học
                </button>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const flashcards = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Flashcards.Select(c => new { c.Id, c.FrontText, c.BackText, c.IsStarred })));
        const setId = @Model.SetId;

        let currentIndex = 0;
        let isFlipped = false;

        const sessionStats = {
            learned: new Set(),
            unlearned: new Set()
        };

        let voices = [];
        const synth = window.speechSynthesis;
        const voiceSelect = document.getElementById('tts-voice-select');
        const autoplayCheckbox = document.getElementById('tts-autoplay');
        const speedSelect = document.getElementById('tts-speed');

        function exitStudy() {
            window.location.href = `/Study/${setId}`;
        }

        function loadVoices() {
            if (!synth || !voiceSelect) return;

            voices = synth.getVoices();
            voiceSelect.innerHTML = '';

            const enVoices = voices.filter(v => v.lang.startsWith('en'));

            if (enVoices.length === 0) {
                const opt = document.createElement('option');
                opt.textContent = 'Mặc định hệ thống';
                opt.value = 'default';
                voiceSelect.appendChild(opt);
            } else {
                enVoices.forEach(voice => {
                    const opt = document.createElement('option');
                    opt.value = voice.name;
                    opt.textContent = `${voice.name} (${voice.lang})`;
                    if (voice.name.toLowerCase().includes('zira') || voice.name.toLowerCase().includes('female')) {
                        opt.selected = true;
                    }
                    voiceSelect.appendChild(opt);
                });
            }

            restoreTtsSettings();
        }

        if (synth) {
            if (synth.onvoiceschanged !== undefined) {
                synth.onvoiceschanged = loadVoices;
            }
            loadVoices();
        }

        function saveTtsSettings() {
            if (!voiceSelect || !autoplayCheckbox || !speedSelect) return;
            localStorage.setItem('ltwnc_tts_settings', JSON.stringify({
                autoplay: autoplayCheckbox.checked,
                voiceName: voiceSelect.value,
                speed: speedSelect.value
            }));
        }

        function restoreTtsSettings() {
            const data = localStorage.getItem('ltwnc_tts_settings');
            if (!data) return;

            try {
                const settings = JSON.parse(data);
                autoplayCheckbox.checked = settings.autoplay;
                speedSelect.value = settings.speed || '1.0';

                for (let i = 0; i < voiceSelect.options.length; i++) {
                    if (voiceSelect.options[i].value === settings.voiceName) {
                        voiceSelect.selectedIndex = i;
                        break;
                    }
                }
            } catch (e) {
                console.error('Failed to restore TTS settings', e);
            }
        }

        autoplayCheckbox?.addEventListener('change', saveTtsSettings);
        voiceSelect?.addEventListener('change', saveTtsSettings);
        speedSelect?.addEventListener('change', saveTtsSettings);

        function speak(text, isVietnamese = false) {
            if (!synth || !text || text.trim() === '') return;
            if (synth.speaking) synth.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.rate = parseFloat(speedSelect?.value) || 1.0;

            if (isVietnamese) {
                const viVoice = voices.find(v => v.lang.startsWith('vi'));
                if (viVoice) utterance.voice = viVoice;
                utterance.lang = 'vi-VN';
            } else {
                const enVoice = voices.find(v => v.name === voiceSelect?.value);
                if (enVoice) utterance.voice = enVoice;
                utterance.lang = 'en-US';
            }

            synth.speak(utterance);
        }

        function updateUI() {
            if (flashcards.length === 0) return;

            const currentCard = flashcards[currentIndex];
            document.getElementById('card-front-text').textContent = currentCard.FrontText;
            document.getElementById('card-back-text').textContent = currentCard.BackText;

            const cardCore = document.getElementById('study-card-core');
            cardCore.classList.remove('flipped');
            isFlipped = false;

            const currentDisplay = currentIndex + 1;
            const total = flashcards.length;
            document.getElementById('card-progress-text').textContent = `Thẻ ${currentDisplay} / ${total}`;
            document.getElementById('card-progress-fill').style.width = `${(currentDisplay / total) * 100}%`;

            updateStarUI(currentCard.IsStarred);
        }

        function toggleCurrentCardStar(event) {
            if (event) {
                event.stopPropagation(); // Prevents flipping the card when clicking the star!
            }
            if (flashcards.length === 0) return;

            const card = flashcards[currentIndex];
            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

            // Optimistic update of UI
            card.IsStarred = !card.IsStarred;
            updateStarUI(card.IsStarred);

            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);

            fetch(`/Study/${setId}/Flashcard/${card.Id}/ToggleStar`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    card.IsStarred = data.isStarred;
                    updateStarUI(card.IsStarred);
                } else {
                    // Revert if failed
                    card.IsStarred = !card.IsStarred;
                    updateStarUI(card.IsStarred);
                }
            })
            .catch(err => {
                console.error('AJAX Error:', err);
                // Revert if failed
                card.IsStarred = !card.IsStarred;
                updateStarUI(card.IsStarred);
            });
        }

        function updateStarUI(isStarred) {
            const starIconFront = document.querySelector('.card-front .card-star-btn i');
            const starIconBack = document.querySelector('.card-back .card-star-btn i');
            const starBtnFront = document.querySelector('.card-front .card-star-btn');
            const starBtnBack = document.querySelector('.card-back .card-star-btn');

            if (starIconFront && starIconBack) {
                if (isStarred) {
                    starIconFront.className = 'ph ph-star-fill';
                    starIconBack.className = 'ph ph-star-fill';
                    starBtnFront.classList.add('is-starred');
                    starBtnBack.classList.add('is-starred');
                } else {
                    starIconFront.className = 'ph ph-star';
                    starIconBack.className = 'ph ph-star';
                    starBtnFront.classList.remove('is-starred');
                    starBtnBack.classList.remove('is-starred');
                }
            }
        }

        function toggleCardFlip() {
            if (flashcards.length === 0) return;

            const cardCore = document.getElementById('study-card-core');
            isFlipped = !isFlipped;
            cardCore.classList.toggle('flipped', isFlipped);

            if (!isFlipped) {
                if (synth) synth.cancel();
                return;
            }

            if (autoplayCheckbox?.checked) {
                speak(flashcards[currentIndex].FrontText, false);
                setTimeout(() => {
                    if (isFlipped) speak(flashcards[currentIndex].BackText, true);
                }, 1000);
            }
        }

        function playAudioCurrentCard() {
            if (flashcards.length === 0) return;
            const current = flashcards[currentIndex];
            speak(isFlipped ? current.BackText : current.FrontText, isFlipped);
        }

        function nextCard() {
            if (currentIndex < flashcards.length - 1) {
                currentIndex++;
                updateUI();
                return;
            }

            showCompletionScreen();
        }

        function prevCard() {
            if (currentIndex > 0) {
                currentIndex--;
                updateUI();
            }
        }

        function markCard(learned) {
            if (flashcards.length === 0) return;

            const card = flashcards[currentIndex];

            if (learned) {
                sessionStats.learned.add(card.Id);
                sessionStats.unlearned.delete(card.Id);
            } else {
                sessionStats.unlearned.add(card.Id);
                sessionStats.learned.delete(card.Id);
            }

            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);
            params.append('setId', setId);
            params.append('cardId', card.Id);
            params.append('learned', learned);

            fetch(`/Study/${setId}/Flashcard/Mark`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => {
                if (!res.ok) console.error('Failed to save progress to server');
            })
            .catch(err => console.error('AJAX Error:', err));

            nextCard();
        }

        function restartStudy() {
            currentIndex = 0;
            sessionStats.learned.clear();
            sessionStats.unlearned.clear();

            document.getElementById('study-view').style.display = 'grid';
            document.getElementById('completion-view').style.display = 'none';

            stopFireworks();
            updateUI();
        }

        function completeStudySession() {
            const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const params = new URLSearchParams();
            params.append('__RequestVerificationToken', verificationToken);
            params.append('setId', setId);

            fetch(`/Study/${setId}/Complete`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: params
            })
            .then(res => res.json())
            .then(data => {
                window.location.href = data.success && data.redirectUrl ? data.redirectUrl : `/Study/${setId}`;
            })
            .catch(err => {
                console.error('AJAX Error:', err);
                window.location.href = `/Study/${setId}`;
            });
        }

        function showCompletionScreen() {
            const learnedCount = sessionStats.learned.size;
            const unlearnedCount = flashcards.length - learnedCount;

            document.getElementById('count-learned').textContent = learnedCount;
            document.getElementById('count-unlearned').textContent = unlearnedCount;

            document.getElementById('study-view').style.display = 'none';
            document.getElementById('completion-view').style.display = 'block';

            startFireworks();
        }

        document.addEventListener('keydown', function(e) {
            const tagName = e.target.tagName;
            if (tagName === 'INPUT' || tagName === 'SELECT' || tagName === 'TEXTAREA' || e.target.isContentEditable) return;

            switch (e.key) {
                case ' ':
                    e.preventDefault();
                    toggleCardFlip();
                    break;
                case 'Backspace':
                    e.preventDefault();
                    exitStudy();
                    break;
                case 'ArrowLeft':
                    e.preventDefault();
                    prevCard();
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    nextCard();
                    break;
                case '1':
                    markCard(false);
                    break;
                case '2':
                    markCard(true);
                    break;
                case 'r':
                case 'R':
                    playAudioCurrentCard();
                    break;
            }
        });

        document.querySelector('.flashcard-frame')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                toggleCardFlip();
            }
        });

        updateUI();

        let canvas, ctx, animationFrameId;
        let fireworksList = [];
        let particlesList = [];
        const celebrateColors = ['#2f6a37', '#1f6c9f', '#9c3430', '#956400', '#151515'];

        class CanvasParticle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.color = color;
                this.angle = Math.random() * Math.PI * 2;
                this.speed = Math.random() * 4 + 1.5;
                this.friction = 0.96;
                this.gravity = 0.08;
                this.alpha = 1;
                this.decay = Math.random() * 0.015 + 0.008;
                this.radius = Math.random() * 2 + 1.5;
            }

            update() {
                this.speed *= this.friction;
                this.x += Math.cos(this.angle) * this.speed;
                this.y += Math.sin(this.angle) * this.speed + this.gravity;
                this.alpha -= this.decay;
            }

            draw() {
                ctx.save();
                ctx.globalAlpha = this.alpha;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        class CanvasFirework {
            constructor() {
                const w = canvas.width / window.devicePixelRatio;
                const h = canvas.height / window.devicePixelRatio;
                this.x = Math.random() * w;
                this.y = h;
                this.targetY = Math.random() * (h * 0.55) + 30;
                this.speed = Math.random() * 5 + 6;
                this.color = celebrateColors[Math.floor(Math.random() * celebrateColors.length)];
                this.exploded = false;
            }

            update() {
                if (!this.exploded) {
                    this.y -= this.speed;
                    this.speed *= 0.98;
                    if (this.speed <= 1 || this.y <= this.targetY) {
                        this.exploded = true;
                        this.explode();
                    }
                }
            }

            draw() {
                if (!this.exploded) {
                    ctx.fillStyle = this.color;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, 2, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            explode() {
                const count = Math.floor(Math.random() * 25) + 35;
                for (let i = 0; i < count; i++) {
                    particlesList.push(new CanvasParticle(this.x, this.y, this.color));
                }
            }
        }

        function resizeCanvas() {
            if (!canvas || !ctx) return;

            const dpr = window.devicePixelRatio || 1;
            canvas.width = canvas.offsetWidth * dpr;
            canvas.height = canvas.offsetHeight * dpr;
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function animateFireworks() {
            const w = canvas.width / (window.devicePixelRatio || 1);
            const h = canvas.height / (window.devicePixelRatio || 1);

            ctx.fillStyle = 'rgba(255, 255, 255, 0.22)';
            ctx.fillRect(0, 0, w, h);

            if (Math.random() < 0.05 && fireworksList.length < 4) {
                fireworksList.push(new CanvasFirework());
            }

            for (let i = fireworksList.length - 1; i >= 0; i--) {
                fireworksList[i].update();
                fireworksList[i].draw();
                if (fireworksList[i].exploded) fireworksList.splice(i, 1);
            }

            for (let i = particlesList.length - 1; i >= 0; i--) {
                particlesList[i].update();
                particlesList[i].draw();
                if (particlesList[i].alpha <= 0) particlesList.splice(i, 1);
            }

            animationFrameId = requestAnimationFrame(animateFireworks);
        }

        function startFireworks() {
            canvas = document.getElementById('fireworksCanvas');
            ctx = canvas.getContext('2d');
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();
            fireworksList = [];
            particlesList = [];
            animateFireworks();
        }

        function stopFireworks() {
            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
                animationFrameId = null;
            }
            window.removeEventListener('resize', resizeCanvas);
        }
    </script>
}
