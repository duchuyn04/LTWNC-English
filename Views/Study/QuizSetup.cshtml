@model QuizSetupViewModel
@{
    ViewData["Title"] = "Thiết lập trắc nghiệm";
}

@section Styles {
    <link rel="stylesheet" href="~/css/quiz.css" asp-append-version="true" />
}

<div class="quiz-shell">
    <main class="quiz-stage">
        <header class="quiz-header">
            <a class="quiz-exit" asp-action="Index" asp-route-setId="@Model.SetId">Thoát</a>
            <div class="quiz-heading">
                <span class="quiz-eyebrow">Trắc nghiệm</span>
                <h1>@Model.SetTitle</h1>
            </div>
        </header>

        <section class="quiz-card" aria-labelledby="quiz-setup-title">
            <h2 id="quiz-setup-title">Chọn thời gian làm bài</h2>
            <form asp-route="QuizStartPost"
                  asp-route-setId="@Model.SetId"
                  method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" role="alert"></div>
                <fieldset>
                    <legend>Thời lượng</legend>
                    <label><input asp-for="SelectedPresetMinutes" type="radio" value="5" /> 5 phút</label>
                    <label><input asp-for="SelectedPresetMinutes" type="radio" value="10" /> 10 phút</label>
                    <label><input asp-for="SelectedPresetMinutes" type="radio" value="15" /> 15 phút</label>
                    <label><input asp-for="SelectedPresetMinutes" type="radio" value="20" /> 20 phút</label>
                </fieldset>

                <label asp-for="CustomMinutes">Hoặc nhập số phút khác</label>
                <input asp-for="CustomMinutes" type="number" min="1" max="120" step="1" />
                <span asp-validation-for="CustomMinutes"></span>

                <button type="submit" class="quiz-action quiz-action-primary">Bắt đầu bài kiểm tra</button>
            </form>

            @if (Model.ActiveSessionId.HasValue)
            {
                <p>
                    Bạn còn một bài đang dở dang.
                    <a asp-action="Quiz"
                       asp-route-setId="@Model.SetId"
                       asp-route-sessionId="@Model.ActiveSessionId">Tiếp tục làm bài</a>
                </p>
            }
        </section>
    </main>
</div>
