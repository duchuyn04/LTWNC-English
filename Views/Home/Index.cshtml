@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

@section FullWidth {
<!-- Hero Section -->
<section class="landing-hero">
    <div class="container">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-6" data-aos="fade-right">
                <h1 class="landing-hero-title" id="typewriter-target"></h1>
                <p class="landing-hero-subtitle" id="hero-subtitle" style="opacity: 0;">
                    Tạo bộ thẻ của riêng bạn hoặc học từ bộ thẻ có sẵn từ cộng đồng.
                </p>
                <div class="d-flex gap-3 flex-wrap" id="hero-buttons" style="opacity: 0;">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Set" class="btn-primary-custom btn-lg">
                            <i class="ph ph-play-circle"></i> Bắt đầu học
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Register" class="btn-primary-custom btn-lg">
                            <i class="ph ph-rocket-launch"></i> Bắt đầu học
                        </a>
                    }
                    <a href="#featured-sets" class="btn-secondary-custom btn-lg smooth-scroll">
                        <i class="ph ph-compass"></i> Khám phá bộ thẻ
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center" data-aos="fade-left" data-aos-delay="500">
                <div class="hero-illustration">
                    <div class="floating-card floating-card-1">
                        <div class="floating-card-inner">
                            <span class="floating-card-front">Hello</span>
                            <span class="floating-card-back">Xin chào</span>
                        </div>
                    </div>
                    <div class="floating-card floating-card-2">
                        <div class="floating-card-inner">
                            <span class="floating-card-front">Thank you</span>
                            <span class="floating-card-back">Cảm ơn</span>
                        </div>
                    </div>
                    <div class="floating-card floating-card-3">
                        <div class="floating-card-inner">
                            <span class="floating-card-front">Good morning</span>
                            <span class="floating-card-back">Chào buổi sáng</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Counter Section -->
<section class="landing-stats" data-aos="fade-up">
    <div class="container">
        <div class="row justify-content-center g-4">
            <div class="col-md-4">
                <div class="stats-card text-center">
                    <div class="stats-number" data-target="1000">0</div>
                    <div class="stats-label">Người dùng</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card text-center">
                    <div class="stats-number" data-target="500">0</div>
                    <div class="stats-label">Bộ thẻ</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card text-center">
                    <div class="stats-number" data-target="10000">0</div>
                    <div class="stats-label">Thẻ đã học</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="landing-how-it-works">
    <div class="container">
        <h2 class="section-title text-center mb-5" data-aos="fade-up">Cách hoạt động</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4" data-aos="fade-right" data-aos-delay="0">
                <div class="step-card text-center">
                    <div class="step-icon">
                        <i class="ph ph-plus-circle"></i>
                    </div>
                    <h4 class="step-title">Tạo bộ thẻ</h4>
                    <p class="step-desc">Tạo bộ thẻ flashcard với từ vựng bạn muốn học. Thêm nghĩa và mô tả.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-right" data-aos-delay="200">
                <div class="step-card text-center">
                    <div class="step-icon">
                        <i class="ph ph-brain"></i>
                    </div>
                    <h4 class="step-title">Học mỗi ngày</h4>
                    <p class="step-desc">Lật thẻ, đánh dấu đã biết hoặc chưa biết. Lặp lại để ghi nhớ lâu hơn.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-right" data-aos-delay="400">
                <div class="step-card text-center">
                    <div class="step-icon">
                        <i class="ph ph-share-network"></i>
                    </div>
                    <h4 class="step-title">Chia sẻ cộng đồng</h4>
                    <p class="step-desc">Chia sẻ bộ thẻ của bạn và học từ bộ thẻ của người khác.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Sets Section -->
<section class="landing-featured" id="featured-sets">
    <div class="container">
        <h2 class="section-title text-center mb-5" data-aos="fade-up">Bộ thẻ nổi bật</h2>

        @if (!Model.PublicSets.Any())
        {
            <div class="text-center py-5" style="color: #787774;" data-aos="fade-up">
                <i class="ph ph-book-open" style="font-size: 3rem;"></i>
                <p class="mt-3">Chưa có bộ thẻ nào. Hãy là người đầu tiên tạo!</p>
            </div>
        }

        <div class="row g-4">
            @foreach (var set in Model.PublicSets)
            {
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="card-custom h-100">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="mb-0" style="font-weight: 600;">@set.Title</h5>
                            <span class="tag tag-new">Công khai</span>
                        </div>
                        @if (!string.IsNullOrEmpty(set.Description))
                        {
                            <p style="color: #787774; font-size: 0.875rem;">@set.Description</p>
                        }
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <small style="color: #787774;">
                                <i class="ph ph-cards"></i> @(set.Flashcards?.Count ?? 0) thẻ
                            </small>
                            <a href="/Study/@set.Id" class="btn-primary-custom" style="padding: 4px 16px; font-size: 0.8125rem;">
                                <i class="ph ph-play-circle"></i> Học ngay
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
}

@section Scripts {
<script>
    // AOS Init
    AOS.init({
        duration: 800,
        once: true,
        offset: 100
    });

    // Typewriter Effect
    function typeWriter(element, text, speed = 80, callback) {
        let i = 0;
        element.textContent = '';
        function type() {
            if (i < text.length) {
                element.textContent += text.charAt(i);
                i++;
                setTimeout(type, speed);
            } else if (callback) {
                callback();
            }
        }
        type();
    }

    // Start typewriter on load
    document.addEventListener('DOMContentLoaded', function() {
        const target = document.getElementById('typewriter-target');
        if (target) {
            typeWriter(target, 'Học tiếng Anh với Flashcard', 80, function() {
                // Show subtitle after typewriter completes
                const subtitle = document.getElementById('hero-subtitle');
                const buttons = document.getElementById('hero-buttons');
                if (subtitle) {
                    subtitle.style.transition = 'opacity 0.6s ease';
                    subtitle.style.opacity = '1';
                }
                if (buttons) {
                    setTimeout(() => {
                        buttons.style.transition = 'opacity 0.6s ease';
                        buttons.style.opacity = '1';
                    }, 300);
                }
            });
        }
    });

    // Counter Animation
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const counters = entry.target.querySelectorAll('.stats-number');
                counters.forEach(counter => {
                    const target = parseInt(counter.getAttribute('data-target'));
                    animateCounter(counter, target);
                });
                counterObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });

    const statsSection = document.querySelector('.landing-stats');
    if (statsSection) counterObserver.observe(statsSection);

    function animateCounter(element, target, duration = 2000) {
        const startTime = performance.now();
        function update(currentTime) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
            element.textContent = Math.floor(eased * target).toLocaleString();
            if (progress < 1) {
                requestAnimationFrame(update);
            } else {
                element.textContent = target.toLocaleString() + '+';
            }
        }
        requestAnimationFrame(update);
    }

    // Smooth Scroll
    document.querySelectorAll('.smooth-scroll').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
</script>
}
