@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
    ViewData["HideLayoutChrome"] = true;
    var primaryCta = User.Identity?.IsAuthenticated == true ? "/Set/Create" : "/Account/Register";
    var secondaryCta = User.Identity?.IsAuthenticated == true ? "/Set" : "#featured-sets";
}

@section FullWidth {
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="home-landing">

    <nav class="home-nav">
        <div class="container home-nav-inner">
            <a class="navbar-brand fw-bold" href="/">
                <i class="ph ph-book-open"></i> LTWNC English
            </a>
            <button class="home-nav-toggle" aria-label="Toggle menu" onclick="toggleMobileMenu()">
                <i class="ph ph-list"></i>
            </button>
            <div class="home-nav-menu" id="homeNavMenu">
                <div class="home-nav-links">
                    <a href="#benefits" onclick="closeMobileMenu()">Lợi ích</a>
                    <a href="#services" onclick="closeMobileMenu()">Tính năng</a>
                    <a href="#onboarding" onclick="closeMobileMenu()">Cách bắt đầu</a>
                    <a href="#quote" onclick="closeMobileMenu()">Tư vấn học</a>
                </div>
                <a class="btn-primary-custom" href="@primaryCta">
                    <i class="ph ph-arrow-right"></i> Bắt đầu
                </a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="home-quote-strip d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <div>
                <strong>Muốn có lộ trình học từ vựng rõ ràng?</strong>
                <span class="ms-2 text-muted">Chọn mục tiêu, tạo bộ thẻ, bắt đầu ôn ngay.</span>
            </div>
            <a class="btn-secondary-custom" href="@primaryCta">Bắt đầu lộ trình</a>
        </div>
    </div>

    <section class="home-hero hero-container-wrapper">
        <div class="fog-container">
            <div class="fog-orb orb-1"></div>
            <div class="fog-orb orb-2"></div>
            <div class="fog-orb orb-3"></div>
        </div>
        <div class="container" style="position: relative; z-index: 2;">
            <div class="row align-items-center g-5">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="home-kicker">Flashcard learning service</div>
                    <h1>Học từ vựng tiếng Anh <span id="typewriter-text" class="typewriter-text"></span><span class="typewriter-cursor">|</span></h1>
                    <p class="home-section-copy mt-3">
                        LTWNC English giúp bạn tạo bộ thẻ, luyện phát âm, đánh dấu từ quan trọng
                        và theo dõi tiến độ học trong một giao diện gọn.
                    </p>
                    <div class="home-btn-row home-btn-row--hero mt-4">
                        <a class="btn-primary-custom btn-lg" href="@primaryCta">
                            <i class="ph ph-rocket-launch"></i> Tạo bộ thẻ
                        </a>
                        <a class="btn-secondary-custom btn-lg" href="@secondaryCta">
                            <i class="ph ph-compass"></i> Khám phá
                        </a>
                    </div>

                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="hero-carousel-wrapper">
                        <!-- Left Navigation Button -->
                        <button class="carousel-nav-btn nav-btn-left" onclick="rotateCarousel('left')" aria-label="Previous card">
                            <i class="ph ph-caret-left"></i>
                        </button>

                        <div class="hero-carousel-container" id="heroCarousel">
                            <!-- Card 1: consistency (Center position at index 0) -->
                            <div class="hero-carousel-item pos-center" data-index="0">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front" style="border-radius: 16px; background: #111827; border: 1px solid rgba(255,255,255,0.1); padding: 1rem;">
                                            <div>
                                                <span class="badge bg-secondary text-white mb-2" style="font-size: 0.65rem; background: rgba(255,255,255,0.1) !important;">NOUN</span>
                                                <h4 class="fw-bold mb-1" style="font-size: 1.2rem; color: #ffffff !important; letter-spacing: -0.02em;">consistency</h4>
                                                <p class="mb-0" style="font-size: 0.75rem; color: rgba(255, 255, 255, 0.45) !important;">/kənˈsɪstənsi/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back text-white" style="border-radius: 16px; background: #1f6c9f; border-color: rgba(255, 255, 255, 0.2); padding: 1rem;">
                                            <div>
                                                <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">sự nhất quán</h5>
                                                <p class="mb-0" style="font-size: 0.7rem; color: rgba(255,255,255,0.85);">Sự kiên định, không thay đổi.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 2: fluency (Right position at index 1) -->
                            <div class="hero-carousel-item pos-right" data-index="1">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front" style="border-radius: 16px; background: #111827; border: 1px solid rgba(255,255,255,0.1); padding: 1rem;">
                                            <div>
                                                <span class="badge bg-secondary text-white mb-2" style="font-size: 0.65rem; background: rgba(255,255,255,0.1) !important;">NOUN</span>
                                                <h4 class="fw-bold mb-1" style="font-size: 1.2rem; color: #ffffff !important; letter-spacing: -0.02em;">fluency</h4>
                                                <p class="mb-0" style="font-size: 0.75rem; color: rgba(255, 255, 255, 0.45) !important;">/ˈfluːənsi/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back text-white" style="border-radius: 16px; background: #2f6a37; border-color: rgba(255, 255, 255, 0.2); padding: 1rem;">
                                            <div>
                                                <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">sự trôi chảy</h5>
                                                <p class="mb-0" style="font-size: 0.7rem; color: rgba(255,255,255,0.85);">Nói hoặc viết trơn tru, dễ dàng.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 3: vocabulary (Back position at index 2) -->
                            <div class="hero-carousel-item pos-back" data-index="2">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front" style="border-radius: 16px; background: #111827; border: 1px solid rgba(255,255,255,0.1); padding: 1rem;">
                                            <div>
                                                <span class="badge bg-secondary text-white mb-2" style="font-size: 0.65rem; background: rgba(255,255,255,0.1) !important;">NOUN</span>
                                                <h4 class="fw-bold mb-1" style="font-size: 1.2rem; color: #ffffff !important; letter-spacing: -0.02em;">vocabulary</h4>
                                                <p class="mb-0" style="font-size: 0.75rem; color: rgba(255, 255, 255, 0.45) !important;">/vəˈkæbjələri/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back text-white" style="border-radius: 16px; background: #b7791f; border-color: rgba(255, 255, 255, 0.2); padding: 1rem;">
                                            <div>
                                                <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">vốn từ vựng</h5>
                                                <p class="mb-0" style="font-size: 0.7rem; color: rgba(255,255,255,0.85);">Tập hợp các từ trong một ngôn ngữ.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 4: persistence (Left position at index 3) -->
                            <div class="hero-carousel-item pos-left" data-index="3">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front" style="border-radius: 16px; background: #111827; border: 1px solid rgba(255,255,255,0.1); padding: 1rem;">
                                            <div>
                                                <span class="badge bg-secondary text-white mb-2" style="font-size: 0.65rem; background: rgba(255,255,255,0.1) !important;">NOUN</span>
                                                <h4 class="fw-bold mb-1" style="font-size: 1.2rem; color: #ffffff !important; letter-spacing: -0.02em;">persistence</h4>
                                                <p class="mb-0" style="font-size: 0.75rem; color: rgba(255, 255, 255, 0.45) !important;">/pəˈsɪstəns/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back text-white" style="border-radius: 16px; background: #6b21a8; border-color: rgba(255, 255, 255, 0.2); padding: 1rem;">
                                            <div>
                                                <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">sự kiên trì</h5>
                                                <p class="mb-0" style="font-size: 0.7rem; color: rgba(255,255,255,0.85);">Bền bỉ theo đuổi mục tiêu.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Navigation Button -->
                        <button class="carousel-nav-btn nav-btn-right" onclick="rotateCarousel('right')" aria-label="Next card">
                            <i class="ph ph-caret-right"></i>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Stats wrapper: after carousel on mobile/tablet, left-aligned on desktop -->
            <div class="home-stats-wrapper">
                <div class="home-stats">
                    <div class="home-stat"><strong><span class="stat-count" data-target="3">0</span> phút</strong><span class="stat-label-long">Tạo bộ thẻ đầu tiên</span><span class="stat-label-short">Tạo bộ thẻ</span></div>
                    <div class="home-stat"><strong><span class="stat-count" data-target="5">0</span> chế độ</strong><span class="stat-label-long">Học và ôn tập</span><span class="stat-label-short">Học &amp; ôn tập</span></div>
                    <div class="home-stat"><strong><span class="stat-count" data-target="100">0</span>%</strong><span class="stat-label-long">Theo dõi tiến độ</span><span class="stat-label-short">Theo dõi</span></div>
                </div>
            </div>
        </div>
    </section>

    <section id="benefits">
        <div class="container">
            <div class="text-center mb-4">
                <div class="home-kicker">Benefits</div>
                <h2 class="home-section-title mist-reveal">Tập trung vào cách bạn ghi nhớ.</h2>
            </div>
            <div class="home-bento-panel" data-aos="fade-up">
                <div class="home-bento-grid-4">
                    <div class="home-bento-card bento-span-2" data-aos="fade-up" data-aos-delay="0"><span class="home-icon"><i class="ph ph-cards"></i></span><h3 class="h5 mt-3">Flashcard rõ ràng</h3><p class="home-section-copy">Mỗi từ có nghĩa, IPA, ví dụ và trạng thái học.</p></div>
                    <div class="home-bento-card" data-aos="fade-up" data-aos-delay="100"><span class="home-icon"><i class="ph ph-speaker-high"></i></span><h3 class="h5 mt-3">Giọng đọc</h3><p class="home-section-copy">Nghe phát âm tiếng Anh ngay khi học thẻ.</p></div>
                    <div class="home-bento-card" data-aos="fade-up" data-aos-delay="200"><span class="home-icon"><i class="ph ph-star"></i></span><h3 class="h5 mt-3">Đánh dấu sao</h3><p class="home-section-copy">Tách nhóm từ quan trọng để ôn nhanh.</p></div>
                    <div class="home-bento-card bento-span-2" data-aos="fade-up" data-aos-delay="300"><span class="home-icon"><i class="ph ph-chart-line-up"></i></span><h3 class="h5 mt-3">Tiến độ học</h3><p class="home-section-copy">Biết từ nào chưa học, đang học, đã thành thạo.</p></div>
                </div>
            </div>
        </div>
    </section>

    <section id="services">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-7">
                    <div class="home-kicker">Services</div>
                    <h2 class="home-section-title mist-reveal">Dịch vụ học nằm ngay trong app.</h2>
                </div>
                <div class="col-lg-5"><p class="home-section-copy">Không thêm quy trình phức tạp: tạo bộ thẻ, học, xem tiến độ.</p></div>
            </div>
            <div class="home-bento-panel" data-aos="fade-up">
                <div class="home-bento-grid-3">
                    <div class="home-bento-card" data-aos="zoom-in" data-aos-delay="0"><span class="home-icon"><i class="ph ph-plus-circle"></i></span><h3 class="h5 mt-3">Tạo bộ thẻ</h3><p class="home-section-copy">Nhập thuật ngữ, định nghĩa, IPA, ví dụ và ảnh minh họa.</p></div>
                    <div class="home-bento-card bento-span-2" data-aos="zoom-in" data-aos-delay="100"><span class="home-icon"><i class="ph ph-brain"></i></span><h3 class="h5 mt-3">Học flashcard</h3><p class="home-section-copy">Lật thẻ, nghe voice, trộn thẻ, đánh dấu đã biết/chưa biết.</p></div>
                    <div class="home-bento-card bento-span-3" data-aos="zoom-in" data-aos-delay="200"><span class="home-icon"><i class="ph ph-stack"></i></span><h3 class="h5 mt-3">Theo dõi tiến độ</h3><p class="home-section-copy">Sắp xếp theo trạng thái học để biết nên ôn gì trước.</p></div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container">
            <div class="home-feature-block">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="home-kicker">Product</div>
                        <h2 class="home-section-title text-white mist-reveal">Một workspace học từ vựng gọn.</h2>
                        <p class="text-white-50">Từ tạo bộ thẻ đến học flashcard đều nằm trong cùng một luồng.</p>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <div class="flashcard-3d-wrapper" style="min-height: 200px;">
                            <div class="flashcard-3d-card" onclick="this.classList.toggle('flipped')" style="min-height: 200px;">
                                <div class="flashcard-face flashcard-front" style="border-radius: 16px;">
                                    <div>
                                        <span class="badge bg-secondary text-white mb-2">VOCABULARY</span>
                                        <h4 class="fw-bold mb-1" style="color: #ffffff !important;">debugging</h4>
                                        <p class="mb-0" style="color: rgba(255, 255, 255, 0.45) !important;">/ˌdiːˈbʌɡɪŋ/ · Click to flip</p>
                                    </div>
                                </div>
                                <div class="flashcard-face flashcard-back text-white" style="border-radius: 16px; background: #2f6a37; border-color: rgba(255, 255, 255, 0.2); padding: 1.5rem;">
                                    <div>
                                        <h4 class="fw-bold mb-1 text-white">gỡ lỗi</h4>
                                        <p class="mb-0 text-white-50" style="font-size: 0.85rem;">Debugging helped identify the cause of the system crash.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container">
            <div class="home-logo-row justify-content-center">
                <span class="home-logo-pill">Flashcards</span>
                <span class="home-logo-pill">Voice</span>
                <span class="home-logo-pill">Progress</span>
                <span class="home-logo-pill">Images</span>
                <span class="home-logo-pill">Public sets</span>
            </div>
        </div>
    </section>

    <section>
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="home-kicker">Why choose us</div>
                    <h2 class="home-section-title mist-reveal">Ít thao tác, nhiều thời gian học hơn.</h2>
                </div>
                <div class="col-lg-6 home-checklist">
                    <div class="home-check" data-aos="fade-left" data-aos-delay="0"><i class="ph ph-check-circle"></i><span>Không cần cài thêm công cụ học rời rạc.</span></div>
                    <div class="home-check" data-aos="fade-left" data-aos-delay="100"><i class="ph ph-check-circle"></i><span>Dữ liệu bộ thẻ nằm trong tài khoản của bạn.</span></div>
                    <div class="home-check" data-aos="fade-left" data-aos-delay="200"><i class="ph ph-check-circle"></i><span>Giao diện học tối giản, tập trung vào từ vựng.</span></div>
                    <div class="home-check" data-aos="fade-left" data-aos-delay="300"><i class="ph ph-check-circle"></i><span>Có thể học từ bộ thẻ cộng đồng.</span></div>
                </div>
            </div>
        </div>
    </section>

    <section id="onboarding">
        <div class="container">
            <div class="text-center mb-4">
                <div class="home-kicker">Onboarding</div>
                <h2 class="home-section-title mist-reveal">Bắt đầu trong 3 bước.</h2>
            </div>
            <div class="home-bento-panel" data-aos="fade-up">
                <div class="home-bento-grid-3">
                    <div class="home-bento-card onboarding-card" data-aos="flip-left" data-aos-delay="0">
                        <div class="onboarding-number">01</div>
                        <h3 class="h5">Đăng ký</h3>
                        <p class="home-section-copy mb-0">Tạo tài khoản để lưu bộ thẻ và tiến độ.</p>
                    </div>
                    <div class="home-bento-card onboarding-card" data-aos="flip-left" data-aos-delay="150">
                        <div class="onboarding-number">02</div>
                        <h3 class="h5">Tạo hoặc chọn bộ thẻ</h3>
                        <p class="home-section-copy mb-0">Tự nhập từ hoặc học từ bộ thẻ công khai.</p>
                    </div>
                    <div class="home-bento-card onboarding-card" data-aos="flip-left" data-aos-delay="300">
                        <div class="onboarding-number">03</div>
                        <h3 class="h5">Ôn mỗi ngày</h3>
                        <p class="home-section-copy mb-0">Dùng flashcard, voice và trạng thái học để ôn đúng trọng tâm.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section-tight" id="testimonials">
        <div class="container">
            <div class="text-center mb-4">
                <div class="home-kicker">Testimonials</div>
                <h2 class="home-section-title mist-reveal">Cảm nhận từ học viên.</h2>
            </div>
            <div class="home-bento-panel" data-aos="fade-up">
                <div class="home-bento-grid-3">
                    <div class="home-bento-card testimonial-card" data-aos="fade-up" data-aos-delay="0">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Flashcard rõ, dễ ôn lại từ chưa thuộc."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/neymar.png" alt="Neymar" class="testimonial-avatar">
                            <div>
                                <strong class="d-block" style="color: var(--home-ink);">Neymar</strong>
                                <small class="text-muted">Sinh viên</small>
                            </div>
                        </div>
                    </div>
                    <div class="home-bento-card testimonial-card" data-aos="fade-up" data-aos-delay="100">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Tôi thích phần đánh sao và nghe phát âm."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/messi.png" alt="Messi" class="testimonial-avatar">
                            <div>
                                <strong class="d-block" style="color: var(--home-ink);">Messi</strong>
                                <small class="text-muted">Người tự học</small>
                            </div>
                        </div>
                    </div>
                    <div class="home-bento-card testimonial-card" data-aos="fade-up" data-aos-delay="200">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Tạo bộ thẻ cho lớp rất nhanh."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/ronaldo.png" alt="Ronaldo" class="testimonial-avatar">
                            <div>
                                <strong class="d-block" style="color: var(--home-ink);">Ronaldo</strong>
                                <small class="text-muted">Gia sư</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section-tight" id="resources">
        <div class="container">
            <div class="text-center mb-4">
                <div class="home-kicker">Resources</div>
                <h2 class="home-section-title mist-reveal">Cẩm nang & Kinh nghiệm học.</h2>
            </div>
            <div class="home-bento-panel" data-aos="fade-up">
                <div class="home-bento-grid-3">
                    <div class="home-bento-card" data-aos="fade-up" data-aos-delay="0">
