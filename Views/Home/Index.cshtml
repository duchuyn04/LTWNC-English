@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var primaryCta = User.Identity?.IsAuthenticated == true ? "/Set/Create" : "/Account/Register";
    var secondaryCta = User.Identity?.IsAuthenticated == true ? "/Set" : "#featured-sets";
}

@section Styles {
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@section FullWidth {
<div class="home-landing">

    <section class="home-hero hero-container-wrapper">
        <div class="container" style="position: relative; z-index: 2;">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 gsap-from-left">
                    <div class="home-kicker">Học qua flashcard</div>
                    <h1>
                        <span class="hero-heading-line">Học từ vựng tiếng Anh</span>
                        <span class="word-rotator" aria-hidden="true">
                            <span class="word-rotator-track" id="wordTrack">
                                <span class="word-rotator-item">theo cách của bạn.</span>
                                <span class="word-rotator-item">có hệ thống hơn.</span>
                                <span class="word-rotator-item">mỗi ngày.</span>
                                <span class="word-rotator-item">chủ động hơn.</span>
                                <span class="word-rotator-item">theo cách của bạn.</span>
                            </span>
                        </span>
                        <span class="visually-hidden">theo cách của bạn.</span>
                    </h1>
                    <p class="home-section-copy mt-3">
                        Tạo bộ thẻ, luyện phát âm, đánh dấu từ quan trọng
                        và theo dõi tiến độ học trong một giao diện gọn.
                    </p>
                    <div class="home-btn-row home-btn-row--hero mt-4">
                        <a class="btn-primary-custom btn-lg" href="@primaryCta">
                            <i class="ph ph-rocket-launch"></i> Tạo bộ thẻ
                        </a>
                        <a class="btn-secondary-custom btn-lg" href="@secondaryCta">
                            <i class="ph ph-compass"></i> Khám phá
                        </a>
                    </div>

                </div>
                <div class="col-lg-6 gsap-from-right">
                    <div class="hero-carousel-wrapper gsap-scale-in">
                        <!-- Left Navigation Button -->
                        <button class="carousel-nav-btn nav-btn-left" onclick="rotateCarousel('left')" aria-label="Thẻ trước">
                            <i class="ph ph-caret-left"></i>
                        </button>

                        <div class="hero-carousel-container" id="heroCarousel">
                            <!-- Card 1: consistency (Center position at index 0) -->
                            <div class="hero-carousel-item pos-center" data-index="0">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front">
                                            <div>
                                                <span class="fc-pos">Noun</span>
                                                <div class="fc-word">consistency</div>
                                                <p class="fc-ipa">/kənˈsɪstənsi/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back">
                                            <div>
                                                <div class="fc-meaning">sự nhất quán</div>
                                                <p class="fc-desc">Sự kiên định, không thay đổi.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 2: fluency (Right position at index 1) -->
                            <div class="hero-carousel-item pos-right" data-index="1">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front">
                                            <div>
                                                <span class="fc-pos">Noun</span>
                                                <div class="fc-word">fluency</div>
                                                <p class="fc-ipa">/ˈfluːənsi/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back">
                                            <div>
                                                <div class="fc-meaning">sự trôi chảy</div>
                                                <p class="fc-desc">Nói hoặc viết trơn tru, dễ dàng.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 3: vocabulary (Back position at index 2) -->
                            <div class="hero-carousel-item pos-back" data-index="2">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front">
                                            <div>
                                                <span class="fc-pos">Noun</span>
                                                <div class="fc-word">vocabulary</div>
                                                <p class="fc-ipa">/vəˈkæbjələri/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back">
                                            <div>
                                                <div class="fc-meaning">vốn từ vựng</div>
                                                <p class="fc-desc">Tập hợp các từ trong một ngôn ngữ.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Card 4: persistence (Left position at index 3) -->
                            <div class="hero-carousel-item pos-left" data-index="3">
                                <div class="flashcard-3d-wrapper w-100 h-100">
                                    <div class="flashcard-3d-card" onclick="handleCardClick(this)">
                                        <div class="flashcard-face flashcard-front">
                                            <div>
                                                <span class="fc-pos">Noun</span>
                                                <div class="fc-word">persistence</div>
                                                <p class="fc-ipa">/pəˈsɪstəns/</p>
                                            </div>
                                        </div>
                                        <div class="flashcard-face flashcard-back">
                                            <div>
                                                <div class="fc-meaning">sự kiên trì</div>
                                                <p class="fc-desc">Bền bỉ theo đuổi mục tiêu.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Navigation Button -->
                        <button class="carousel-nav-btn nav-btn-right" onclick="rotateCarousel('right')" aria-label="Thẻ tiếp theo">
                            <i class="ph ph-caret-right"></i>
                        </button>
                    </div>
                </div>
            </div>
            <!-- Stats wrapper: after carousel on mobile/tablet, left-aligned on desktop -->
            <div class="home-stats-wrapper gsap-fade-up">
                <div class="home-stats">
                    <div class="home-stat"><strong><span class="stat-count" data-target="3">0</span> phút</strong><span class="stat-label-long">Tạo bộ thẻ đầu tiên</span><span class="stat-label-short">Tạo bộ thẻ</span></div>
                    <div class="home-stat"><strong><span class="stat-count" data-target="5">0</span> chế độ</strong><span class="stat-label-long">Học và ôn tập</span><span class="stat-label-short">Học &amp; ôn tập</span></div>
                    <div class="home-stat"><strong><span class="stat-count" data-target="100">0</span>%</strong><span class="stat-label-long">Theo dõi tiến độ</span><span class="stat-label-short">Theo dõi</span></div>
                </div>
            </div>
        </div>
    </section>

    <section id="benefits" class="home-section home-section-capabilities">
        <div class="container">
            <div class="home-section-heading home-section-heading--split">
                <div>
                    <span class="home-kicker">Một hệ thống học rõ ràng</span>
                    <h2 class="home-section-title mist-reveal">Tập trung vào cách bạn ghi nhớ.</h2>
                </div>
                <p class="home-section-copy">Mọi công cụ cần thiết để học một từ mới đều nằm trong cùng một nhịp.</p>
            </div>

            <div class="home-capabilities gsap-fade-up">
                <article class="home-capability-lead">
                    <div class="home-capability-lead-icon"><i class="ph ph-cards"></i></div>
                    <div class="home-capability-lead-content">
                        <span class="home-capability-label">Nền tảng chính</span>
                        <h3>Flashcard rõ ràng</h3>
                        <p>Mỗi từ có nghĩa, IPA, ví dụ và trạng thái học để bạn biết mình đang ở đâu.</p>
                        <div class="home-capability-meta" aria-label="Các thành phần của flashcard">
                            <span><i class="ph ph-text-aa"></i> Nghĩa và IPA</span>
                            <span><i class="ph ph-speaker-high"></i> Phát âm</span>
                            <span><i class="ph ph-chart-line-up"></i> Tiến độ</span>
                        </div>
                    </div>
                </article>
                <div class="home-capability-rail gsap-stagger">
                    <article class="home-capability-row">
                        <span class="home-icon"><i class="ph ph-speaker-high"></i></span>
                        <div><h3>Giọng đọc</h3><p>Nghe phát âm tiếng Anh ngay khi học thẻ.</p></div>
                    </article>
                    <article class="home-capability-row">
                        <span class="home-icon"><i class="ph ph-star"></i></span>
                        <div><h3>Đánh dấu sao</h3><p>Giữ lại những từ cần được ôn trước.</p></div>
                    </article>
                    <article class="home-capability-row">
                        <span class="home-icon"><i class="ph ph-funnel"></i></span>
                        <div><h3>Lọc để ôn</h3><p>Chọn đúng nhóm từ cần tập trung hôm nay.</p></div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="home-section home-section-workflow">
        <span id="onboarding" class="homepage-anchor" aria-hidden="true"></span>
        <div class="container">
            <div class="home-section-heading home-section-heading--compact">
                <span class="home-kicker">Từ bắt đầu đến tiến bộ</span>
                <h2 class="home-section-title mist-reveal">Một vòng học, ba nhịp đơn giản.</h2>
            </div>
            <div class="home-workflow gsap-stagger" aria-label="Quy trình học với LTWNC">
                <article class="home-workflow-step">
                    <div class="home-workflow-marker"><span>01</span><i class="ph ph-plus-circle"></i></div>
                    <div class="home-workflow-content"><span class="home-capability-label">Tạo nền tảng</span><h3>Chọn điều bạn muốn học</h3><p>Tạo bộ thẻ riêng hoặc bắt đầu từ một bộ thẻ công khai. Thêm từ, nghĩa, IPA, ví dụ và hình ảnh.</p></div>
                </article>
                <article class="home-workflow-step">
                    <div class="home-workflow-marker"><span>02</span><i class="ph ph-brain"></i></div>
                    <div class="home-workflow-content"><span class="home-capability-label">Học chủ động</span><h3>Nhìn, nghe và lật thẻ</h3><p>Học qua flashcard, nghe phát âm, trộn thứ tự và đánh dấu những từ bạn đã biết.</p></div>
                </article>
                <article class="home-workflow-step">
                    <div class="home-workflow-marker"><span>03</span><i class="ph ph-chart-line-up"></i></div>
                    <div class="home-workflow-content"><span class="home-capability-label">Ôn đúng trọng tâm</span><h3>Quay lại đúng từ cần nhớ</h3><p>Lọc từ chưa thuộc, mở nhóm đã đánh dấu và theo dõi tiến độ qua từng buổi học.</p></div>
                </article>
            </div>
        </div>
    </section>

    <section class="home-section home-section-demo">
        <div class="container">
            <div class="home-feature-block">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-6 gsap-from-left">
                        <span class="home-kicker home-kicker--inverse">Trải nghiệm trực tiếp</span>
                        <h2 class="home-section-title text-white mist-reveal">Một workspace học từ vựng gọn.</h2>
                        <p>Từ tạo bộ thẻ đến học flashcard đều nằm trong cùng một luồng.</p>
                        <a class="btn-primary-custom demo-cta" href="@primaryCta"><i class="ph ph-rocket-launch"></i> Tạo bộ thẻ đầu tiên</a>
                    </div>
                    <div class="col-lg-6 gsap-from-right">
                        <button type="button" class="flashcard-3d-card demo-flashcard" data-demo-card aria-pressed="false" aria-label="Lật thẻ debugging để xem nghĩa">
                            <span class="flashcard-face flashcard-face--paper"><span><span class="fc-pos">Vocabulary</span><span class="fc-word">debugging</span><span class="fc-ipa">/ˌdiːˈbʌɡɪŋ/<br>Chọn hoặc nhấn Enter để lật thẻ</span></span></span>
                            <span class="flashcard-face flashcard-back flashcard-face--sage"><span><span class="fc-meaning">gỡ lỗi</span><span class="fc-desc">Debugging helped identify the cause of the system crash.</span></span></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section-proof">
        <div class="container">
            <div class="home-proof-band gsap-fade-up">
                <div class="home-proof-heading"><span class="home-kicker">Bớt bước thừa</span><h2 class="home-section-title mist-reveal">Dành thời gian cho việc học.</h2></div>
                <div class="home-checklist gsap-stagger">
                    <div class="home-check"><i class="ph ph-check-circle"></i><span>Không cần chuyển qua nhiều công cụ.</span></div>
                    <div class="home-check"><i class="ph ph-check-circle"></i><span>Bộ thẻ và tiến độ được lưu trong tài khoản của bạn.</span></div>
                    <div class="home-check"><i class="ph ph-check-circle"></i><span>Màn hình tập trung vào từng từ vựng.</span></div>
                    <div class="home-check"><i class="ph ph-check-circle"></i><span>Bạn cũng có thể bắt đầu với một bộ thẻ công khai.</span></div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section-tight" id="testimonials">
        <div class="container">
            <div class="text-center mb-4">
                <div class="home-kicker">Cảm nhận học viên</div>
                <h2 class="home-section-title mist-reveal">Cảm nhận từ học viên.</h2>
            </div>
            <div class="home-bento-panel gsap-fade-up">
                <div class="home-bento-grid-3 gsap-stagger">
                    <div class="home-bento-card testimonial-card">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Flashcard rõ, dễ ôn lại từ chưa thuộc."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/neymar.png" alt="Neymar" class="testimonial-avatar">
                            <div>
                                <strong class="d-block">Neymar</strong>
                                <small class="text-muted">Sinh viên</small>
                            </div>
                        </div>
                    </div>
                    <div class="home-bento-card testimonial-card">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Tôi thích phần đánh sao và nghe phát âm."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/messi.png" alt="Messi" class="testimonial-avatar">
                            <div>
                                <strong class="d-block">Messi</strong>
                                <small class="text-muted">Người tự học</small>
                            </div>
                        </div>
                    </div>
                    <div class="home-bento-card testimonial-card">
                        <div>
                            <div class="testimonial-stars mb-3">
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                                <i class="ph ph-star-fill"></i>
                            </div>
                            <p class="home-section-copy mb-4" style="font-style: italic;">"Tạo bộ thẻ cho lớp rất nhanh."</p>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <img src="/images/ronaldo.png" alt="Ronaldo" class="testimonial-avatar">
                            <div>
                                <strong class="d-block">Ronaldo</strong>
                                <small class="text-muted">Gia sư</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section-sets" id="featured-sets">
        <div class="container">
            <div class="home-section-heading home-section-heading--sets">
                <div>
                    <span class="home-kicker">Cộng đồng</span>
                    <h2 class="home-section-title mist-reveal">Tìm một bộ thẻ để bắt đầu.</h2>
                </div>
                <form class="home-set-search" method="get" action="/">
                    <label for="public-set-search">Tìm theo tên bộ thẻ</label>
                    <div class="home-set-search-controls">
                        <input id="public-set-search" name="q" value="@Model.SearchQuery" class="form-input-custom" type="search" placeholder="Ví dụ: giao tiếp" />
                        <button class="btn-secondary-custom" type="submit"><i class="ph ph-magnifying-glass"></i><span>Tìm</span></button>
                        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                        {
                            <a class="home-set-search-clear" href="/">Xóa</a>
                        }
                    </div>
                </form>
            </div>

            @if (!Model.PublicSets.Any())
            {
                <div class="home-set-empty gsap-fade-up">
                    <i class="ph ph-books"></i>
                    <div>
                        <h3>Chưa có bộ thẻ phù hợp.</h3>
                        <p>Thử một từ khóa khác hoặc tạo bộ thẻ đầu tiên của riêng bạn.</p>
                    </div>
                    <a class="btn-primary-custom" href="@primaryCta">Tạo bộ thẻ</a>
                </div>
            }
            else
            {
                var featuredSet = Model.PublicSets.First();
                <div class="home-set-discovery gsap-fade-up">
                    <article class="home-set-featured">
                        <div class="home-set-featured-icon"><i class="ph ph-books"></i></div>
                        <div class="home-set-content">
                            <span class="home-capability-label">Bộ thẻ nổi bật</span>
                            <h3>@featuredSet.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(featuredSet.Description))
                            {
                                <p>@featuredSet.Description</p>
                            }
                            <a class="btn-primary-custom" href="/Set/@featuredSet.Id"><i class="ph ph-arrow-up-right"></i> Xem bộ thẻ</a>
                        </div>
                    </article>
                    @if (Model.PublicSets.Count > 1)
                    {
                        <div class="home-set-list" aria-label="Các bộ thẻ khác">
                            @foreach (var set in Model.PublicSets.Skip(1).Take(5))
                            {
                                <article class="home-set-row">
                                    <div>
                                        <h3>@set.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(set.Description))
                                        {
                                            <p>@set.Description</p>
                                        }
                                    </div>
                                    <a href="/Set/@set.Id" aria-label="Xem bộ thẻ @set.Title"><i class="ph ph-arrow-up-right"></i></a>
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <section class="home-section home-section-resources" id="resources">
        <div class="container">
            <div class="home-section-heading home-section-heading--compact">
                <span class="home-kicker">Gợi ý học tập</span>
                <h2 class="home-section-title mist-reveal">Ba cách để nhớ sâu hơn.</h2>
            </div>
            <div class="home-resource-index gsap-stagger">
                <article class="home-resource-feature">
                    <span class="home-resource-number">01</span>
                    <span class="home-icon"><i class="ph ph-notebook"></i></span>
                    <h3>Nhớ từ theo ngữ cảnh</h3>
                    <p class="home-section-copy">Viết một ví dụ riêng cho mỗi từ. Khi từ gắn với một tình huống quen thuộc, bạn sẽ dễ gọi lại hơn.</p>
                </article>
                <div class="home-resource-secondary">
                    <article class="home-resource-compact">
                        <span class="home-resource-number">02</span>
                        <div><h3>Khi nào nên đánh dấu sao?</h3><p class="home-section-copy">Dùng sao cho từ khó, từ hay sai và từ cần ôn trước.</p></div>
                    </article>
                    <article class="home-resource-compact">
                        <span class="home-resource-number">03</span>
                        <div><h3>Nghe phát âm khi lật thẻ</h3><p class="home-section-copy">Kết hợp nhìn, nghe và ví dụ để học sâu hơn.</p></div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section-closing" id="quote">
        <div class="container">
            <div class="home-quote-form home-closing-panel gsap-fade-up">
                <div class="home-closing-copy">
                    <span class="home-kicker">Bắt đầu từ một từ</span>
                    <h2 class="home-section-title mist-reveal">Một nhịp học nhỏ, tiến bộ rõ ràng.</h2>
                    <p class="home-section-copy">Tạo không gian học phù hợp với cách bạn ghi nhớ, rồi quay lại mỗi ngày.</p>
                    <div class="home-closing-actions">
                        <a class="btn-primary-custom" href="@primaryCta"><i class="ph ph-rocket-launch"></i> Đăng ký và tạo bộ thẻ</a>
                        <a class="btn-secondary-custom" href="/Account/Login">Đăng nhập</a>
                    </div>
                </div>
                <div class="home-philosophy-grid home-closing-principles gsap-stagger" aria-label="Nguyên tắc của LTWNC">
                    <div class="home-philosophy-item"><h3>Nhịp học ngắn</h3><p class="home-section-copy">Dễ bắt đầu và dễ lặp lại mỗi ngày.</p></div>
                    <div class="home-philosophy-item"><h3>Tập trung vào từ</h3><p class="home-section-copy">Ít bước thừa, nhiều thời gian ghi nhớ hơn.</p></div>
                    <div class="home-philosophy-item"><h3>Tiến độ rõ ràng</h3><p class="home-section-copy">Biết mình đã học gì và cần ôn gì tiếp theo.</p></div>
                </div>
            </div>
        </div>
    </section>
</div>
}

@section Scripts {
<script>
    // Rotating headline phrase (masked vertical slide, seamless loop)
    (function initWordRotator() {
        const track = document.getElementById('wordTrack');
        if (!track) return;
        const items = track.children;
        if (items.length < 2) return;
        let index = 0;
        setInterval(() => {
            index++;
            track.style.transform = `translateY(${-index * items[0].offsetHeight}px)`;
            if (index === items.length - 1) {
                // Reached the duplicated first item: snap back seamlessly
                setTimeout(() => {
                    track.style.transition = 'none';
                    track.style.transform = 'translateY(0)';
                    requestAnimationFrame(() => requestAnimationFrame(() => {
                        track.style.transition = '';
                    }));
                    index = 0;
                }, 600);
            }
        }, 2600);
    })();

    // Carousel State Tracking
    let currentCenterIndex = 0; // consistency (index 0) starts in the middle
    const totalItems = 4;
    const positions = ['pos-center', 'pos-right', 'pos-back', 'pos-left'];
    let autoplayInterval;

    window.startAutoplay = function() {
        window.stopAutoplay();
        autoplayInterval = setInterval(() => {
            window.rotateCarousel('right');
        }, 2500);
    }

    window.stopAutoplay = function() {
        if (autoplayInterval) {
            clearInterval(autoplayInterval);
            autoplayInterval = null;
        }
    }

    window.rotateCarousel = function(direction) {
        const container = document.getElementById('heroCarousel');
        if (!container) return;
        const items = container.querySelectorAll('.hero-carousel-item');

        // Clear flipped state from all cards before rotating to maintain front side
        items.forEach(el => {
            const card = el.querySelector('.flashcard-3d-card');
            if (card) card.classList.remove('flipped');
        });

        if (direction === 'left') {
            currentCenterIndex = (currentCenterIndex - 1 + totalItems) % totalItems;
        } else {
            currentCenterIndex = (currentCenterIndex + 1) % totalItems;
        }

        items.forEach((item, index) => {
            item.className = 'hero-carousel-item'; // Reset class list

            // Calculate relative state class index
            const relativePos = (index - currentCenterIndex + totalItems) % totalItems;
            item.classList.add(positions[relativePos]);
        });

        // Reset timer if autoplay is active
        if (autoplayInterval) {
            window.startAutoplay();
        }
    }

    window.handleCardClick = function(cardElement) {
        const itemContainer = cardElement.closest('.hero-carousel-item');
        if (!itemContainer) return;

        if (itemContainer.classList.contains('pos-center')) {
            // Flip card only when it resides in the center focus position
            cardElement.classList.toggle('flipped');
        } else if (itemContainer.classList.contains('pos-left')) {
            window.rotateCarousel('left');
        } else if (itemContainer.classList.contains('pos-right')) {
            window.rotateCarousel('right');
        }
    }

    document.querySelectorAll('.home-landing a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const target = document.querySelector(this.getAttribute('href'));
            if (!target) return;
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    // The demo card is a real button, so click, Enter and Space all expose
    // the same flip state to mouse, keyboard and touch users.
    const demoCard = document.querySelector('[data-demo-card]');
    if (demoCard) {
        demoCard.addEventListener('click', function () {
            const flipped = demoCard.classList.toggle('flipped');
            demoCard.setAttribute('aria-pressed', String(flipped));
        });
        demoCard.addEventListener('keydown', function (event) {
            if (event.key === ' ') {
                event.preventDefault();
                demoCard.click();
            }
        });
    }

    // Count animation logic
    function animateCount(element) {
        const target = parseInt(element.getAttribute('data-target'), 10);
        const duration = 1500; // 1.5 seconds
        const startTime = performance.now();

        function update(currentTime) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);

            // Easing out quadratic
            const easeProgress = progress * (2 - progress);

            const currentValue = Math.floor(easeProgress * target);
            element.textContent = currentValue;

            if (progress < 1) {
                requestAnimationFrame(update);
            } else {
                element.textContent = target;
            }
        }
        requestAnimationFrame(update);
    }

    // Intersection Observer for Misty de-blur scroll reveal and Stat Counters
    document.addEventListener("DOMContentLoaded", function() {
        const mistElements = document.querySelectorAll('.mist-reveal');
        const countElements = document.querySelectorAll('.stat-count');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('mist-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px"
        });

        mistElements.forEach(el => observer.observe(el));

        const countObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    animateCount(entry.target);
                    countObserver.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.5
        });

        countElements.forEach(el => countObserver.observe(el));

        // Initialize Carousel Autoplay and hover controls
        const carousel = document.querySelector('.hero-carousel-wrapper');
        if (carousel) {
            window.startAutoplay();
            carousel.addEventListener('mouseenter', window.stopAutoplay);
            carousel.addEventListener('mouseleave', window.startAutoplay);
        }
    });
</script>
}
