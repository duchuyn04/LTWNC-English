@model HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var primaryCta = User.Identity?.IsAuthenticated == true ? "/Set/Create" : "/Account/Register";
}

@section Styles {
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@section FullWidth {
<div class="home-landing">
    <section class="home-hero" aria-labelledby="home-hero-title">
        <div class="container">
            <div class="home-hero-grid">
                <div class="home-hero-copy">
                    <span class="home-eyebrow">Flashcard · Nghe chép · Hội thoại AI</span>
                    <h1 id="home-hero-title">
                        Học từ mới.
                        <span>Dùng được thật.</span>
                    </h1>
                    <p class="home-hero-summary">
                        Tạo bộ từ, luyện theo nhiều chế độ và theo dõi tiến độ sau từng buổi học.
                    </p>
                    <div class="home-actions home-hero-actions">
                        <a class="btn-primary-custom" href="@primaryCta">
                            <i class="ph ph-plus-circle" aria-hidden="true"></i>
                            Bắt đầu học
                        </a>
                        <a class="btn-secondary-custom" href="/Library">
                            Khám phá bộ từ
                            <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
                        </a>
                    </div>
                    <ul class="home-hero-facts" aria-label="Chế độ học chính">
                        <li><i class="ph ph-cards" aria-hidden="true"></i> Flashcard</li>
                        <li><i class="ph ph-headphones" aria-hidden="true"></i> Nghe chép</li>
                        <li><i class="ph ph-chats-circle" aria-hidden="true"></i> English Mission</li>
                    </ul>
                </div>

                <div class="home-carousel-column">
                    <div class="home-carousel" data-home-carousel data-autoplay-ms="4500" aria-label="Flashcard mẫu">
                        <div class="home-carousel-stage" id="heroCarousel">
                            <article class="home-carousel-item pos-center" data-carousel-item data-index="0" aria-hidden="false">
                                <button class="flashcard-3d-card" type="button" data-carousel-card aria-label="Lật thẻ consistency" aria-pressed="false" tabindex="0">
                                    <span class="flashcard-face flashcard-front">
                                        <span class="flashcard-copy">
                                            <span class="fc-pos">Noun</span>
                                            <span class="fc-word">consistency</span>
                                            <span class="fc-ipa">/kənˈsɪstənsi/</span>
                                            <span class="fc-action"><i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Lật thẻ</span>
                                        </span>
                                    </span>
                                    <span class="flashcard-face flashcard-back">
                                        <span class="flashcard-copy">
                                            <span class="fc-meaning">sự nhất quán</span>
                                            <span class="fc-desc">Sự kiên định, không thay đổi.</span>
                                            <span class="fc-action"><i class="ph ph-arrow-bend-up-left" aria-hidden="true"></i> Xem mặt trước</span>
                                        </span>
                                    </span>
                                </button>
                            </article>

                            <article class="home-carousel-item pos-right" data-carousel-item data-index="1" aria-hidden="true">
                                <button class="flashcard-3d-card" type="button" data-carousel-card aria-label="Lật thẻ fluency" aria-pressed="false" tabindex="-1">
                                    <span class="flashcard-face flashcard-front">
                                        <span class="flashcard-copy">
                                            <span class="fc-pos">Noun</span>
                                            <span class="fc-word">fluency</span>
                                            <span class="fc-ipa">/ˈfluːənsi/</span>
                                            <span class="fc-action"><i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Lật thẻ</span>
                                        </span>
                                    </span>
                                    <span class="flashcard-face flashcard-back">
                                        <span class="flashcard-copy">
                                            <span class="fc-meaning">sự trôi chảy</span>
                                            <span class="fc-desc">Nói hoặc viết trơn tru, dễ dàng.</span>
                                            <span class="fc-action"><i class="ph ph-arrow-bend-up-left" aria-hidden="true"></i> Xem mặt trước</span>
                                        </span>
                                    </span>
                                </button>
                            </article>

                            <article class="home-carousel-item pos-back" data-carousel-item data-index="2" aria-hidden="true">
                                <button class="flashcard-3d-card" type="button" data-carousel-card aria-label="Lật thẻ vocabulary" aria-pressed="false" tabindex="-1">
                                    <span class="flashcard-face flashcard-front">
                                        <span class="flashcard-copy">
                                            <span class="fc-pos">Noun</span>
                                            <span class="fc-word">vocabulary</span>
                                            <span class="fc-ipa">/vəˈkæbjələri/</span>
                                            <span class="fc-action"><i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Lật thẻ</span>
                                        </span>
                                    </span>
                                    <span class="flashcard-face flashcard-back">
                                        <span class="flashcard-copy">
                                            <span class="fc-meaning">vốn từ vựng</span>
                                            <span class="fc-desc">Tập hợp các từ trong một ngôn ngữ.</span>
                                            <span class="fc-action"><i class="ph ph-arrow-bend-up-left" aria-hidden="true"></i> Xem mặt trước</span>
                                        </span>
                                    </span>
                                </button>
                            </article>

                            <article class="home-carousel-item pos-left" data-carousel-item data-index="3" aria-hidden="true">
                                <button class="flashcard-3d-card" type="button" data-carousel-card aria-label="Lật thẻ persistence" aria-pressed="false" tabindex="-1">
                                    <span class="flashcard-face flashcard-front">
                                        <span class="flashcard-copy">
                                            <span class="fc-pos">Noun</span>
                                            <span class="fc-word">persistence</span>
                                            <span class="fc-ipa">/pəˈsɪstəns/</span>
                                            <span class="fc-action"><i class="ph ph-arrows-clockwise" aria-hidden="true"></i> Lật thẻ</span>
                                        </span>
                                    </span>
                                    <span class="flashcard-face flashcard-back">
                                        <span class="flashcard-copy">
                                            <span class="fc-meaning">sự kiên trì</span>
                                            <span class="fc-desc">Bền bỉ theo đuổi mục tiêu.</span>
                                            <span class="fc-action"><i class="ph ph-arrow-bend-up-left" aria-hidden="true"></i> Xem mặt trước</span>
                                        </span>
                                    </span>
                                </button>
                            </article>
                        </div>

                        <div class="home-carousel-controls" aria-label="Điều khiển flashcard mẫu">
                            <button type="button" class="home-carousel-control" data-carousel-previous aria-controls="heroCarousel" aria-label="Thẻ trước">
                                <i class="ph ph-arrow-left" aria-hidden="true"></i>
                            </button>
                            <span class="home-carousel-status" data-carousel-status aria-live="off">1 / 4</span>
                            <button type="button" class="home-carousel-toggle" data-carousel-toggle aria-controls="heroCarousel" aria-label="Tạm dừng chuyển thẻ" aria-pressed="false">
                                <i class="ph ph-pause" data-carousel-toggle-icon aria-hidden="true"></i>
                                <span data-carousel-toggle-label>Tạm dừng</span>
                            </button>
                            <button type="button" class="home-carousel-control" data-carousel-next aria-controls="heroCarousel" aria-label="Thẻ tiếp theo">
                                <i class="ph ph-arrow-right" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span class="visually-hidden" data-carousel-announcement aria-live="polite"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-feature" id="benefits" aria-labelledby="home-feature-title">
        <div class="container">
            <header class="home-editorial-header" data-home-reveal>
                <span class="home-section-number" aria-hidden="true">01</span>
                <h2 id="home-feature-title">Một thẻ, đủ để hiểu từ.</h2>
                <p>Nghĩa, cách đọc và trạng thái học nằm cùng một chỗ.</p>
            </header>

            <div class="home-feature-grid" data-home-reveal>
                <article class="home-word-specimen" aria-label="Ví dụ nội dung một flashcard">
                    <span class="home-specimen-label">Trong một thẻ</span>
                    <div class="home-specimen-word">context</div>
                    <div class="home-specimen-ipa">/ˈkɒntekst/</div>
                    <p class="home-specimen-meaning">ngữ cảnh</p>
                    <p class="home-specimen-example">“Học một từ trong câu giúp bạn nhớ cách dùng của nó.”</p>
                    <div class="home-specimen-meta">
                        <span><i class="ph ph-speaker-high" aria-hidden="true"></i> Nghe từ</span>
                        <span><i class="ph ph-star" aria-hidden="true"></i> Đánh dấu</span>
                    </div>
                </article>

                <div class="home-feature-list">
                    <article class="home-feature-row">
                        <span class="home-feature-index">01</span>
                        <i class="ph ph-text-aa" aria-hidden="true"></i>
                        <div><h3>Nghĩa và IPA</h3><p>Nhìn cách đọc và nghĩa ở cùng một chỗ.</p></div>
                    </article>
                    <article class="home-feature-row">
                        <span class="home-feature-index">02</span>
                        <i class="ph ph-speaker-high" aria-hidden="true"></i>
                        <div><h3>Nghe và đánh dấu</h3><p>Nghe phát âm, giữ lại từ cần ôn.</p></div>
                    </article>
                    <article class="home-feature-row">
                        <span class="home-feature-index">03</span>
                        <i class="ph ph-chart-line-up" aria-hidden="true"></i>
                        <div><h3>Biết mình đã thuộc</h3><p>Trạng thái học cho biết từ nào cần quay lại.</p></div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-modes" id="services" aria-labelledby="home-modes-title">
        <div class="container">
            <header class="home-editorial-header" data-home-reveal>
                <span class="home-section-number" aria-hidden="true">02</span>
                <h2 id="home-modes-title">Không chỉ có flashcard.</h2>
                <p>Chọn cách luyện phù hợp với mục tiêu của từng buổi học.</p>
            </header>

            <div class="home-mode-grid">
                <article class="home-mode-card home-mode-card--primary" data-home-reveal>
                    <span class="home-mode-index">01</span>
                    <i class="ph ph-cards" aria-hidden="true"></i>
                    <div>
                        <h3>Flashcard</h3>
                        <p>Lật thẻ, nghe phát âm và đánh dấu những từ cần ôn lại.</p>
                    </div>
                </article>
                <article class="home-mode-card" data-home-reveal>
                    <span class="home-mode-index">02</span>
                    <i class="ph ph-headphones" aria-hidden="true"></i>
                    <div>
                        <h3>Nghe chép</h3>
                        <p>Nghe từ hoặc câu ví dụ, gõ lại và xem lỗi ngay sau mỗi lượt.</p>
                    </div>
                </article>
                <article class="home-mode-card" data-home-reveal>
                    <span class="home-mode-index">03</span>
                    <i class="ph ph-chats-circle" aria-hidden="true"></i>
                    <div>
                        <h3>English Mission</h3>
                        <p>Dùng từ vừa học trong hội thoại tình huống với gia sư AI.</p>
                    </div>
                </article>
                <article class="home-mode-card home-mode-card--progress" data-home-reveal>
                    <span class="home-mode-index">04</span>
                    <i class="ph ph-trophy" aria-hidden="true"></i>
                    <div>
                        <h3>Tiến độ và thành tích</h3>
                        <p>Xem mức độ ghi nhớ, huy hiệu và bảng xếp hạng sau các buổi học.</p>
                    </div>
                    <a href="/Leaderboard">Xem bảng xếp hạng <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
                </article>
            </div>
        </div>
    </section>

    <section class="home-section home-sets" id="featured-sets" aria-labelledby="home-sets-title">
        <div class="container">
            <header class="home-editorial-header home-sets-header" data-home-reveal>
                <span class="home-section-number" aria-hidden="true">03</span>
                <div>
                    <span class="home-eyebrow">Bộ thẻ cộng đồng</span>
                    <h2 id="home-sets-title">Chọn một bộ thẻ và học ngay.</h2>
                </div>
                <form class="home-set-search" method="get" action="/">
                    <label for="public-set-search">Tìm bộ thẻ</label>
                    <div class="home-set-search-controls">
                        <input id="public-set-search" name="q" value="@Model.SearchQuery" class="form-input-custom" type="search" placeholder="Tên bộ thẻ" />
                        <button class="btn-secondary-custom" type="submit">
                            <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
                            <span>Tìm</span>
                        </button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                    {
                        <a class="home-set-search-clear" href="/">Xóa bộ lọc</a>
                    }
                </form>
            </header>

            @if (!Model.PublicSets.Any())
            {
                <div class="home-set-empty">
                    <i class="ph ph-books" aria-hidden="true"></i>
                    <div>
                        <h3>Chưa tìm thấy bộ thẻ.</h3>
                        <p>Thử tên khác hoặc tạo bộ thẻ riêng.</p>
                    </div>
                    <a class="btn-primary-custom" href="@primaryCta">Tạo bộ thẻ</a>
                </div>
            }
            else
            {
                var featuredSet = Model.PublicSets.First();
                <div class="home-set-discovery @(Model.PublicSets.Count > 1 ? "" : "home-set-discovery--single")" data-home-reveal>
                    <article class="home-set-featured">
                        <span class="home-set-featured-label">Bộ thẻ nổi bật</span>
                        <div class="home-set-featured-copy">
                            <i class="ph ph-books" aria-hidden="true"></i>
                            <h3>@featuredSet.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(featuredSet.Description))
                            {
                                <p>@featuredSet.Description</p>
                            }
                        </div>
                        <a class="home-set-featured-action" href="/Set/@featuredSet.Id">
                            Mở bộ thẻ
                            <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
                        </a>
                    </article>

                    @if (Model.PublicSets.Count > 1)
                    {
                        <div class="home-set-list" aria-label="Các bộ thẻ khác">
                            @foreach (var set in Model.PublicSets.Skip(1).Take(5))
                            {
                                <article class="home-set-row">
                                    <div>
                                        <h3>@set.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(set.Description))
                                        {
                                            <p>@set.Description</p>
                                        }
                                    </div>
                                    <a class="home-set-open" href="/Set/@set.Id" aria-label="Mở bộ thẻ @set.Title">
                                        Mở
                                        <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
                                    </a>
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <section class="home-section home-testimonials" id="testimonials" aria-labelledby="home-testimonials-title">
        <div class="container">
            <header class="home-editorial-header" data-home-reveal>
                <span class="home-section-number" aria-hidden="true">04</span>
                <h2 id="home-testimonials-title">Người học nói gì.</h2>
                <p>Những điều họ thấy hữu ích khi học theo nhiều chế độ.</p>
            </header>

            <div class="home-testimonial-grid">
                <figure class="home-testimonial" data-home-reveal>
                    <blockquote>“Chế độ nghe chép giúp mình nhận ra ngay những từ nghe quen nhưng vẫn viết sai.”</blockquote>
                    <figcaption><span>MA</span><div><strong>Minh Anh</strong><small>Sinh viên</small></div></figcaption>
                </figure>
                <figure class="home-testimonial" data-home-reveal>
                    <blockquote>“English Mission buộc mình dùng từ trong câu, thay vì chỉ nhớ nghĩa trên thẻ.”</blockquote>
                    <figcaption><span>HN</span><div><strong>Hoàng Nam</strong><small>Người học giao tiếp</small></div></figcaption>
                </figure>
                <figure class="home-testimonial" data-home-reveal>
                    <blockquote>“Mình nhìn được tiến độ của từng buổi và biết chính xác nhóm từ nào cần học lại.”</blockquote>
                    <figcaption><span>TH</span><div><strong>Thu Hà</strong><small>Người tự học</small></div></figcaption>
                </figure>
            </div>
        </div>
    </section>

    <section class="home-closing" aria-labelledby="home-closing-title">
        <div class="container">
            <div class="home-closing-grid" data-home-reveal>
                <div>
                    <span class="home-eyebrow">Bắt đầu hôm nay</span>
                    <h2 id="home-closing-title">Bắt đầu buổi học đầu tiên.</h2>
                    <p>Tạo bộ từ rồi chọn flashcard, nghe chép hoặc hội thoại tình huống.</p>
                    <div class="home-actions home-closing-actions">
                        <a class="home-closing-primary" href="/Account/Register">Đăng ký</a>
                        <a class="home-closing-secondary" href="/Account/Login">Đăng nhập</a>
                    </div>
                </div>
                <div class="home-closing-mark" aria-hidden="true">
                    <span>A</span>
                    <i class="ph ph-arrow-right"></i>
                    <span>Z</span>
                </div>
            </div>
        </div>
    </section>
</div>
}

@section Scripts {
<script src="~/js/home.js" asp-append-version="true"></script>
}
