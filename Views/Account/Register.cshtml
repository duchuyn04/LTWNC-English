@model RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center gsap-fade-up">
    <div class="col-md-6 col-lg-5">
        <div class="card-custom gsap-scale-in">
            <h1 class="h3 mb-1">Đăng ký</h1>
            <p class="auth-sub">Tạo tài khoản để bắt đầu học.</p>

            <form asp-action="Register" method="post" class="mt-4">
                <div asp-validation-summary="ModelOnly" class="mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label auth-label"></label>
                    <input asp-for="Email" class="form-input-custom" placeholder="you@example.com" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label auth-label"></label>
                    <input asp-for="Username" class="form-input-custom" placeholder="Tên của bạn" />
                    <small class="form-text text-muted">3-50 ký tự; dùng chữ không dấu, số, ., _ hoặc -.</small>
                    <span asp-validation-for="Username"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label auth-label"></label>
                    <input asp-for="Password" class="form-input-custom" placeholder="Mật khẩu" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label auth-label"></label>
                    <input asp-for="ConfirmPassword" class="form-input-custom" placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <button type="submit" class="btn-primary-custom w-100">Đăng ký</button>
            </form>

            <p class="mt-3 text-center auth-alt">
                Đã có tài khoản? <a href="/Account/Login">Đăng nhập</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
