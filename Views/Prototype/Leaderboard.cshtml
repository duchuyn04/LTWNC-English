@{
    // PROTOTYPE - throwaway. Uses mock data only.
    ViewData["Title"] = "Prototype bảng xếp hạng";
    var variant = ViewData["Variant"] as string ?? "a";
    var period = ViewData["Period"] as int? ?? 7;
    var state = ViewData["State"] as string ?? "outside";
    var multiplier = period == 30 ? 3.72 : 1.0;
    var people = new[]
    {
        ("Minh Anh", "MA", 12840, 21), ("Hà My", "HM", 11320, 18), ("Quang Huy", "QH", 10470, 17),
        ("Thu Trang", "TT", 9820, 16), ("Đức Phúc", "ĐP", 9210, 15), ("Ngọc Linh", "NL", 8870, 15),
        ("Gia Bảo", "GB", 8240, 14), ("Khánh Vy", "KV", 7930, 13), ("Hoàng Nam", "HN", 7460, 12),
        ("Mai Chi", "MC", 7120, 12), ("Trọng Nghĩa", "TN", 6790, 11), ("Thanh Tâm", "TT", 6410, 11),
        ("Phương Thảo", "PT", 5980, 10), ("Tuấn Kiệt", "TK", 5640, 9), ("Bảo Ngọc", "BN", 5290, 9),
        ("Nhật Minh", "NM", 4880, 8), ("Yến Nhi", "YN", 4510, 8), ("Anh Khoa", "AK", 4170, 7),
        ("Diệu Linh", "DL", 3860, 7), ("Hải Đăng", "HĐ", 3420, 6)
    };
    string Duration(int seconds)
    {
        var adjusted = (int)Math.Round(seconds * multiplier);
        var hours = adjusted / 3600;
        var minutes = (adjusted % 3600) / 60;
        return hours > 0 ? $"{hours} giờ {minutes:00} phút" : $"{minutes} phút";
    }
    string LinkFor(string nextVariant, int? nextPeriod = null, string? nextState = null)
        => $"/Prototype/Leaderboard?variant={nextVariant}&period={nextPeriod ?? period}&state={nextState ?? state}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/prototype-leaderboard.css" asp-append-version="true" />
}

<div class="lb-prototype" data-variant="@variant">
    <div class="lb-prototype-note"><i class="ph ph-flask"></i> Prototype dùng dữ liệu giả, không phải tính năng thật</div>

    @if (state == "empty")
    {
        <section class="lb-empty" aria-labelledby="lb-empty-title">
            <i class="ph ph-hourglass-medium"></i>
            <h1 id="lb-empty-title">Chưa có thời gian học trong kỳ này.</h1>
            <p>Khi có người hoàn thành một buổi học, bảng xếp hạng sẽ xuất hiện ở đây.</p>
            <a class="btn-primary-custom" href="@LinkFor(variant, null, "outside")">Xem dữ liệu mẫu</a>
        </section>
    }
    else if (variant == "a")
    {
        <header class="lb-header">
            <div><span class="lb-eyebrow">Bảng xếp hạng học tập</span><h1>Ai dành nhiều thời gian học nhất?</h1><p>Chỉ tính thời gian hoạt động khi người học đang ở trong buổi học.</p></div>
            @PeriodNav()
        </header>
        @CurrentUserStrip()
        <section class="lb-podium" aria-label="Ba vị trí dẫn đầu">
            <article class="lb-champion">
                <div class="lb-medal lb-medal--gold"><i class="ph ph-medal" aria-hidden="true"></i><span>Hạng 1</span></div>
                <div class="lb-rank-mark">01</div><div class="lb-avatar lb-avatar--large">@people[0].Item2</div>
                <div><span class="lb-small-label">Dẫn đầu @period ngày</span><h2>@people[0].Item1</h2><strong>@Duration(people[0].Item3)</strong><small>@people[0].Item4 buổi học</small></div>
            </article>
            <div class="lb-podium-side">
                @for (var i = 1; i < 3; i++) { @RankCard(i) }
            </div>
        </section>
        <ol class="lb-list" start="4" aria-label="Các vị trí từ 4 đến 20">
            @for (var i = 3; i < people.Length; i++) { @RankRow(i) }
        </ol>
    }
    else if (variant == "b")
    {
        <header class="lb-header lb-header--compact">
            <div><span class="lb-eyebrow">Sổ học cộng đồng</span><h1>Thời gian học trong @period ngày</h1></div>
            @PeriodNav()
        </header>
        <section class="lb-ledger" aria-labelledby="ledger-title">
            <h2 id="ledger-title" class="visually-hidden">Danh sách xếp hạng</h2>
            <div class="lb-ledger-head"><span>Hạng</span><span>Người học</span><span>Buổi học</span><span>Thời gian</span></div>
            <ol class="lb-ledger-body">
                @for (var i = 0; i < people.Length; i++)
                {
                    <li class="lb-ledger-row @(i < 3 ? "is-top" : "")">
                        <span class="lb-ledger-rank">@(i + 1 < 10 ? $"0{i + 1}" : i + 1)</span>
                        <span class="lb-person"><span class="lb-avatar">@people[i].Item2</span><span>@people[i].Item1</span></span>
                        <span class="lb-sessions">@people[i].Item4</span><strong>@Duration(people[i].Item3)</strong>
                    </li>
                }
            </ol>
        </section>
        @CurrentUserStrip()
    }
    else
    {
        <div class="lb-journal">
            <aside class="lb-journal-context">
                <span class="lb-eyebrow">Nhật ký học tuần này</span><h1>Giữ nhịp đều, không cần chạy đua.</h1><p>Bảng xếp hạng chỉ gồm những người đã chọn xuất hiện.</p>
                @PeriodNav()
                <div class="lb-you-card"><span>Vị trí của bạn</span><strong>#27</strong><p>@Duration(2760) trong @period ngày</p><small>Cần thêm 18 phút để lên một bậc.</small></div>
                <div class="lb-privacy"><i class="ph ph-eye"></i><span>Bạn có thể tắt hiển thị trong cài đặt profile.</span></div>
            </aside>
            <main class="lb-journal-ranking">
                <div class="lb-journal-title"><span>Top 20</span><span>Cập nhật theo thời gian học chủ động</span></div>
                <ol class="lb-list lb-list--journal">
                    @for (var i = 0; i < people.Length; i++) { @RankRow(i) }
                </ol>
            </main>
        </div>
    }

    <nav class="lb-switcher" aria-label="Chuyển phương án prototype">
        <span>Kiểu giao diện</span>
        <a class="@(variant == "a" ? "active" : "")" href="@LinkFor("a")">A. Podium</a>
        <a class="@(variant == "b" ? "active" : "")" href="@LinkFor("b")">B. Sổ học</a>
        <a class="@(variant == "c" ? "active" : "")" href="@LinkFor("c")">C. Nhật ký</a>
        <span class="lb-switcher-divider"></span>
        <a href="@LinkFor(variant, null, "normal")">Top 20</a>
        <a href="@LinkFor(variant, null, "outside")">Ngoài top</a>
        <a href="@LinkFor(variant, null, "empty")">Trống</a>
    </nav>
</div>

@functions {
    private Microsoft.AspNetCore.Html.IHtmlContent PeriodNav()
    {
        var variant = ViewData["Variant"] as string ?? "a";
        var period = ViewData["Period"] as int? ?? 7;
        var state = ViewData["State"] as string ?? "outside";
        return new Microsoft.AspNetCore.Html.HtmlString($"""
            <nav class="lb-period" aria-label="Chọn khoảng thời gian">
                <a class="{(period == 7 ? "active" : "")}" href="/Prototype/Leaderboard?variant={variant}&amp;period=7&amp;state={state}">7 ngày</a>
                <a class="{(period == 30 ? "active" : "")}" href="/Prototype/Leaderboard?variant={variant}&amp;period=30&amp;state={state}">30 ngày</a>
            </nav>
        """);
    }
}

@{
    Microsoft.AspNetCore.Html.IHtmlContent RankRow(int i)
    {
        var p = people[i];
        return new Microsoft.AspNetCore.Html.HtmlString($"""
            <li class="lb-row"><span class="lb-row-rank">{i + 1:00}</span><span class="lb-person"><span class="lb-avatar">{p.Item2}</span><span><strong>{p.Item1}</strong><small>{p.Item4} buổi học</small></span></span><span class="lb-duration">{Duration(p.Item3)}</span></li>
        """);
    }
    Microsoft.AspNetCore.Html.IHtmlContent RankCard(int i)
    {
        var p = people[i];
        return new Microsoft.AspNetCore.Html.HtmlString($"""
            <article class="lb-runner"><span class="lb-medal lb-medal--{(i == 1 ? "silver" : "bronze")}"><i class="ph ph-medal" aria-hidden="true"></i><span>Hạng {i + 1}</span></span><span class="lb-avatar">{p.Item2}</span><span><strong>{p.Item1}</strong><small>{p.Item4} buổi học</small></span><b>{Duration(p.Item3)}</b></article>
        """);
    }
    Microsoft.AspNetCore.Html.IHtmlContent CurrentUserStrip()
    {
        if (state != "outside") return Microsoft.AspNetCore.Html.HtmlString.Empty;
        return new Microsoft.AspNetCore.Html.HtmlString($"""
            <section class="lb-current" aria-label="Vị trí của bạn"><span class="lb-current-label">Vị trí của bạn</span><span class="lb-current-rank">#27</span><span class="lb-person"><span class="lb-avatar">BT</span><span><strong>Bạn</strong><small>8 buổi học</small></span></span><span class="lb-current-progress">Cần thêm 18 phút để lên một bậc</span><span class="lb-duration">{Duration(2760)}</span></section>
        """);
    }
}
