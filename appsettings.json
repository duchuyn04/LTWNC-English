{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=LTWNC-English;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "AiProviders": {
    "Routing": {
      "OverallTimeoutSeconds": 90
    },
    "Health": {
      "WindowMinutes": 5,
      "MinimumSampleSize": 20,
      "ErrorRateThresholdPercent": 10,
      "UnstableFailureThreshold": 3
    }
  }
}
